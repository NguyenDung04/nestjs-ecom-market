<section class="relative bg-slate-50">
  <div class="absolute inset-0 -z-10">
    <div class="absolute left-0 top-0 h-72 w-72 rounded-full bg-primary-100/60 blur-3xl"></div>
    <div class="absolute right-0 top-40 h-80 w-80 rounded-full bg-sky-100/70 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-7xl px-5 py-10">
    <div class="mb-6 flex flex-wrap items-center gap-2 text-sm text-slate-500">
      <a href="/" class="font-medium hover:text-primary-600">Trang chủ</a>
      <i class="fa-solid fa-chevron-right text-xs"></i>
      <span class="font-semibold text-slate-800">Tài khoản cá nhân</span>
    </div>

    <div class="mb-6 overflow-hidden rounded-[32px] border border-slate-200 bg-white shadow-sm">
      <div class="relative overflow-hidden px-6 py-7 lg:px-8">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(14,165,233,0.14),_transparent_30%),linear-gradient(135deg,_rgba(248,250,252,0.96),_rgba(255,255,255,0.94))]"></div>
        <div class="relative flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-2xl">
            <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-primary-100 bg-primary-50/90 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-primary-700">
              <i class="fa-solid fa-id-card"></i>
              Client / Profile
            </div>

            <h1 class="text-3xl font-black tracking-tight text-slate-900">
              Hồ sơ cá nhân
            </h1>

            <p class="mt-3 text-sm leading-7 text-slate-600">
              Quản lý thông tin tài khoản, trạng thái truy cập và các thao tác bảo mật trong cùng một nơi.
            </p>
          </div>

          <a
            href="/products"
            class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm font-bold text-slate-700 transition hover:bg-slate-50"
          >
            <i class="fa-solid fa-box-open"></i>
            Tiếp tục mua sắm
          </a>
        </div>
      </div>
    </div>

    <div id="profileLoading" class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
        <div class="mx-auto h-24 w-24 animate-pulse rounded-full bg-slate-100"></div>
        <div class="mx-auto mt-5 h-5 w-40 animate-pulse rounded-full bg-slate-100"></div>
        <div class="mx-auto mt-3 h-4 w-52 animate-pulse rounded-full bg-slate-100"></div>
      </div>

      <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
        <div class="h-6 w-52 animate-pulse rounded-full bg-slate-100"></div>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <div class="h-12 animate-pulse rounded-2xl bg-slate-100"></div>
          <div class="h-12 animate-pulse rounded-2xl bg-slate-100"></div>
          <div class="h-12 animate-pulse rounded-2xl bg-slate-100"></div>
          <div class="h-12 animate-pulse rounded-2xl bg-slate-100"></div>
        </div>
      </div>
    </div>

    <div id="profileContent" class="hidden grid gap-6 lg:grid-cols-3">
      <aside class="space-y-6">
        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 text-center shadow-sm">
          <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-full bg-gradient-to-br from-primary-600 to-sky-500 text-3xl font-black text-white shadow-lg shadow-primary-600/20">
            <span id="profileAvatarText">U</span>
          </div>

          <h1 id="profileUsername" class="mt-5 text-2xl font-black text-slate-900">
            --
          </h1>

          <p id="profileEmail" class="mt-2 text-sm text-slate-500">
            --
          </p>

          <div class="mt-5 flex justify-center">
            <span id="profileRoleBadge" class="inline-flex items-center gap-2 rounded-full bg-slate-100 px-3 py-1 text-xs font-bold text-slate-700">
              <i class="fa-solid fa-user"></i>
              --
            </span>
          </div>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-black text-slate-900">Trạng thái tài khoản</h2>

          <div class="mt-5 space-y-4 text-sm">
            <div class="flex items-center justify-between border-b border-slate-100 pb-3">
              <span class="text-slate-500">ID</span>
              <span id="profileId" class="font-bold text-slate-900">--</span>
            </div>

            <div class="flex items-center justify-between border-b border-slate-100 pb-3">
              <span class="text-slate-500">Trạng thái</span>
              <span id="profileStatus" class="font-bold text-slate-900">--</span>
            </div>

            <div class="flex items-center justify-between">
              <span class="text-slate-500">Quyền</span>
              <span id="profileRoleText" class="font-bold text-slate-900">--</span>
            </div>
          </div>
        </div>

        <button
          type="button"
          onclick="logoutClient()"
          class="inline-flex w-full items-center justify-center gap-2 rounded-2xl border border-rose-200 bg-white px-5 py-3 text-sm font-bold text-rose-600 transition hover:bg-rose-50"
        >
          <i class="fa-solid fa-right-from-bracket"></i>
          Đăng xuất
        </button>
      </aside>

      <div class="space-y-6 lg:col-span-2">
        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <div>
              <h2 class="text-2xl font-black text-slate-900">
                Thông tin cá nhân
              </h2>

              <p class="mt-2 text-sm leading-6 text-slate-500">
                Cập nhật username và email của bạn. Vai trò tài khoản không thể thay đổi tại khu vực này.
              </p>
            </div>

            <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">
              Đồng bộ qua API `/api/users/me`
            </span>
          </div>

          <form id="profileForm" class="mt-6 grid gap-5 md:grid-cols-2">
            <div>
              <label class="mb-2 block text-sm font-semibold text-slate-700">
                Tên đăng nhập
              </label>

              <div class="relative">
                <i class="fa-regular fa-user absolute left-4 top-1/2 -translate-y-1/2 text-sm text-slate-400"></i>

                <input
                  id="username"
                  name="username"
                  type="text"
                  class="block w-full rounded-2xl border border-slate-300 bg-slate-50 py-3 pl-11 pr-4 text-sm text-slate-700 outline-none transition focus:border-primary-500 focus:bg-white focus:ring-4 focus:ring-primary-100"
                  placeholder="username"
                />
              </div>
            </div>

            <div>
              <label class="mb-2 block text-sm font-semibold text-slate-700">
                Email
              </label>

              <div class="relative">
                <i class="fa-regular fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-sm text-slate-400"></i>

                <input
                  id="email"
                  name="email"
                  type="email"
                  class="block w-full rounded-2xl border border-slate-300 bg-slate-50 py-3 pl-11 pr-4 text-sm text-slate-700 outline-none transition focus:border-primary-500 focus:bg-white focus:ring-4 focus:ring-primary-100"
                  placeholder="email@example.com"
                />
              </div>
            </div>

            <div class="md:col-span-2">
              <button
                id="profileSaveButton"
                type="submit"
                class="inline-flex items-center justify-center gap-2 rounded-2xl bg-primary-600 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-primary-600/20 transition hover:bg-primary-700 disabled:cursor-not-allowed disabled:opacity-70"
              >
                <i class="fa-solid fa-floppy-disk"></i>
                Lưu thay đổi
              </button>
            </div>
          </form>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-xl font-black text-slate-900">
              Bảo mật tài khoản
            </h2>

            <p class="mt-2 text-sm leading-6 text-slate-500">
              Nếu cần thay đổi mật khẩu, bạn có thể tạo yêu cầu reset trực tiếp từ đây.
            </p>

            <div class="mt-5 flex flex-col gap-3">
              <a
                href="/auth/forgot-password"
                class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-300 bg-white px-5 py-3 text-sm font-bold text-slate-700 transition hover:bg-slate-50"
              >
                <i class="fa-solid fa-key"></i>
                Quên mật khẩu
              </a>

              <a
                href="/auth/reset-password"
                class="inline-flex items-center justify-center gap-2 rounded-2xl bg-slate-900 px-5 py-3 text-sm font-bold text-white transition hover:bg-slate-800"
              >
                <i class="fa-solid fa-shield-halved"></i>
                Đặt lại mật khẩu
              </a>
            </div>
          </div>

          <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-xl font-black text-slate-900">
              Gợi ý sử dụng
            </h2>

            <div class="mt-4 space-y-3 text-sm text-slate-600">
              <div class="rounded-2xl bg-slate-50 p-4">
                Cập nhật email thường xuyên để không bỏ lỡ thông báo xác thực hoặc khôi phục tài khoản.
              </div>
              <div class="rounded-2xl bg-slate-50 p-4">
                Nếu là tài khoản admin, vai trò sẽ được gắn thêm ở khu vực quản trị sau khi đăng nhập.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div id="profileError" class="hidden rounded-[2rem] border border-rose-200 bg-rose-50 p-8 text-center">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-3xl bg-white text-rose-600">
        <i class="fa-solid fa-triangle-exclamation text-2xl"></i>
      </div>

      <h2 class="text-xl font-black text-rose-800">
        Chưa đăng nhập hoặc phiên đã hết hạn
      </h2>

      <p class="mt-2 text-sm text-rose-600">
        Vui lòng đăng nhập lại để xem và cập nhật thông tin tài khoản.
      </p>

      <a
        href="/auth/login"
        class="mt-5 inline-flex items-center justify-center gap-2 rounded-2xl bg-rose-600 px-5 py-3 text-sm font-bold text-white hover:bg-rose-700"
      >
        <i class="fa-solid fa-right-to-bracket"></i>
        Đăng nhập
      </a>
    </div>
  </div>
</section>

<script>
  let currentUser = null;

  document.addEventListener('DOMContentLoaded', function () {
    loadProfile();

    const profileForm = document.getElementById('profileForm');

    if (profileForm) {
      profileForm.addEventListener('submit', updateProfile);
    }
  });

  async function loadProfile() {
    const loading = document.getElementById('profileLoading');
    const content = document.getElementById('profileContent');
    const errorBox = document.getElementById('profileError');

    try {
      const response = await fetch('/api/users/me', {
        method: 'GET',
        credentials: 'include',
      });

      const result = await response.json();

      console.log('PROFILE_RESPONSE:', result);

      if (!response.ok || result.success === false) {
        throw new Error(result.message || 'Không tải được thông tin tài khoản');
      }

      const user = result.data?.data || result.data;

      if (!user) {
        throw new Error('Không tìm thấy thông tin người dùng');
      }

      currentUser = user;
      renderProfile(user);

      loading.classList.add('hidden');
      content.classList.remove('hidden');
    } catch (error) {
      console.error(error);

      loading.classList.add('hidden');
      errorBox.classList.remove('hidden');

      if (typeof showToast === 'function') {
        showToast(error.message || 'Vui lòng đăng nhập lại', 'error');
      }
    }
  }

  async function updateProfile(event) {
    event.preventDefault();

    const profileSaveButton = document.getElementById('profileSaveButton');

    const username = document.getElementById('username').value.trim();
    const email = document.getElementById('email').value.trim();

    profileSaveButton.disabled = true;
    profileSaveButton.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang lưu...';

    try {
      const response = await fetch('/api/users/me', {
        method: 'PATCH',
        credentials: 'include',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          username,
          email,
        }),
      });

      const result = await response.json();

      console.log('UPDATE_PROFILE_RESPONSE:', result);

      if (!response.ok || result.success === false) {
        throw new Error(result.message || 'Cập nhật thông tin thất bại');
      }

      const user = result.data?.data || result.data;

      if (user) {
        currentUser = user;
        renderProfile(user);
      }

      if (typeof showToast === 'function') {
        showToast(result.message || 'Cập nhật thông tin thành công', 'success');
      }
    } catch (error) {
      console.error(error);

      if (typeof showToast === 'function') {
        showToast(error.message || 'Cập nhật thông tin thất bại', 'error');
      } else {
        alert(error.message || 'Cập nhật thông tin thất bại');
      }
    } finally {
      profileSaveButton.disabled = false;
      profileSaveButton.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi';
    }
  }

  function renderProfile(user) {
    const username = user.username || 'User';
    const email = user.email || '--';
    const role = user.role || 'user';
    const isActive = user.isActive === true || user.is_active === true;

    document.getElementById('profileAvatarText').innerText = getAvatarText(username);
    document.getElementById('profileUsername').innerText = username;
    document.getElementById('profileEmail').innerText = email;
    document.getElementById('profileId').innerText = '#' + user.id;
    document.getElementById('profileStatus').innerText = isActive ? 'Đang hoạt động' : 'Bị khóa';
    document.getElementById('profileRoleText').innerText = role;

    document.getElementById('username').value = username;
    document.getElementById('email').value = email;

    document.getElementById('profileRoleBadge').innerHTML = createRoleBadge(role);
  }

  function createRoleBadge(role) {
    if (role === 'admin') {
      return '<i class="fa-solid fa-user-shield"></i> Admin';
    }

    return '<i class="fa-solid fa-user"></i> User';
  }

  function getAvatarText(username) {
    const text = String(username || 'U').trim();

    if (!text) return 'U';

    return text.slice(0, 2).toUpperCase();
  }

  async function logoutClient() {
    try {
      await fetch('/api/auth/logout', {
        method: 'POST',
        credentials: 'include',
      });

      if (typeof showToast === 'function') {
        showToast('Đăng xuất thành công', 'success');
      }

      setTimeout(function () {
        window.location.href = '/auth/login';
      }, 500);
    } catch (error) {
      console.error(error);

      if (typeof showToast === 'function') {
        showToast('Đăng xuất thất bại', 'error');
      } else {
        alert('Đăng xuất thất bại');
      }
    }
  }
</script>
