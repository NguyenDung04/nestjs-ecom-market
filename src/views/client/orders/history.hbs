<section class="mx-auto max-w-7xl px-4 py-8">
  <h1 class="mb-6 text-3xl font-bold text-slate-900">{{title}}</h1>

  <div class="overflow-hidden rounded-2xl border bg-white shadow-sm">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-100">
        <tr>
          <th class="px-5 py-4">Mã đơn</th>
          <th class="px-5 py-4">Ngày đặt</th>
          <th class="px-5 py-4">Tổng tiền</th>
          <th class="px-5 py-4">Trạng thái</th>
          <th class="px-5 py-4">Thao tác</th>
        </tr>
      </thead>

      <tbody>
        {{#each orders}}
          <tr class="border-t">
            <td class="px-5 py-4 font-semibold">{{this.code}}</td>
            <td class="px-5 py-4">{{this.createdAt}}</td>
            <td class="px-5 py-4">{{formatCurrency this.total}}</td>
            <td class="px-5 py-4">{{orderStatusLabel this.status}}</td>
            <td class="px-5 py-4">
              <a href="/orders/{{this.id}}" class="font-semibold" style="color: var(--teal-600);">
                Chi tiết
              </a>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</section>