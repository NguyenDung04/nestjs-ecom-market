<main class="min-h-screen bg-gray-50">

  <!-- ===== BANNER ===== -->
  <section class="relative overflow-hidden">
    <div class="banner-gradient relative">
      <!-- Decorative elements -->
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-20 -right-20 w-96 h-96 bg-white opacity-5 rounded-full"></div>
        <div class="absolute -bottom-32 -left-32 w-[500px] h-[500px] bg-white opacity-5 rounded-full"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-white opacity-[0.02] rounded-full"></div>
      </div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-24 relative z-10">
        <div class="grid lg:grid-cols-2 gap-10 items-center">
          <!-- Text -->
          <div class="text-white space-y-6">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/15 backdrop-blur-sm rounded-full text-sm font-medium sale-badge-pulse">
              <i class="fa-solid fa-fire text-yellow-300"></i>
              Ưu đãi hôm nay
            </div>
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight">
              Mua sắm thông minh<br>
              <span class="text-teal-100">Tiết kiệm hơn</span>
            </h1>
            <p class="text-teal-100/80 text-base sm:text-lg max-w-md leading-relaxed">
              Khám phá hàng ngàn sản phẩm chất lượng với giá ưu đãi đặc biệt. Giao hàng nhanh, đổi trả dễ dàng.
            </p>
            <div class="flex flex-wrap gap-3 pt-2">
              <a href="/products" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-teal-700 font-semibold rounded-xl hover:bg-teal-50 transition-all hover:shadow-lg hover:shadow-black/10 hover:-translate-y-0.5">
                <i class="fa-solid fa-bag-shopping"></i> Mua ngay
              </a>
              <a href="/promotions" class="inline-flex items-center gap-2 px-6 py-3 border-2 border-white/40 text-white font-semibold rounded-xl hover:bg-white/10 transition-all hover:-translate-y-0.5">
                <i class="fa-solid fa-percent"></i> Xem khuyến mãi
              </a>
            </div>
            <!-- Stats -->
            <div class="flex gap-8 pt-4">
              <div>
                <p class="text-2xl font-bold">10K+</p>
                <p class="text-teal-100/60 text-sm">Sản phẩm</p>
              </div>
              <div>
                <p class="text-2xl font-bold">50K+</p>
                <p class="text-teal-100/60 text-sm">Khách hàng</p>
              </div>
              <div>
                <p class="text-2xl font-bold">4.9<i class="fa-solid fa-star text-yellow-300 text-sm ml-1"></i></p>
                <p class="text-teal-100/60 text-sm">Đánh giá</p>
              </div>
            </div>
          </div>
          <!-- Image placeholder -->
          <div class="hidden lg:flex justify-center">
            <div class="relative">
              <div class="w-80 h-80 xl:w-96 xl:h-96 bg-white/10 backdrop-blur-sm rounded-3xl border border-white/20 flex items-center justify-center">
                <div class="text-center text-white/60">
                  <i class="fa-solid fa-image text-6xl mb-3 block"></i>
                  <p class="text-sm">Banner Image</p>
                </div>
              </div>
              <!-- Floating badges -->
              <div class="absolute -top-4 -left-4 bg-white text-teal-700 px-4 py-2 rounded-xl shadow-lg font-bold text-sm flex items-center gap-2">
                <i class="fa-solid fa-bolt text-yellow-500"></i> Giảm đến 50%
              </div>
              <div class="absolute -bottom-4 -right-4 bg-white text-teal-700 px-4 py-2 rounded-xl shadow-lg font-bold text-sm flex items-center gap-2">
                <i class="fa-solid fa-truck-fast text-teal-500"></i> Freeship
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== DANH MỤC NỔI BẬT ===== -->
  <section class="py-14 sm:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section header -->
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-xl sm:text-2xl font-bold text-gray-800 flex items-center gap-2">
            <i class="fa-solid fa-layer-group text-teal-500"></i>
            Danh mục nổi bật
          </h2>
          <p class="text-gray-400 text-sm mt-1">Khám phá theo nhóm sản phẩm yêu thích</p>
        </div>
        <a href="/categories" class="text-sm font-medium text-teal-600 hover:text-teal-700 transition-colors flex items-center gap-1">
          Xem tất cả <i class="fa-solid fa-arrow-right text-xs"></i>
        </a>
      </div>

      {{#if categories}}
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4">
        {{#each categories}}
        <a href="/products?category={{slug}}" class="category-card bg-white rounded-2xl border border-gray-100 p-5 text-center group cursor-pointer">
          <div class="w-14 h-14 mx-auto mb-3 bg-teal-50 rounded-2xl flex items-center justify-center group-hover:bg-teal-100 transition-colors">
            {{#if icon}}
            <i class="{{icon}} text-2xl text-teal-500"></i>
            {{else}}
            <i class="fa-solid fa-folder text-2xl text-teal-500"></i>
            {{/if}}
          </div>
          <h3 class="text-sm font-semibold text-gray-700 group-hover:text-teal-600 transition-colors line-clamp-1">{{name}}</h3>
          <p class="text-xs text-gray-400 mt-1">{{productCount}} sản phẩm</p>
        </a>
        {{/each}}
      </div>
      {{else}}
      <!-- Empty state -->
      <div class="bg-white rounded-2xl border border-gray-100 py-16 text-center">
        <div class="empty-float inline-block mb-4">
          <i class="fa-solid fa-folder-open text-5xl text-gray-200"></i>
        </div>
        <p class="text-gray-400 font-medium">Chưa có danh mục nào</p>
        <p class="text-gray-300 text-sm mt-1">Danh mục sẽ hiển thị khi được thêm vào</p>
      </div>
      {{/if}}
    </div>
  </section>

  <!-- ===== SẢN PHẨM MỚI ===== -->
  <section class="py-14 sm:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-xl sm:text-2xl font-bold text-gray-800 flex items-center gap-2">
            <i class="fa-solid fa-sparkles text-teal-500"></i>
            Sản phẩm mới
          </h2>
          <p class="text-gray-400 text-sm mt-1">Những sản phẩm vừa được cập nhật</p>
        </div>
        <a href="/products?sort=newest" class="text-sm font-medium text-teal-600 hover:text-teal-700 transition-colors flex items-center gap-1">
          Xem tất cả <i class="fa-solid fa-arrow-right text-xs"></i>
        </a>
      </div>

      {{#if newProducts}}
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 sm:gap-5">
        {{#each newProducts}}
        <div class="product-card bg-white rounded-2xl border border-gray-100 overflow-hidden group">
          <!-- Image -->
          <a href="/products/{{id}}" class="block relative aspect-square bg-gray-50 overflow-hidden">
            <img
              src="{{imageUrl}}"
              alt="{{name}}"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              onerror="this.onerror=null; this.parentElement.innerHTML='<div class=\'w-full h-full flex items-center justify-center text-gray-200\'><i class=\'fa-solid fa-image text-4xl\'></i></div>'"
            >
            <span class="absolute top-3 left-3 px-2.5 py-1 bg-teal-500 text-white text-xs font-bold rounded-lg">
              Mới
            </span>
          </a>
          <!-- Info -->
          <div class="p-3 sm:p-4">
            <a href="/products/{{id}}" class="block">
              <h3 class="text-sm font-medium text-gray-700 line-clamp-2 hover:text-teal-600 transition-colors min-h-[40px]">{{name}}</h3>
            </a>
            <div class="mt-2">
              <span class="text-base font-bold text-teal-600">{{formattedPrice}}</span>
            </div>
            <div class="mt-3 flex gap-2">
              <a href="/products/{{id}}" class="flex-1 text-center py-2 rounded-lg border border-gray-200 text-gray-500 text-xs font-medium hover:border-teal-300 hover:text-teal-600 hover:bg-teal-50 transition-all">
                <i class="fa-solid fa-eye mr-1"></i> Xem
              </a>
              <button onclick="addToCart({{id}})" class="flex-1 py-2 rounded-lg bg-teal-500 text-white text-xs font-medium hover:bg-teal-600 transition-colors">
                <i class="fa-solid fa-plus mr-1"></i> Giỏ hàng
              </button>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="bg-gray-50 rounded-2xl py-16 text-center">
        <div class="empty-float inline-block mb-4">
          <i class="fa-solid fa-box-open text-5xl text-gray-200"></i>
        </div>
        <p class="text-gray-400 font-medium">Chưa có sản phẩm mới</p>
        <p class="text-gray-300 text-sm mt-1">Sản phẩm mới sẽ xuất hiện tại đây</p>
      </div>
      {{/if}}
    </div>
  </section>

  <!-- ===== SẢN PHẨM BÁN CHẠY ===== -->
  <section class="py-14 sm:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-xl sm:text-2xl font-bold text-gray-800 flex items-center gap-2">
            <i class="fa-solid fa-fire-flame-curved text-orange-500"></i>
            Sản phẩm bán chạy
          </h2>
          <p class="text-gray-400 text-sm mt-1">Sản phẩm được yêu thích nhất</p>
        </div>
        <a href="/products?sort=best-selling" class="text-sm font-medium text-teal-600 hover:text-teal-700 transition-colors flex items-center gap-1">
          Xem tất cả <i class="fa-solid fa-arrow-right text-xs"></i>
        </a>
      </div>

      {{#if bestSellingProducts}}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
        {{#each bestSellingProducts}}
        <div class="product-card bg-white rounded-2xl border border-gray-100 overflow-hidden group flex flex-col sm:flex-row">
          <!-- Rank + Image -->
          <div class="relative sm:w-44 flex-shrink-0">
            <a href="/products/{{id}}" class="block aspect-square sm:aspect-auto sm:h-full bg-gray-50 overflow-hidden">
              <img
                src="{{imageUrl}}"
                alt="{{name}}"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                onerror="this.onerror=null; this.parentElement.innerHTML='<div class=\'w-full h-full flex items-center justify-center text-gray-200\'><i class=\'fa-solid fa-image text-4xl\'></i></div>'"
              >
            </a>
            <span class="rank-badge rank-{{@index}} absolute top-3 left-3">{{add @index 1}}</span>
            <span class="absolute top-3 right-3 px-2 py-0.5 bg-orange-500 text-white text-xs font-bold rounded-md">
              Bán chạy
            </span>
          </div>
          <!-- Info -->
          <div class="p-4 flex-1 flex flex-col justify-between">
            <div>
              <a href="/products/{{id}}">
                <h3 class="text-sm font-semibold text-gray-700 line-clamp-2 hover:text-teal-600 transition-colors">{{name}}</h3>
              </a>
              <div class="mt-2 flex items-center gap-2 text-xs text-gray-400">
                <i class="fa-solid fa-cart-arrow-down"></i>
                <span>Đã bán {{soldCount}}</span>
              </div>
              <div class="mt-2">
                {{#if formattedSalePrice}}
                <span class="text-lg font-bold text-teal-600">{{formattedSalePrice}}</span>
                <span class="text-sm text-gray-400 line-through ml-2">{{formattedOriginalPrice}}</span>
                {{else}}
                <span class="text-lg font-bold text-teal-600">{{formattedPrice}}</span>
                {{/if}}
              </div>
            </div>
            <div class="mt-3 flex gap-2">
              <a href="/products/{{id}}" class="flex-1 text-center py-2 rounded-lg border border-gray-200 text-gray-500 text-xs font-medium hover:border-teal-300 hover:text-teal-600 hover:bg-teal-50 transition-all">
                <i class="fa-solid fa-eye mr-1"></i> Xem chi tiết
              </a>
              <button onclick="addToCart({{id}})" class="flex-1 py-2 rounded-lg bg-teal-500 text-white text-xs font-medium hover:bg-teal-600 transition-colors">
                <i class="fa-solid fa-cart-plus mr-1"></i> Thêm vào giỏ
              </button>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="bg-white rounded-2xl border border-gray-100 py-16 text-center">
        <div class="empty-float inline-block mb-4">
          <i class="fa-solid fa-chart-line text-5xl text-gray-200"></i>
        </div>
        <p class="text-gray-400 font-medium">Chưa có dữ liệu bán chạy</p>
        <p class="text-gray-300 text-sm mt-1">Sản phẩm bán chạy sẽ hiển thị tại đây</p>
      </div>
      {{/if}}
    </div>
  </section>

  <!-- ===== SẢN PHẨM KHUYẾN MÃI ===== -->
  <section class="py-14 sm:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-xl sm:text-2xl font-bold text-gray-800 flex items-center gap-2">
            <i class="fa-solid fa-tags text-red-500"></i>
            Khuyến mãi hot
          </h2>
          <p class="text-gray-400 text-sm mt-1">Đừng bỏ lỡ những deal tốt nhất</p>
        </div>
        <a href="/promotions" class="text-sm font-medium text-teal-600 hover:text-teal-700 transition-colors flex items-center gap-1">
          Xem tất cả khuyến mãi <i class="fa-solid fa-arrow-right text-xs"></i>
        </a>
      </div>

      {{#if saleProducts}}
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 sm:gap-5">
        {{#each saleProducts}}
        <div class="product-card bg-white rounded-2xl border border-red-100 overflow-hidden group relative">
          <!-- Discount badge -->
          <div class="absolute top-3 right-3 z-10">
            <span class="sale-badge-pulse inline-flex items-center px-2 py-1 bg-red-500 text-white text-xs font-bold rounded-lg shadow-lg">
              -{{discountPercent}}%
            </span>
          </div>
          <!-- Image -->
          <a href="/products/{{id}}" class="block relative aspect-square bg-gray-50 overflow-hidden">
            <img
              src="{{imageUrl}}"
              alt="{{name}}"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              onerror="this.onerror=null; this.parentElement.innerHTML='<div class=\'w-full h-full flex items-center justify-center text-gray-200\'><i class=\'fa-solid fa-image text-4xl\'></i></div>'"
            >
          </a>
          <!-- Info -->
          <div class="p-3 sm:p-4">
            <a href="/products/{{id}}">
              <h3 class="text-sm font-medium text-gray-700 line-clamp-2 hover:text-teal-600 transition-colors min-h-[40px]">{{name}}</h3>
            </a>
            <div class="mt-2 space-y-0.5">
              <span class="text-base font-bold text-red-500">{{formattedSalePrice}}</span>
              <p class="text-xs text-gray-400 line-through">{{formattedOriginalPrice}}</p>
            </div>
            <!-- Savings -->
            <div class="mt-2 inline-flex items-center gap-1 px-2 py-0.5 bg-red-50 text-red-500 text-xs font-medium rounded">
              <i class="fa-solid fa-piggy-bank"></i>
              Tiết kiệm {{formattedSaving}}
            </div>
            <div class="mt-3 flex gap-2">
              <a href="/products/{{id}}" class="flex-1 text-center py-2 rounded-lg border border-gray-200 text-gray-500 text-xs font-medium hover:border-teal-300 hover:text-teal-600 hover:bg-teal-50 transition-all">
                <i class="fa-solid fa-eye mr-1"></i> Xem
              </a>
              <button onclick="addToCart({{id}})" class="flex-1 py-2 rounded-lg bg-red-500 text-white text-xs font-medium hover:bg-red-600 transition-colors">
                <i class="fa-solid fa-bolt mr-1"></i> Mua
              </button>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="bg-gray-50 rounded-2xl py-16 text-center">
        <div class="empty-float inline-block mb-4">
          <i class="fa-solid fa-tag text-5xl text-gray-200"></i>
        </div>
        <p class="text-gray-400 font-medium">Chưa có khuyến mãi nào</p>
        <p class="text-gray-300 text-sm mt-1">Khuyến mãi sẽ xuất hiện tại đây khi có chương trình</p>
      </div>
      {{/if}}
    </div>
  </section>

  <!-- ===== CTA TRUST ===== -->
  <section class="py-14 sm:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white rounded-2xl border border-gray-100 p-6 text-center group hover:border-teal-200 transition-colors">
          <div class="w-12 h-12 mx-auto mb-3 bg-teal-50 rounded-xl flex items-center justify-center group-hover:bg-teal-100 transition-colors">
            <i class="fa-solid fa-truck-fast text-xl text-teal-500"></i>
          </div>
          <h3 class="text-sm font-semibold text-gray-700">Giao hàng nhanh</h3>
          <p class="text-xs text-gray-400 mt-1">Toàn quốc 1-3 ngày</p>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 p-6 text-center group hover:border-teal-200 transition-colors">
          <div class="w-12 h-12 mx-auto mb-3 bg-teal-50 rounded-xl flex items-center justify-center group-hover:bg-teal-100 transition-colors">
            <i class="fa-solid fa-shield-halved text-xl text-teal-500"></i>
          </div>
          <h3 class="text-sm font-semibold text-gray-700">Chính hãng 100%</h3>
          <p class="text-xs text-gray-400 mt-1">Cam kết chất lượng</p>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 p-6 text-center group hover:border-teal-200 transition-colors">
          <div class="w-12 h-12 mx-auto mb-3 bg-teal-50 rounded-xl flex items-center justify-center group-hover:bg-teal-100 transition-colors">
            <i class="fa-solid fa-rotate-left text-xl text-teal-500"></i>
          </div>
          <h3 class="text-sm font-semibold text-gray-700">Đổi trả dễ dàng</h3>
          <p class="text-xs text-gray-400 mt-1">Trong 30 ngày</p>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 p-6 text-center group hover:border-teal-200 transition-colors">
          <div class="w-12 h-12 mx-auto mb-3 bg-teal-50 rounded-xl flex items-center justify-center group-hover:bg-teal-100 transition-colors">
            <i class="fa-solid fa-headset text-xl text-teal-500"></i>
          </div>
          <h3 class="text-sm font-semibold text-gray-700">Hỗ trợ 24/7</h3>
          <p class="text-xs text-gray-400 mt-1">Tư vấn miễn phí</p>
        </div>
      </div>
    </div>
  </section>

</main>