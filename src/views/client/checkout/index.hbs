<section class="mx-auto max-w-5xl px-4 py-8">
  <h1 class="mb-6 text-3xl font-bold text-slate-900">{{title}}</h1>

  <form class="grid gap-6 rounded-2xl bg-white p-6 shadow-sm md:grid-cols-2">
    <div>
      <label class="mb-1 block text-sm font-medium">Họ tên người nhận</label>
      <input class="w-full rounded-xl border px-4 py-3" placeholder="Nguyễn Văn A" />
    </div>

    <div>
      <label class="mb-1 block text-sm font-medium">Số điện thoại</label>
      <input class="w-full rounded-xl border px-4 py-3" placeholder="0900000000" />
    </div>

    <div class="md:col-span-2">
      <label class="mb-1 block text-sm font-medium">Địa chỉ giao hàng</label>
      <input class="w-full rounded-xl border px-4 py-3" placeholder="Địa chỉ chi tiết" />
    </div>

    <div class="md:col-span-2">
      <button
        type="button"
        class="rounded-xl px-5 py-3 font-semibold text-white"
        style="background: var(--teal-600);"
      >
        Xác nhận đặt hàng
      </button>
    </div>
  </form>
</section>