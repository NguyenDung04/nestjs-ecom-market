<section class="relative bg-slate-50">
  <div class="absolute inset-0 -z-10">
    <div class="absolute left-0 top-0 h-72 w-72 rounded-full bg-primary-100/60 blur-3xl"></div>
    <div class="absolute right-0 top-56 h-80 w-80 rounded-full bg-sky-100/60 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-7xl px-5 py-10">
    <div class="mb-6 flex flex-wrap items-center gap-2 text-sm text-slate-500">
      <a href="/" class="font-medium hover:text-primary-600">Trang chủ</a>
      <i class="fa-solid fa-chevron-right text-xs"></i>
      <span class="font-semibold text-slate-800">Sản phẩm</span>
    </div>

    <div class="overflow-hidden rounded-[32px] border border-slate-200 bg-white shadow-sm">
      <div class="relative px-6 py-7 lg:px-8">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(14,165,233,0.14),_transparent_30%),linear-gradient(135deg,_rgba(248,250,252,0.96),_rgba(255,255,255,0.94))]"></div>
        <div class="relative flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-2xl">
            <div class="mb-3 inline-flex items-center gap-2 rounded-full bg-primary-50 px-3 py-1 text-xs font-bold text-primary-700">
              <i class="fa-solid fa-box-open"></i>
              Client / Products
            </div>

            <h1 class="text-3xl font-black tracking-tight text-slate-900">
              Khám phá sản phẩm
            </h1>

            <p class="mt-3 text-sm leading-7 text-slate-500">
              Tìm sản phẩm theo danh mục, lọc nhanh hơn và xem thông tin trực quan hơn với layout tối ưu cho người mua.
            </p>
          </div>

          <div class="grid gap-3 sm:grid-cols-2 lg:flex">
            <div class="relative">
              <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-sm text-slate-400"></i>

              <input
                id="productSearchInput"
                type="text"
                placeholder="Tìm kiếm sản phẩm..."
                class="w-full rounded-2xl border border-slate-300 bg-white py-3 pl-11 pr-4 text-sm text-slate-700 outline-none transition focus:border-primary-500 focus:ring-4 focus:ring-primary-100 lg:w-80"
              />
            </div>

            <select
              id="categoryFilter"
              class="rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-700 outline-none transition focus:border-primary-500 focus:ring-4 focus:ring-primary-100"
            >
              <option value="">Tất cả danh mục</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-6 grid gap-5 md:grid-cols-3">
      <div class="rounded-[28px] border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-slate-500">Tổng sản phẩm</p>
            <h2 id="totalProductsStat" class="mt-2 text-3xl font-black text-slate-900">--</h2>
          </div>

          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-sky-50 text-sky-600">
            <i class="fa-solid fa-boxes-stacked text-xl"></i>
          </div>
        </div>
      </div>

      <div class="rounded-[28px] border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-slate-500">Đang hiển thị</p>
            <h2 id="visibleProductsStat" class="mt-2 text-3xl font-black text-slate-900">--</h2>
          </div>

          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-600">
            <i class="fa-solid fa-circle-check text-xl"></i>
          </div>
        </div>
      </div>

      <div class="rounded-[28px] border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-slate-500">Danh mục</p>
            <h2 id="totalCategoriesStat" class="mt-2 text-3xl font-black text-slate-900">--</h2>
          </div>

          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-violet-50 text-violet-600">
            <i class="fa-solid fa-layer-group text-xl"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-6 overflow-hidden rounded-[32px] border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-200 px-5 py-5 sm:px-6">
        <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
          <div>
            <h2 class="text-xl font-black text-slate-900">Sản phẩm nổi bật</h2>
            <p class="mt-1 text-sm text-slate-500">
              Dữ liệu được tải từ API <span class="font-semibold text-slate-700">/api/products</span>.
            </p>
          </div>

          <button
            type="button"
            onclick="resetFilters()"
            class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-300 bg-white px-4 py-2.5 text-sm font-bold text-slate-700 transition hover:bg-slate-50"
          >
            <i class="fa-solid fa-rotate-left"></i>
            Làm mới bộ lọc
          </button>
        </div>
      </div>

      <div class="p-5 sm:p-6">
        <div id="productLoadingGrid" class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          <div class="rounded-[28px] border border-slate-200 bg-white p-4 shadow-sm">
            <div class="h-44 animate-pulse rounded-2xl bg-slate-100"></div>
            <div class="mt-4 h-4 w-3/4 animate-pulse rounded-full bg-slate-100"></div>
            <div class="mt-3 h-4 w-1/2 animate-pulse rounded-full bg-slate-100"></div>
            <div class="mt-5 h-10 w-full animate-pulse rounded-2xl bg-slate-100"></div>
          </div>
          <div class="rounded-[28px] border border-slate-200 bg-white p-4 shadow-sm">
            <div class="h-44 animate-pulse rounded-2xl bg-slate-100"></div>
            <div class="mt-4 h-4 w-3/4 animate-pulse rounded-full bg-slate-100"></div>
            <div class="mt-3 h-4 w-1/2 animate-pulse rounded-full bg-slate-100"></div>
            <div class="mt-5 h-10 w-full animate-pulse rounded-2xl bg-slate-100"></div>
          </div>
          <div class="rounded-[28px] border border-slate-200 bg-white p-4 shadow-sm">
            <div class="h-44 animate-pulse rounded-2xl bg-slate-100"></div>
            <div class="mt-4 h-4 w-3/4 animate-pulse rounded-full bg-slate-100"></div>
            <div class="mt-3 h-4 w-1/2 animate-pulse rounded-full bg-slate-100"></div>
            <div class="mt-5 h-10 w-full animate-pulse rounded-2xl bg-slate-100"></div>
          </div>
          <div class="rounded-[28px] border border-slate-200 bg-white p-4 shadow-sm">
            <div class="h-44 animate-pulse rounded-2xl bg-slate-100"></div>
            <div class="mt-4 h-4 w-3/4 animate-pulse rounded-full bg-slate-100"></div>
            <div class="mt-3 h-4 w-1/2 animate-pulse rounded-full bg-slate-100"></div>
            <div class="mt-5 h-10 w-full animate-pulse rounded-2xl bg-slate-100"></div>
          </div>
        </div>

        <div id="productGrid" class="hidden grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"></div>

        <div id="productEmptyState" class="hidden py-14">
          <div class="mx-auto flex max-w-md flex-col items-center justify-center text-center">
            <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-3xl bg-slate-100 text-slate-400">
              <i class="fa-solid fa-box-open text-2xl"></i>
            </div>

            <h3 class="text-lg font-black text-slate-900">
              Không tìm thấy sản phẩm
            </h3>

            <p class="mt-2 text-sm leading-7 text-slate-500">
              Không có sản phẩm phù hợp với bộ lọc hiện tại. Hãy thử đổi từ khóa hoặc chọn lại danh mục.
            </p>

            <button
              type="button"
              onclick="resetFilters()"
              class="mt-5 rounded-2xl bg-primary-600 px-5 py-3 text-sm font-bold text-white hover:bg-primary-700"
            >
              Xóa bộ lọc
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  let allProducts = [];
  let allCategories = [];

  document.addEventListener('DOMContentLoaded', function () {
    loadClientProducts();
    loadClientCategories();

    document.getElementById('productSearchInput').addEventListener('input', function () {
      renderProducts();
    });

    document.getElementById('categoryFilter').addEventListener('change', function () {
      renderProducts();
    });
  });

  async function loadClientProducts() {
    const loadingGrid = document.getElementById('productLoadingGrid');
    const productGrid = document.getElementById('productGrid');

    try {
      loadingGrid.classList.remove('hidden');
      productGrid.classList.add('hidden');

      const response = await fetch('/api/products', {
        method: 'GET',
        credentials: 'include',
      });

      const result = await response.json();

      console.log('CLIENT_PRODUCTS_RESPONSE:', result);

      if (!response.ok || result.success === false) {
        throw new Error(result.message || 'Không tải được sản phẩm');
      }

      const payload = result.data?.data || result.data;
      allProducts = Array.isArray(payload) ? payload : payload?.items || payload?.data || [];

      renderProducts();
    } catch (error) {
      console.error(error);

      if (typeof showToast === 'function') {
        showToast(error.message || 'Không tải được danh sách sản phẩm', 'error');
      }

      allProducts = [];
      renderProducts();
    } finally {
      loadingGrid.classList.add('hidden');
      productGrid.classList.remove('hidden');
    }
  }

  async function loadClientCategories() {
    try {
      const response = await fetch('/api/categories', {
        method: 'GET',
        credentials: 'include',
      });

      const result = await response.json();

      console.log('CLIENT_CATEGORIES_RESPONSE:', result);

      if (!response.ok || result.success === false) {
        throw new Error(result.message || 'Không tải được danh mục');
      }

      const payload = result.data?.data || result.data;
      allCategories = Array.isArray(payload) ? payload : payload?.items || payload?.data || [];

      renderCategoryOptions();
      updateStats();
    } catch (error) {
      console.error(error);
      allCategories = [];
      renderCategoryOptions();
      updateStats();
    }
  }

  function renderCategoryOptions() {
    const categoryFilter = document.getElementById('categoryFilter');

    categoryFilter.innerHTML = '<option value="">Tất cả danh mục</option>';

    allCategories.forEach(function (category) {
      const option = document.createElement('option');
      option.value = category.id;
      option.textContent = category.name || category.title || 'Danh mục #' + category.id;
      categoryFilter.appendChild(option);
    });
  }

  function renderProducts() {
    const productGrid = document.getElementById('productGrid');
    const emptyState = document.getElementById('productEmptyState');
    const keyword = document.getElementById('productSearchInput').value.trim().toLowerCase();
    const categoryId = document.getElementById('categoryFilter').value;

    const filteredProducts = allProducts.filter(function (product) {
      const name = String(product.name || '').toLowerCase();
      const description = String(product.description || '').toLowerCase();
      const productCategoryId = String(product.categoryId || product.category_id || product.category?.id || '');

      const matchKeyword = !keyword || name.includes(keyword) || description.includes(keyword);
      const matchCategory = !categoryId || productCategoryId === String(categoryId);

      return matchKeyword && matchCategory;
    });

    productGrid.innerHTML = '';

    if (filteredProducts.length === 0) {
      productGrid.classList.add('hidden');
      emptyState.classList.remove('hidden');
      updateStats(filteredProducts.length);
      return;
    }

    emptyState.classList.add('hidden');
    productGrid.classList.remove('hidden');

    filteredProducts.forEach(function (product) {
      productGrid.insertAdjacentHTML('beforeend', createProductCard(product));
    });

    updateStats(filteredProducts.length);
  }

  function createProductCard(product) {
    const imageUrl = normalizeImageUrl(product.image || product.imageUrl || product.image_url);
    const categoryName =
      product.category?.name ||
      product.categoryName ||
      product.category?.title ||
      'Chưa phân loại';

    const description = product.description || 'Sản phẩm hiện chưa có mô tả.';
    const isActive = product.isActive === true || product.is_active === true;

    return `
      <article class="group overflow-hidden rounded-[28px] border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-md">
        <a href="/products/${product.id}" class="block">
          <div class="relative h-52 overflow-hidden bg-slate-100">
            <img
              src="${escapeHtml(imageUrl)}"
              alt="${escapeHtml(product.name || 'Product')}"
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
              onerror="this.src='https://placehold.co/600x400?text=Product'"
            />

            <div class="absolute left-4 top-4">
              ${
                isActive
                  ? '<span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-3 py-1 text-xs font-bold text-emerald-700 shadow-sm"><span class="h-1.5 w-1.5 rounded-full bg-emerald-600"></span>Đang bán</span>'
                  : '<span class="inline-flex items-center gap-1 rounded-full bg-amber-50 px-3 py-1 text-xs font-bold text-amber-700 shadow-sm"><span class="h-1.5 w-1.5 rounded-full bg-amber-600"></span>Tạm ẩn</span>'
              }
            </div>
          </div>
        </a>

        <div class="p-5">
          <div class="mb-3 flex items-center justify-between gap-3">
            <span class="line-clamp-1 rounded-full bg-primary-50 px-3 py-1 text-xs font-bold text-primary-700">
              ${escapeHtml(categoryName)}
            </span>

            <span class="text-xs font-semibold text-slate-400">
              #${product.id}
            </span>
          </div>

          <a href="/products/${product.id}" class="block">
            <h3 class="line-clamp-2 min-h-[3.5rem] text-lg font-black leading-7 text-slate-900 transition group-hover:text-primary-600">
              ${escapeHtml(product.name || 'Sản phẩm chưa đặt tên')}
            </h3>
          </a>

          <p class="mt-2 line-clamp-2 min-h-[2.5rem] text-sm leading-6 text-slate-500">
            ${escapeHtml(description)}
          </p>

          <div class="mt-5 flex items-center justify-between gap-3">
            <div>
              <p class="text-xs font-medium text-slate-400">Giá bán</p>
              <p class="mt-1 text-lg font-black text-primary-600">
                ${formatCurrency(product.price)}
              </p>
            </div>

            <a
              href="/products/${product.id}"
              class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-primary-600 text-white shadow-lg shadow-primary-600/20 transition hover:bg-primary-700"
              title="Xem chi tiết"
            >
              <i class="fa-solid fa-arrow-right"></i>
            </a>
          </div>
        </div>
      </article>
    `;
  }

  function resetFilters() {
    document.getElementById('productSearchInput').value = '';
    document.getElementById('categoryFilter').value = '';
    renderProducts();

    if (typeof showToast === 'function') {
      showToast('Đã làm mới bộ lọc', 'success');
    }
  }

  function updateStats(visibleCount) {
    const totalProducts = allProducts.length;
    const activeProducts = allProducts.filter(function (product) {
      return product.isActive === true || product.is_active === true;
    }).length;

    document.getElementById('totalProductsStat').innerText = totalProducts;
    document.getElementById('visibleProductsStat').innerText =
      typeof visibleCount === 'number' ? visibleCount : activeProducts;
    document.getElementById('totalCategoriesStat').innerText = allCategories.length;
  }

  function normalizeImageUrl(image) {
    if (!image) {
      return 'https://placehold.co/600x400?text=Product';
    }

    if (image.startsWith('http://') || image.startsWith('https://')) {
      return image;
    }

    if (image.startsWith('/public/')) {
      return image;
    }

    if (image.startsWith('public/')) {
      return '/' + image;
    }

    return '/public/' + image.replace(/^\/+/, '');
  }

  function formatCurrency(value) {
    const number = Number(value || 0);

    return new Intl.NumberFormat('vi-VN', {
      style: 'currency',
      currency: 'VND',
      maximumFractionDigits: 0,
    }).format(number);
  }

  function escapeHtml(value) {
    return String(value || '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }
</script>
