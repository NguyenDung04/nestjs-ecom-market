    function formatPrice(price) {
        return new Intl.NumberFormat("vi-VN").format(price) + "đ";
    }

    function calcDiscountPercent(price, salePrice) {
        if (!salePrice || salePrice >= price) return 0;
        return Math.round(((price - salePrice) / price) * 100);
    }

    function isOutOfStock(product) {
        return product.quantity === 0;
    }

    // =============================================
    // GIỎ HÀNG DEMO
    // =============================================

    let cartCount = 0;

    function updateCartBadge() {
        const badge = document.getElementById("cartBadge");
        const mobileCount = document.getElementById("mobileCartCount");
        if (cartCount > 0) {
            badge.textContent = cartCount > 99 ? "99+" : cartCount;
            badge.classList.remove("hidden");
            badge.classList.add("cart-badge");
            // Re-trigger animation
            void badge.offsetWidth;
            badge.classList.add("cart-badge");
        } else {
            badge.classList.add("hidden");
        }
        if (mobileCount) mobileCount.textContent = cartCount;
    }

    function addToCart(product) {
        if (isOutOfStock(product)) {
            Swal.fire({
                icon: "warning",
                title: "Sản phẩm đã hết hàng",
                text: `"${product.name}" hiện tại không còn trong kho.`,
                confirmButtonColor: "#007a7a",
                background: "#fff",
            });
            return;
        }
        cartCount++;
        updateCartBadge();
        Swal.fire({
            icon: "success",
            title: "Đã thêm vào giỏ hàng",
            text: `"${product.name}" đã được thêm vào giỏ hàng.`,
            confirmButtonColor: "#007a7a",
            background: "#fff",
            timer: 2000,
            timerProgressBar: true,
            showConfirmButton: false,
        });
    }

    // =============================================
    // RENDER DANH MỤC
    // =============================================

    function renderCategories() {
        const grid = document.getElementById("categoriesGrid");
        const activeCategories = categoriesData.filter(
            (c) => c.status === "active",
        );

        grid.innerHTML = activeCategories
            .map(
                (cat) => `
        <div class="category-card bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 cursor-pointer group" onclick="goToCategory('${cat.slug}', '${cat.name}')">
          <div class="relative h-36 sm:h-40 overflow-hidden">
            <img src="${cat.image}" alt="${cat.name}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy">
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
            <div class="absolute bottom-3 left-3 right-3">
              <h3 class="text-white font-semibold text-base truncate">${cat.name}</h3>
            </div>
          </div>
          <div class="p-4">
            <p class="text-gray-400 text-xs leading-relaxed line-clamp-2 mb-3">${cat.description}</p>
            <span class="inline-flex items-center gap-1 text-teal-600 text-xs font-medium group-hover:gap-2 transition-all">
              Xem sản phẩm <i class="fas fa-arrow-right text-[10px]"></i>
            </span>
          </div>
        </div>
      `,
            )
            .join("");
    }

    function goToCategory(slug, name) {
        Swal.fire({
            icon: "info",
            title: "Chuyển đến danh mục",
            html: `Bạn sẽ chuyển đến danh mục <strong>${name}</strong><br><code class="text-xs text-gray-400">/categories/${slug}</code>`,
            confirmButtonColor: "#007a7a",
            background: "#fff",
            timer: 2000,
            timerProgressBar: true,
            showConfirmButton: false,
        });
    }

    // =============================================
    // RENDER PRODUCT CARD (CHUNG)
    // =============================================

    function renderProductCard(product, badgeType, extraInfo) {
        const outOfStock = isOutOfStock(product);
        const hasSale =
            product.sale_price && product.sale_price < product.price;
        const discount = calcDiscountPercent(product.price, product.sale_price);

        let badgeHtml = "";
        if (outOfStock) {
            badgeHtml =
                '<span class="badge-out absolute top-3 left-3 px-2.5 py-1 rounded-lg text-xs font-semibold">Hết hàng</span>';
        } else if (badgeType === "new") {
            badgeHtml =
                '<span class="badge-new absolute top-3 left-3 px-2.5 py-1 rounded-lg text-xs font-semibold">Mới</span>';
        } else if (badgeType === "hot") {
            badgeHtml =
                '<span class="badge-hot absolute top-3 left-3 px-2.5 py-1 rounded-lg text-xs font-semibold"><i class="fas fa-fire mr-1"></i>Bán chạy</span>';
        } else if (badgeType === "sale" && hasSale) {
            badgeHtml = `<span class="badge-sale absolute top-3 left-3 px-2.5 py-1 rounded-lg text-xs font-semibold">-${discount}%</span>`;
        }

        const priceHtml = hasSale
            ? `<span class="text-red-500 font-bold text-lg">${formatPrice(product.sale_price)}</span>
           <span class="text-gray-400 line-through text-sm ml-1">${formatPrice(product.price)}</span>`
            : `<span class="text-teal-700 font-bold text-lg">${formatPrice(product.price)}</span>`;

        const hotBorder = badgeType === "hot" ? "ring-2 ring-orange-200" : "";

        return `
        <div class="product-card bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 ${hotBorder}">
          <div class="relative group cursor-pointer" onclick="viewProductDetail(${product.id})">
            <div class="aspect-square overflow-hidden bg-gray-50">
              <img src="${product.thumbnail}" alt="${product.name}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-400 ${outOfStock ? "opacity-60" : ""}" loading="lazy">
            </div>
            ${badgeHtml}
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors"></div>
          </div>
          <div class="p-4 space-y-2.5">
            <h3 class="font-semibold text-gray-800 text-sm leading-snug line-clamp-2 cursor-pointer hover:text-teal-600 transition-colors" onclick="viewProductDetail(${product.id})">${product.name}</h3>
            <p class="text-gray-400 text-xs leading-relaxed line-clamp-2">${product.short_description}</p>
            ${extraInfo ? `<p class="text-xs text-gray-500">${extraInfo}</p>` : ""}
            <div class="flex items-center flex-wrap gap-1">${priceHtml}</div>
            <div class="flex items-center gap-2 pt-1">
              <button onclick="viewProductDetail(${product.id})" class="btn-outline-teal flex-1 py-2 rounded-xl text-xs font-medium text-center">
                <i class="fas fa-eye mr-1"></i> Xem chi tiết
              </button>
              <button onclick='addToCart(${JSON.stringify(product).replace(/'/g, "\\'")})' class="btn-teal flex-1 py-2 rounded-xl text-xs font-medium text-center ${outOfStock ? "opacity-50 cursor-not-allowed" : ""}" ${outOfStock ? "disabled" : ""}>
                <i class="fas fa-cart-plus mr-1"></i> Thêm vào giỏ
              </button>
            </div>
          </div>
        </div>
      `;
    }

    // =============================================
    // RENDER SẢN PHẨM MỚI
    // =============================================

    function renderNewProducts() {
        const grid = document.getElementById("newProductsGrid");
        const activeProducts = productsData.filter(
            (p) => p.status === "active",
        );
        // Sắp xếp theo created_at giảm dần, lấy 4 sản phẩm mới nhất
        const newProducts = [...activeProducts]
            .sort((a, b) => new Date(b.created_at) - new Date(a.created_at))
            .slice(0, 4);

        grid.innerHTML = newProducts
            .map((p) => renderProductCard(p, "new", null))
            .join("");
    }

    // =============================================
    // RENDER SẢN PHẨM BÁN CHẠY
    // =============================================

    function renderBestSelling() {
        const grid = document.getElementById("bestSellingGrid");
        const html = bestSellingData
            .map((item) => {
                const product = productsData.find(
                    (p) => p.id === item.product_id,
                );
                if (!product || product.status !== "active") return "";
                const extraInfo = `<i class="fas fa-chart-line text-orange-400 mr-1"></i> Đã bán <strong>${item.total_sold}</strong> sản phẩm <span class="text-gray-300 ml-1">(tổng hợp từ order_items)</span>`;
                return renderProductCard(product, "hot", extraInfo);
            })
            .join("");
        grid.innerHTML = html;
    }

    // =============================================
    // RENDER SẢN PHẨM KHUYẾN MÃI
    // =============================================

    function renderSaleProducts() {
        const grid = document.getElementById("saleProductsGrid");
        // Điều kiện: sale_price khác null VÀ sale_price < price
        const saleProducts = productsData.filter(
            (p) =>
                p.status === "active" &&
                p.sale_price !== null &&
                p.sale_price < p.price,
        );

        grid.innerHTML = saleProducts
            .map((p) => renderProductCard(p, "sale", null))
            .join("");
    }

    // =============================================
    // XEM CHI TIẾT SẢN PHẨM (SWEETALERT2)
    // =============================================

    function viewProductDetail(productId) {
        const product = productsData.find((p) => p.id === productId);
        if (!product) return;

        const hasSale =
            product.sale_price && product.sale_price < product.price;
        const discount = calcDiscountPercent(product.price, product.sale_price);
        const outOfStock = isOutOfStock(product);

        const priceSection = hasSale
            ? `<div class="flex items-center gap-2 mb-2">
             <span class="text-red-500 font-bold text-2xl">${formatPrice(product.sale_price)}</span>
             <span class="text-gray-400 line-through text-sm">${formatPrice(product.price)}</span>
             <span class="bg-red-100 text-red-600 text-xs font-semibold px-2 py-0.5 rounded-full">-${discount}%</span>
           </div>`
            : `<div class="mb-2"><span class="text-teal-700 font-bold text-2xl">${formatPrice(product.price)}</span></div>`;

        const stockText = outOfStock
            ? '<span class="text-red-500 text-sm font-medium"><i class="fas fa-times-circle mr-1"></i>Hết hàng</span>'
            : `<span class="text-green-600 text-sm font-medium"><i class="fas fa-check-circle mr-1"></i>Còn hàng: ${product.quantity} sản phẩm</span>`;

        Swal.fire({
            title: "",
            html: `
          <div class="text-left">
            <div class="flex flex-col sm:flex-row gap-4">
              <img src="${product.thumbnail}" alt="${product.name}" class="w-full sm:w-48 h-48 object-cover rounded-xl border border-gray-100">
              <div class="flex-1">
                <h3 class="font-bold text-gray-800 text-lg mb-1">${product.name}</h3>
                <p class="text-gray-400 text-xs mb-3">SKU: ${product.sku}</p>
                ${priceSection}
                <p class="text-gray-500 text-sm leading-relaxed mb-3">${product.short_description}</p>
                <div class="mb-3">${stockText}</div>
                <div class="text-xs text-gray-400">
                  <i class="fas fa-link mr-1"></i> /products/${product.slug}
                </div>
              </div>
            </div>
          </div>
        `,
            confirmButtonText: outOfStock
                ? "Đóng"
                : '<i class="fas fa-cart-plus mr-1"></i> Thêm vào giỏ',
            confirmButtonColor: outOfStock ? "#94a3b8" : "#007a7a",
            showCancelButton: true,
            cancelButtonText: "Đóng",
            cancelButtonColor: "#e2e8f0",
            customClass: { cancelButton: "!text-gray-600" },
            width: 600,
            background: "#fff",
            preConfirm: () => {
                if (!outOfStock) addToCart(product);
                return false;
            },
        });
    }

    // =============================================
    // TÌM KIẾM NHANH
    // =============================================

    function setupSearch(inputId, dropdownId, resultsId) {
        const input = document.getElementById(inputId);
        const dropdown = document.getElementById(dropdownId);
        const results = document.getElementById(resultsId);

        input.addEventListener("input", function () {
            const keyword = this.value.trim().toLowerCase();
            if (keyword.length === 0) {
                dropdown.classList.add("hidden");
                return;
            }

            const matched = productsData
                .filter(
                    (p) =>
                        p.status === "active" &&
                        p.name.toLowerCase().includes(keyword),
                )
                .slice(0, 6);

            if (matched.length === 0) {
                results.innerHTML = `
            <div class="px-4 py-6 text-center text-gray-400 text-sm">
              <i class="fas fa-search text-2xl mb-2 block text-gray-300"></i>
              Không tìm thấy sản phẩm phù hợp
            </div>`;
            } else {
                results.innerHTML = matched
                    .map((p) => {
                        const hasSale = p.sale_price && p.sale_price < p.price;
                        const displayPrice = hasSale
                            ? `<span class="text-red-500 font-semibold">${formatPrice(p.sale_price)}</span> <span class="text-gray-300 line-through text-xs">${formatPrice(p.price)}</span>`
                            : `<span class="text-teal-700 font-semibold">${formatPrice(p.price)}</span>`;
                        return `
              <div class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-teal-50 cursor-pointer transition-colors" onclick="viewProductDetail(${p.id}); document.getElementById('${inputId}').value=''; document.getElementById('${dropdownId}').classList.add('hidden');">
                <img src="${p.thumbnail}" alt="${p.name}" class="w-11 h-11 rounded-lg object-cover border border-gray-100 shrink-0">
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-gray-800 truncate">${p.name}</p>
                  <div class="text-xs mt-0.5">${displayPrice}</div>
                </div>
                <i class="fas fa-chevron-right text-gray-300 text-xs shrink-0"></i>
              </div>`;
                    })
                    .join("");
            }
            dropdown.classList.remove("hidden");
        });

        input.addEventListener("focus", function () {
            if (this.value.trim().length > 0) {
                dropdown.classList.remove("hidden");
            }
        });

        // Đóng dropdown khi click bên ngoài
        document.addEventListener("click", function (e) {
            if (!input.contains(e.target) && !dropdown.contains(e.target)) {
                dropdown.classList.add("hidden");
            }
        });
    }

    // =============================================
    // MOBILE MENU
    // =============================================

    function setupMobileMenu() {
        const menuBtn = document.getElementById("mobileMenuBtn");
        const closeBtn = document.getElementById("closeMobileMenu");
        const menu = document.getElementById("mobileMenu");
        const overlay = document.getElementById("mobileOverlay");

        function openMenu() {
            menu.classList.add("active");
            overlay.classList.add("active");
            document.body.style.overflow = "hidden";
        }

        function closeMenu() {
            menu.classList.remove("active");
            overlay.classList.remove("active");
            document.body.style.overflow = "";
        }

        menuBtn.addEventListener("click", openMenu);
        closeBtn.addEventListener("click", closeMenu);
        overlay.addEventListener("click", closeMenu);

        // Đóng menu khi click link
        menu.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", closeMenu);
        });
    }

    // =============================================
    // CART BUTTON
    // =============================================

    function setupCartButton() {
        document
            .getElementById("cartBtn")
            .addEventListener("click", function () {
                Swal.fire({
                    icon: "info",
                    title: "Giỏ hàng",
                    html:
                        cartCount > 0
                            ? `Bạn có <strong>${cartCount}</strong> sản phẩm trong giỏ hàng.<br><code class="text-xs text-gray-400">/cart</code>`
                            : "Giỏ hàng của bạn đang trống.",
                    confirmButtonColor: "#007a7a",
                    background: "#fff",
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = "/zai/client/cart/";
                    }
                });
            });
    }

    // =============================================
    // LOGIN / REGISTER BUTTONS
    // =============================================

    function setupAuthButtons() {
        document
            .getElementById("loginBtn")
            .addEventListener("click", function (e) {
                e.preventDefault();
                Swal.fire({
                    icon: "info",
                    title: "Đăng nhập",
                    html: 'Bạn sẽ chuyển đến trang đăng nhập.<br><code class="text-xs text-gray-400">/login</code>',
                    confirmButtonColor: "#007a7a",
                    background: "#fff",
                    timer: 2000,
                    timerProgressBar: true,
                    showConfirmButton: false,
                }).then(() => {
                    window.location.href = "/zai/client/auth/login.html";
                });
            });

        document
            .getElementById("registerBtn")
            .addEventListener("click", function (e) {
                e.preventDefault();
                Swal.fire({
                    icon: "info",
                    title: "Đăng ký",
                    html: 'Bạn sẽ chuyển đến trang đăng ký.<br><code class="text-xs text-gray-400">/register</code>',
                    confirmButtonColor: "#007a7a",
                    background: "#fff",
                    timer: 2000,
                    timerProgressBar: true,
                    showConfirmButton: false,
                }).then(() => {
                    window.location.href = "/zai/client/auth/register.html";
                });
            });
    } 

    // =============================================
    // KHỞI TẠO
    // =============================================

    document.addEventListener("DOMContentLoaded", function () {
        renderCategories();
        renderNewProducts();
        renderBestSelling();
        renderSaleProducts();
        setupSearch("searchInput", "searchDropdown", "searchResults");
        setupSearch(
            "searchInputMobile",
            "searchDropdownMobile",
            "searchResultsMobile",
        );
        setupMobileMenu();
        setupCartButton();
        setupAuthButtons(); 
        updateCartBadge();
    });
</script>
