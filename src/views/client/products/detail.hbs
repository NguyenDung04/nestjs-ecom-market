<section class="mx-auto max-w-7xl px-4 py-8">
  <div class="grid gap-8 rounded-3xl bg-white p-8 shadow-sm md:grid-cols-2">
    <div class="flex h-96 items-center justify-center rounded-2xl bg-slate-100">
      <i class="fa-solid fa-box-open text-7xl text-slate-400"></i>
    </div>

    <div>
      <p class="text-sm font-semibold" style="color: var(--teal-600);">
        {{product.category}}
      </p>

      <h1 class="mt-2 text-4xl font-bold text-slate-900">
        {{product.name}}
      </h1>

      <div class="mt-4 text-3xl font-bold" style="color: var(--teal-700);">
        {{formatCurrency product.price}}
      </div>

      <p class="mt-5 text-slate-600">
        {{product.description}}
      </p>

      <div class="mt-6 flex gap-3">
        <button
          class="rounded-xl px-5 py-3 font-semibold text-white"
          style="background: var(--teal-600);"
        >
          Thêm vào giỏ hàng
        </button>

        <a href="/products" class="rounded-xl border bg-white px-5 py-3 font-semibold">
          Quay lại
        </a>
      </div>
    </div>
  </div>
</section>