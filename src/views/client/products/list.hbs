<section class="mx-auto max-w-7xl px-4 py-8">
  <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
    <div>
      <h1 class="text-3xl font-bold text-slate-900">{{title}}</h1>
      <p class="mt-1 text-slate-500">Danh sách sản phẩm hiển thị từ dữ liệu mẫu.</p>
    </div>
  </div>

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
    {{#each products}}
      <article class="rounded-2xl border bg-white p-4 shadow-sm">
        <div class="flex h-40 items-center justify-center rounded-xl bg-slate-100">
          <i class="fa-solid fa-box text-4xl text-slate-400"></i>
        </div>

        <h2 class="mt-4 font-bold text-slate-900">{{this.name}}</h2>
        <p class="mt-1 text-sm text-slate-500">{{this.category}}</p>

        <div class="mt-3 font-bold" style="color: var(--teal-700);">
          {{formatCurrency this.price}}
        </div>

        <a
          href="/products/{{this.slug}}"
          class="mt-4 inline-block rounded-lg px-4 py-2 text-sm font-semibold text-white"
          style="background: var(--teal-600);"
        >
          Chi tiết
        </a>
      </article>
    {{/each}}
  </div>

  {{> client/pagination}}
</section>