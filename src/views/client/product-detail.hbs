<section class="relative bg-slate-50">
  <div class="absolute inset-0 -z-10">
    <div class="absolute left-0 top-0 h-80 w-80 rounded-full bg-primary-100/50 blur-3xl"></div>
    <div class="absolute right-0 top-48 h-80 w-80 rounded-full bg-sky-100/60 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-7xl px-5 py-10">
    <div class="mb-6 flex flex-wrap items-center gap-2 text-sm text-slate-500">
      <a href="/" class="font-medium hover:text-primary-600">Trang chủ</a>
      <i class="fa-solid fa-chevron-right text-xs"></i>
      <a href="/products" class="font-medium hover:text-primary-600">Sản phẩm</a>
      <i class="fa-solid fa-chevron-right text-xs"></i>
      <span class="font-semibold text-slate-800">Chi tiết sản phẩm</span>
    </div>

    <div id="productDetailLoading" class="grid gap-8 lg:grid-cols-2">
      <div class="rounded-[2rem] border border-slate-200 bg-white p-5 shadow-sm">
        <div class="h-[420px] animate-pulse rounded-[1.5rem] bg-slate-100"></div>
      </div>

      <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
        <div class="h-5 w-32 animate-pulse rounded-full bg-slate-100"></div>
        <div class="mt-5 h-9 w-3/4 animate-pulse rounded-full bg-slate-100"></div>
        <div class="mt-4 h-5 w-1/2 animate-pulse rounded-full bg-slate-100"></div>
        <div class="mt-8 h-12 w-44 animate-pulse rounded-full bg-slate-100"></div>
      </div>
    </div>

    <div id="productDetailContent" class="hidden">
      <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="rounded-[2rem] border border-slate-200 bg-white p-5 shadow-sm">
          <div class="relative overflow-hidden rounded-[1.5rem] bg-slate-100">
            <img
              id="productImage"
              src=""
              alt="Product image"
              class="h-[420px] w-full object-cover"
            />

            <div id="productStatusBadge" class="absolute left-5 top-5"></div>
          </div>

          <div class="mt-5 grid grid-cols-4 gap-3">
            <div class="h-20 rounded-2xl border border-primary-200 bg-primary-50 p-2">
              <div class="flex h-full items-center justify-center rounded-xl bg-white text-primary-600">
                <i class="fa-regular fa-image"></i>
              </div>
            </div>
            <div class="h-20 rounded-2xl border border-slate-200 bg-slate-50 p-2">
              <div class="flex h-full items-center justify-center rounded-xl bg-white text-slate-400">
                <i class="fa-regular fa-image"></i>
              </div>
            </div>
            <div class="h-20 rounded-2xl border border-slate-200 bg-slate-50 p-2">
              <div class="flex h-full items-center justify-center rounded-xl bg-white text-slate-400">
                <i class="fa-regular fa-image"></i>
              </div>
            </div>
            <div class="h-20 rounded-2xl border border-slate-200 bg-slate-50 p-2">
              <div class="flex h-full items-center justify-center rounded-xl bg-white text-slate-400">
                <i class="fa-regular fa-image"></i>
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex flex-wrap items-center gap-3">
            <span
              id="productCategory"
              class="inline-flex items-center gap-2 rounded-full bg-primary-50 px-3 py-1 text-xs font-bold text-primary-700"
            >
              <i class="fa-solid fa-layer-group"></i>
              --
            </span>

            <span
              id="productId"
              class="inline-flex items-center gap-2 rounded-full bg-slate-100 px-3 py-1 text-xs font-bold text-slate-600"
            >
              ID: --
            </span>
          </div>

          <h1 id="productName" class="mt-5 text-3xl font-black tracking-tight text-slate-900 lg:text-4xl">
            --
          </h1>

          <p id="productShortDescription" class="mt-4 text-base leading-8 text-slate-600">
            --
          </p>

          <div class="mt-6 flex flex-wrap items-end gap-3">
            <p id="productPrice" class="text-4xl font-black text-primary-600">
              --
            </p>

            <p class="pb-1 text-sm text-slate-400 line-through">
              0đ
            </p>
          </div>

          <div class="mt-8 grid gap-3 sm:grid-cols-3">
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
              <div class="mb-2 text-primary-600">
                <i class="fa-solid fa-truck-fast"></i>
              </div>
              <p class="text-sm font-bold text-slate-900">Giao nhanh</p>
              <p class="mt-1 text-xs text-slate-500">Hỗ trợ xử lý đơn nhanh</p>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
              <div class="mb-2 text-emerald-600">
                <i class="fa-solid fa-circle-check"></i>
              </div>
              <p class="text-sm font-bold text-slate-900">Thông tin rõ ràng</p>
              <p class="mt-1 text-xs text-slate-500">Mô tả và trạng thái trực quan</p>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
              <div class="mb-2 text-violet-600">
                <i class="fa-solid fa-headset"></i>
              </div>
              <p class="text-sm font-bold text-slate-900">Tư vấn</p>
              <p class="mt-1 text-xs text-slate-500">Sẵn sàng hỗ trợ khi cần</p>
            </div>
          </div>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <button
              type="button"
              onclick="showToast('Tinh nang them vao gio se duoc bo sung o buoc sau', 'info')"
              class="inline-flex flex-1 items-center justify-center gap-2 rounded-2xl bg-primary-600 px-6 py-4 text-sm font-bold text-white shadow-lg shadow-primary-600/20 transition hover:bg-primary-700"
            >
              <i class="fa-solid fa-cart-plus"></i>
              Thêm vào giỏ
            </button>

            <a
              href="/products"
              class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-300 bg-white px-6 py-4 text-sm font-bold text-slate-700 transition hover:bg-slate-50"
            >
              <i class="fa-solid fa-arrow-left"></i>
              Quay lại
            </a>
          </div>
        </div>
      </div>

      <div class="mt-8 grid gap-8 lg:grid-cols-3">
        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
          <h2 class="text-xl font-black text-slate-900">
            Mô tả sản phẩm
          </h2>

          <p id="productDescription" class="mt-4 text-sm leading-7 text-slate-600">
            --
          </p>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-black text-slate-900">
            Thông tin nhanh
          </h2>

          <div class="mt-5 space-y-4 text-sm">
            <div class="flex items-center justify-between border-b border-slate-100 pb-3">
              <span class="text-slate-500">Mã sản phẩm</span>
              <span id="infoProductId" class="font-bold text-slate-900">--</span>
            </div>

            <div class="flex items-center justify-between border-b border-slate-100 pb-3">
              <span class="text-slate-500">Danh mục</span>
              <span id="infoCategory" class="font-bold text-slate-900">--</span>
            </div>

            <div class="flex items-center justify-between border-b border-slate-100 pb-3">
              <span class="text-slate-500">Trạng thái</span>
              <span id="infoStatus" class="font-bold text-slate-900">--</span>
            </div>

            <div class="flex items-center justify-between">
              <span class="text-slate-500">Ngày tạo</span>
              <span id="infoCreatedAt" class="font-bold text-slate-900">--</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div id="productDetailError" class="hidden rounded-[2rem] border border-rose-200 bg-rose-50 p-8 text-center">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-3xl bg-white text-rose-600">
        <i class="fa-solid fa-triangle-exclamation text-2xl"></i>
      </div>

      <h2 class="text-xl font-black text-rose-800">
        Không tải được sản phẩm
      </h2>

      <p class="mt-2 text-sm text-rose-600">
        Sản phẩm không tồn tại hoặc hệ thống đang gặp lỗi.
      </p>

      <a
        href="/products"
        class="mt-5 inline-flex items-center justify-center gap-2 rounded-2xl bg-rose-600 px-5 py-3 text-sm font-bold text-white hover:bg-rose-700"
      >
        <i class="fa-solid fa-arrow-left"></i>
        Quay lại danh sách
      </a>
    </div>
  </div>
</section>

<script>
  const PRODUCT_ID = '{{productId}}';

  document.addEventListener('DOMContentLoaded', function () {
    loadProductDetail();
  });

  async function loadProductDetail() {
    const loading = document.getElementById('productDetailLoading');
    const content = document.getElementById('productDetailContent');
    const errorBox = document.getElementById('productDetailError');

    try {
      const response = await fetch('/api/products/' + PRODUCT_ID, {
        method: 'GET',
        credentials: 'include',
      });

      const result = await response.json();

      console.log('PRODUCT_DETAIL_RESPONSE:', result);

      if (!response.ok || result.success === false) {
        throw new Error(result.message || 'Không tải được sản phẩm');
      }

      const product = result.data?.data || result.data;

      if (!product) {
        throw new Error('Không tìm thấy dữ liệu sản phẩm');
      }

      renderProductDetail(product);

      loading.classList.add('hidden');
      content.classList.remove('hidden');
    } catch (error) {
      console.error(error);

      loading.classList.add('hidden');
      errorBox.classList.remove('hidden');

      if (typeof showToast === 'function') {
        showToast(error.message || 'Không tải được chi tiết sản phẩm', 'error');
      }
    }
  }

  function renderProductDetail(product) {
    const imageUrl = normalizeImageUrl(product.image || product.imageUrl || product.image_url);
    const categoryName =
      product.category?.name ||
      product.categoryName ||
      product.category?.title ||
      'Chưa phân loại';

    const description =
      product.description ||
      'Sản phẩm hiện chưa có mô tả chi tiết.';

    const isActive = product.isActive === true || product.is_active === true;

    document.getElementById('productImage').src = imageUrl;
    document.getElementById('productImage').alt = product.name || 'Product image';

    document.getElementById('productCategory').innerHTML =
      '<i class="fa-solid fa-layer-group"></i>' + escapeHtml(categoryName);

    document.getElementById('productId').innerText = 'ID: ' + product.id;
    document.getElementById('productName').innerText = product.name || '--';
    document.getElementById('productShortDescription').innerText = description;
    document.getElementById('productPrice').innerText = formatCurrency(product.price);
    document.getElementById('productDescription').innerText = description;

    document.getElementById('infoProductId').innerText = '#' + product.id;
    document.getElementById('infoCategory').innerText = categoryName;
    document.getElementById('infoStatus').innerText = isActive ? 'Đang bán' : 'Tạm ẩn';
    document.getElementById('infoCreatedAt').innerText = formatDate(product.createdAt || product.created_at);

    document.getElementById('productStatusBadge').innerHTML = isActive
      ? '<span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-3 py-1 text-xs font-bold text-emerald-700 shadow-sm"><span class="h-1.5 w-1.5 rounded-full bg-emerald-600"></span>Đang bán</span>'
      : '<span class="inline-flex items-center gap-1 rounded-full bg-amber-50 px-3 py-1 text-xs font-bold text-amber-700 shadow-sm"><span class="h-1.5 w-1.5 rounded-full bg-amber-600"></span>Tạm ẩn</span>';
  }

  function normalizeImageUrl(image) {
    if (!image) {
      return 'https://placehold.co/900x700?text=Product';
    }

    if (image.startsWith('http://') || image.startsWith('https://')) {
      return image;
    }

    if (image.startsWith('/public/')) {
      return image;
    }

    if (image.startsWith('public/')) {
      return '/' + image;
    }

    return '/public/' + image.replace(/^\/+/, '');
  }

  function formatCurrency(value) {
    const number = Number(value || 0);

    return new Intl.NumberFormat('vi-VN', {
      style: 'currency',
      currency: 'VND',
      maximumFractionDigits: 0,
    }).format(number);
  }

  function formatDate(value) {
    if (!value) return '--';

    const date = new Date(value);

    if (Number.isNaN(date.getTime())) return '--';

    return date.toLocaleDateString('vi-VN');
  }

  function escapeHtml(value) {
    return String(value || '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }
</script>
