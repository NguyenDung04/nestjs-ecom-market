<section class="rounded-3xl border border-slate-200 bg-white shadow-soft">
    <div id="tableView">
        <div class="hidden overflow-x-auto lg:block">
            <table class="min-w-full text-left text-sm">
                <thead class="bg-slate-50 text-xs uppercase text-slate-400">
                    <tr>
                        <th class="px-5 py-4">
                            <input
                                id="selectAll"
                                type="checkbox"
                                class="h-4 w-4 rounded border-slate-300 text-kigen-600"
                            />
                        </th>
                        <th class="px-5 py-4">Danh mục</th>
                        <th class="px-5 py-4">Slug</th>
                        <th class="px-5 py-4">Danh mục cha</th>
                        <th class="px-5 py-4">Sản phẩm</th>
                        <th class="px-5 py-4">Danh mục con</th>
                        <th class="px-5 py-4">Trạng thái</th>
                        <th class="px-5 py-4">Ngày tạo</th>
                        <th class="px-5 py-4 text-right">Thao tác</th>
                    </tr>
                </thead>

                <tbody id="categoryTable">
                    <tr>
                        <td colspan="9" class="px-5 py-12 text-center text-sm font-semibold text-slate-500">
                            Đang tải danh mục...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div id="categoryCards" class="space-y-4 p-4 lg:hidden"></div>
    </div>

    <div id="treeView" class="hidden p-4 lg:p-5"></div>

    <div
        class="flex flex-col gap-3 border-t border-slate-100 px-5 py-4 lg:flex-row lg:items-center lg:justify-between"
    >
        <p id="paginationText" class="text-sm font-semibold text-slate-500">
            Trang 1
        </p>

        <div class="flex items-center gap-2">
            <button
                id="prevPageBtn"
                type="button"
                class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-bold text-slate-600 hover:border-kigen-500 hover:text-kigen-700 disabled:cursor-not-allowed disabled:opacity-50"
            >
                Trước
            </button>

            <button
                id="nextPageBtn"
                type="button"
                class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-bold text-slate-600 hover:border-kigen-500 hover:text-kigen-700 disabled:cursor-not-allowed disabled:opacity-50"
            >
                Sau
            </button>
        </div>
    </div>
</section>