            text: "Đã xác nhận",
            className: "bg-sky-50 text-sky-700 ring-sky-200",
        },
        shipping: {
            text: "Đang giao",
            className: "bg-indigo-50 text-indigo-700 ring-indigo-200",
        },
        completed: {
            text: "Hoàn tất",
            className: "bg-emerald-50 text-emerald-700 ring-emerald-200",
        },
        cancelled: {
            text: "Đã hủy",
            className: "bg-rose-50 text-rose-700 ring-rose-200",
        },
        paid: {
            text: "Đã thanh toán",
            className: "bg-emerald-50 text-emerald-700 ring-emerald-200",
        },
        unpaid: {
            text: "Chưa thanh toán",
            className: "bg-slate-100 text-slate-600 ring-slate-200",
        },
    };

    function statusBadge(status) {
        const data = statusMap[status] || {
            text: status,
            className: "bg-slate-100 text-slate-600 ring-slate-200",
        };
        return `<span class="inline-flex rounded-full px-2.5 py-1 text-xs font-bold ring-1 ${data.className}">${data.text}</span>`;
    }

    function filteredOrders() {
        const now = new Date("2026-04-29T12:00:00");
        const start = new Date(now);
        if (activeRange === "today") start.setHours(0, 0, 0, 0);
        if (activeRange === "7days") start.setDate(now.getDate() - 6);
        if (activeRange === "30days") start.setDate(now.getDate() - 29);
        if (activeRange === "month") start.setDate(1);
        if (activeRange === "year") start.setMonth(0, 1);
        return orders.filter(
            (order) =>
                new Date(order.created_at) >= start &&
                new Date(order.created_at) <= now,
        );
    }

    function renderKpis() {
        const scopedOrders = filteredOrders();
        const completedOrders = scopedOrders.filter(
            (order) =>
                order.order_status === "completed" &&
                order.payment_status === "paid",
        );
        const customerRoleIds = roles
            .filter((role) => role.name !== "admin")
            .map((role) => role.id);
        const customers = users.filter((user) =>
            customerRoleIds.includes(user.role_id),
        );
        const activeProducts = products.filter(
            (product) => product.status === "active",
        );
        const revenue = completedOrders.reduce(
            (sum, order) => sum + order.total_amount,
            0,
        );
        const todayOrders = orders.filter(
            (order) => order.created_at === "2026-04-29",
        ).length;

        const cards = [
            {
                label: "Tổng doanh thu",
                value: formatCurrency(revenue),
                helper: "+12.8% so với kỳ trước",
                icon: "fa-sack-dollar",
            },
            {
                label: "Tổng đơn hàng",
                value: scopedOrders.length,
                helper: `${todayOrders} đơn mới hôm nay`,
                icon: "fa-file-invoice-dollar",
            },
            {
                label: "Tổng sản phẩm",
                value: products.length,
                helper: `${activeProducts.length} sản phẩm active`,
                icon: "fa-box-open",
            },
            {
                label: "Tổng khách hàng",
                value: customers.length,
                helper: "Không tính tài khoản admin",
                icon: "fa-user-group",
            },
        ];

        byId("kpiGrid").innerHTML = cards
            .map(
                (card) => `
        <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-soft">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-semibold text-slate-500">${card.label}</p>
              <p class="mt-3 text-2xl font-bold text-slate-950">${card.value}</p>
            </div>
            <div class="grid h-12 w-12 shrink-0 place-items-center rounded-2xl bg-kigen-50 text-kigen-700">
              <i class="fa-solid ${card.icon}"></i>
            </div>
          </div>
          <p class="mt-4 flex items-center gap-2 text-sm font-semibold text-emerald-600">
            <i class="fa-solid fa-arrow-trend-up"></i>${card.helper}
          </p>
        </article>
      `,
            )
            .join("");
    }

    function chartData() {
        const completed = filteredOrders().filter(
            (order) => order.order_status === "completed",
        );
        const groups = {};
        completed.forEach((order) => {
            const date = new Date(order.created_at);
            let key = order.created_at.slice(5);
            if (activeChart === "month") key = `T${date.getMonth() + 1}`;
            if (activeChart === "year") key = String(date.getFullYear());
            groups[key] = (groups[key] || 0) + order.total_amount;
        });
        const fallback =
            activeChart === "day"
                ? [
                      "04-18",
                      "04-23",
                      "04-24",
                      "04-25",
                      "04-26",
                      "04-27",
                      "04-29",
                  ]
                : activeChart === "month"
                  ? ["T1", "T2", "T3", "T4"]
                  : ["2024", "2025", "2026"];
        return fallback.map((label) => ({ label, value: groups[label] || 0 }));
    }

    function renderChart() {
        const data = chartData();
        const max = Math.max(...data.map((item) => item.value), 1);
        byId("revenueChart").innerHTML = data
            .map((item) => {
                const height = Math.max(
                    (item.value / max) * 92,
                    item.value ? 12 : 4,
                );
                return `
          <div class="chart-bar relative flex h-full min-w-10 flex-1 flex-col items-center justify-end gap-2">
            <div class="chart-tooltip absolute bottom-full z-10 mb-2 min-w-32 rounded-xl bg-slate-950 px-3 py-2 text-center text-xs font-semibold text-white opacity-0 shadow-lg transition">
              ${item.label}<br>${formatCurrency(item.value)}
            </div>
            <div class="w-full rounded-t-2xl bg-gradient-to-t from-kigen-700 to-kigen-500 transition hover:from-kigen-900" style="height:${height}%"></div>
            <span class="text-xs font-semibold text-slate-500">${item.label}</span>
          </div>
        `;
            })
            .join("");
        document.querySelectorAll(".chart-tab").forEach((tab) => {
            tab.className = `chart-tab rounded-xl px-4 py-2 text-sm font-semibold ${tab.dataset.chart === activeChart ? "bg-white text-kigen-700 shadow-sm" : "text-slate-500"}`;
        });
    }

    function renderQuickStats() {
        const scopedOrders = filteredOrders();
        const stats = [
            {
                label: "Đơn đã hoàn tất",
                value: scopedOrders.filter(
                    (order) => order.order_status === "completed",
                ).length,
                icon: "fa-circle-check",
                color: "text-emerald-600",
            },
            {
                label: "Đơn đang giao",
                value: scopedOrders.filter(
                    (order) => order.order_status === "shipping",
                ).length,
                icon: "fa-truck-fast",
                color: "text-indigo-600",
            },
            {
                label: "Đơn đã hủy",
                value: scopedOrders.filter(
                    (order) => order.order_status === "cancelled",
                ).length,
                icon: "fa-ban",
                color: "text-rose-600",
            },
            {
                label: "Doanh thu hôm nay",
                value: formatCurrency(
                    orders
                        .filter(
                            (order) =>
                                order.created_at === "2026-04-29" &&
                                order.order_status === "completed",
                        )
                        .reduce((sum, order) => sum + order.total_amount, 0),
                ),
                icon: "fa-calendar-day",
                color: "text-kigen-700",
            },
            {
                label: "Sản phẩm sắp hết hàng",
                value: products.filter((product) => product.quantity <= 5)
                    .length,
                icon: "fa-triangle-exclamation",
                color: "text-amber-600",
            },
        ];

        byId("quickStats").innerHTML = stats
            .map(
                (stat) => `
        <div class="flex items-center justify-between rounded-2xl border border-slate-100 bg-slate-50 px-4 py-3">
          <div class="flex items-center gap-3">
            <i class="fa-solid ${stat.icon} ${stat.color} w-5"></i>
            <span class="text-sm font-semibold text-slate-600">${stat.label}</span>
          </div>
          <span class="text-sm font-bold text-slate-950">${stat.value}</span>
        </div>
      `,
            )
            .join("");
    }

    function renderRecentOrders() {
        const status = byId("statusFilter").value;
        const list = filteredOrders()
            .filter(
                (order) => status === "all" || order.order_status === status,
            )
            .sort((a, b) => new Date(b.created_at) - new Date(a.created_at))
            .slice(0, 8);

        byId("recentOrders").innerHTML = list.length
            ? list
                  .map(
                      (order) => `
        <div class="flex flex-col gap-3 rounded-2xl border border-slate-100 bg-slate-50 p-4 sm:flex-row sm:items-center sm:justify-between">
          <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-2">
              <p class="font-bold text-slate-950">${order.order_code}</p>
              ${statusBadge(order.order_status)}
              ${statusBadge(order.payment_status)}
            </div>
            <p class="mt-1 text-sm text-slate-500">${order.customer_name} • ${formatDate(order.created_at)} • ${order.payment_method}</p>
          </div>
          <div class="flex items-center gap-3">
            <p class="text-sm font-bold text-kigen-700">${formatCurrency(order.total_amount)}</p>
            <button onclick="showOrderDetail('${order.order_code}')" class="rounded-xl bg-white px-3 py-2 text-sm font-semibold text-slate-700 ring-1 ring-slate-200 hover:text-kigen-700">Xem chi tiết</button>
          </div>
        </div>
      `,
                  )
                  .join("")
            : `<div class="rounded-2xl bg-slate-50 p-5 text-center text-sm text-slate-500">Không có dữ liệu đơn hàng phù hợp.</div>`;
    }

    function renderTopProducts() {
        const summary = order_items.reduce((acc, item) => {
            if (!acc[item.product_id])
                acc[item.product_id] = { quantity: 0, revenue: 0 };
            acc[item.product_id].quantity += item.quantity;
            acc[item.product_id].revenue += item.total_price;
            return acc;
        }, {});

        const topProducts = Object.entries(summary)
            .map(([productId, data]) => ({
                ...products.find((product) => product.id === Number(productId)),
                ...data,
            }))
            .filter((product) => product.id)
            .sort((a, b) => b.quantity - a.quantity)
            .slice(0, 5);

        byId("topProducts").innerHTML = topProducts
            .map(
                (product, index) => `
        <div class="flex items-center gap-4 rounded-2xl border border-slate-100 bg-slate-50 p-3">
          <img src="${product.thumbnail}" alt="${product.name}" class="h-16 w-16 rounded-2xl object-cover">
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-2">
              <span class="rounded-full bg-kigen-600 px-2 py-0.5 text-xs font-bold text-white">Top ${index + 1}</span>
              <p class="truncate text-sm font-bold text-slate-950">${product.name}</p>
            </div>
            <p class="mt-1 text-xs text-slate-500">SKU: ${product.sku}</p>
            <p class="mt-1 text-sm font-semibold text-slate-700">${product.quantity} đã bán • ${formatCurrency(product.revenue)}</p>
          </div>
        </div>
      `,
            )
            .join("");
    }

    function renderPendingOrders() {
        const pending = orders
            .filter((order) => order.order_status === "pending")
            .sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
        byId("pendingCount").textContent = `${pending.length} đơn chờ xử lý`;
        byId("pendingDot").classList.toggle("hidden", pending.length === 0);

        if (!pending.length) {
            byId("pendingOrders").innerHTML =
                `<div class="rounded-2xl bg-slate-50 p-6 text-center text-sm text-slate-500">Không còn đơn hàng chờ xử lý.</div>`;
            return;
        }

        byId("pendingOrders").innerHTML = `
        <table class="min-w-full text-left text-sm">
          <thead>
            <tr class="border-b border-slate-200 text-xs uppercase text-slate-400">
              <th class="whitespace-nowrap px-3 py-3">Mã đơn</th>
              <th class="whitespace-nowrap px-3 py-3">Khách hàng</th>
              <th class="whitespace-nowrap px-3 py-3">Tổng tiền</th>
              <th class="whitespace-nowrap px-3 py-3">Thanh toán</th>
              <th class="whitespace-nowrap px-3 py-3">Ngày tạo</th>
              <th class="whitespace-nowrap px-3 py-3 text-right">Thao tác</th>
            </tr>
          </thead>
          <tbody>
            ${pending
                .map(
                    (order) => `
              <tr class="border-b border-slate-100 last:border-0">
                <td class="whitespace-nowrap px-3 py-4 font-bold text-slate-950">${order.order_code}</td>
                <td class="whitespace-nowrap px-3 py-4">
                  <p class="font-semibold text-slate-700">${order.customer_name}</p>
                  <p class="text-xs text-slate-500">${order.customer_phone}</p>
                </td>
                <td class="whitespace-nowrap px-3 py-4 font-bold text-kigen-700">${formatCurrency(order.total_amount)}</td>
                <td class="whitespace-nowrap px-3 py-4">
                  <p class="text-xs text-slate-500">${order.payment_method}</p>
                  <div class="mt-1">${statusBadge(order.payment_status)}</div>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-slate-500">${formatDate(order.created_at)}</td>
                <td class="whitespace-nowrap px-3 py-4 text-right">
                  <button onclick="confirmOrder('${order.order_code}')" class="rounded-xl bg-kigen-600 px-3 py-2 text-sm font-bold text-white hover:bg-kigen-700">Xác nhận</button>
                  <button onclick="showOrderDetail('${order.order_code}')" class="ml-2 rounded-xl bg-slate-100 px-3 py-2 text-sm font-bold text-slate-700 hover:bg-slate-200">Xem chi tiết</button>
                </td>
              </tr>
            `,
                )
                .join("")}
          </tbody>
        </table>
      `;
    }

    function showOrderDetail(orderCode) {
        const order = orders.find((item) => item.order_code === orderCode);
        if (!order) {
            Swal.fire(
                "Không có dữ liệu",
                "Không tìm thấy đơn hàng phù hợp.",
                "warning",
            );
            return;
        }
        Swal.fire({
            title: order.order_code,
            html: `
          <div class="text-left text-sm leading-7">
            <p><b>Khách hàng:</b> ${order.customer_name}</p>
            <p><b>Điện thoại:</b> ${order.customer_phone}</p>
            <p><b>Email:</b> ${order.customer_email}</p>
            <p><b>Địa chỉ:</b> ${order.shipping_address}</p>
            <p><b>Tổng tiền:</b> ${formatCurrency(order.total_amount)}</p>
            <p><b>Thanh toán:</b> ${order.payment_method} | ${statusMap[order.payment_status]?.text || order.payment_status}</p>
            <p><b>Trạng thái:</b> ${statusMap[order.order_status]?.text || order.order_status}</p>
            <p class="mt-2 text-slate-500">Demo route: /admin/orders/${order.order_code}</p>
          </div>
        `,
            confirmButtonColor: "#0d9488",
            confirmButtonText: "Đóng",
        });
    }

    function confirmOrder(orderCode) {
        const order = orders.find((item) => item.order_code === orderCode);
        Swal.fire({
            title: "Xác nhận đơn hàng?",
            text: `Cập nhật ${orderCode} từ pending sang confirmed.`,
            icon: "question",
            showCancelButton: true,
            confirmButtonColor: "#0d9488",
            cancelButtonColor: "#64748b",
            confirmButtonText: "Xác nhận",
            cancelButtonText: "Hủy",
        }).then((result) => {
            if (!result.isConfirmed) return;
            order.order_status = "confirmed";
            order.updated_at = "2026-04-29";
            renderAll();
            Swal.fire({
                title: "Đã xác nhận",
                text: `${orderCode} đã được cập nhật trạng thái.`,
                icon: "success",
                confirmButtonColor: "#0d9488",
            });
        });
    }

    function renderAll() {
        renderKpis();
        renderChart();
        renderQuickStats();
        renderRecentOrders();
        renderTopProducts();
        renderPendingOrders();
        document.querySelectorAll(".range-btn").forEach((button) => {
            button.className = `range-btn rounded-xl border px-4 py-2 text-sm font-semibold ${button.dataset.range === activeRange ? "border-kigen-600 bg-kigen-600 text-white" : "border-slate-200 text-slate-600 hover:border-kigen-500 hover:text-kigen-700"}`;
        });
    }

    byId("adminAvatar").src = currentAdmin.avatar;
    byId("adminName").textContent = currentAdmin.name;

    byId("toggleSidebar").addEventListener("click", () => {
        if (window.innerWidth < 1024)
            document.body.classList.toggle("mobile-sidebar-open");
        else document.body.classList.toggle("sidebar-collapsed");
    });

    byId("sidebarOverlay").addEventListener("click", () =>
        document.body.classList.remove("mobile-sidebar-open"),
    );
    byId("accountBtn").addEventListener("click", () =>
        byId("accountMenu").classList.toggle("hidden"),
    );
    byId("notifyBtn").addEventListener("click", () =>
        Swal.fire({
            title: "Thông báo",
            text: `${orders.filter((order) => order.order_status === "pending").length} đơn hàng đang chờ xác nhận.`,
            icon: "info",
            confirmButtonColor: "#0d9488",
        }),
    );

    byId("timeFilters").addEventListener("click", (event) => {
        const button = event.target.closest(".range-btn");
        if (!button) return;
        activeRange = button.dataset.range;
        renderAll();
    });

    byId("chartTabs").addEventListener("click", (event) => {
        const button = event.target.closest(".chart-tab");
        if (!button) return;
        activeChart = button.dataset.chart;
        renderChart();
    });

    byId("statusFilter").addEventListener("change", renderRecentOrders);
    byId("quickSearch").addEventListener("keydown", (event) => {
        if (event.key !== "Enter") return;
        const keyword = event.target.value.trim().toLowerCase();
        const order = orders.find(
            (item) =>
                item.order_code.toLowerCase().includes(keyword) ||
                item.customer_name.toLowerCase().includes(keyword),
        );
        if (order) showOrderDetail(order.order_code);
        else
            Swal.fire(
                "Không có dữ liệu",
                "Không tìm thấy đơn hàng hoặc khách hàng phù hợp.",
                "warning",
            );
    });

    renderAll();
</script>
