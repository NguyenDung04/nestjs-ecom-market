<section class="space-y-6">
    <div>
        <h1 class="text-2xl font-bold text-slate-950">Cài đặt hệ thống</h1>
        <p class="mt-1 text-sm text-slate-500">
            Cấu hình tên website, thông tin liên hệ, giao diện và các thiết lập chung.
        </p>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-slate-900">Thông tin website</h2>

        <div class="mt-5 grid gap-5 md:grid-cols-2">
            <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700">Tên website</label>
                <input
                    type="text"
                    value="{{siteName}}"
                    class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-kigen-500"
                />
            </div>

            <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700">Email hỗ trợ</label>
                <input
                    type="email"
                    placeholder="support@example.com"
                    class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-kigen-500"
                />
            </div>

            <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700">Số điện thoại</label>
                <input
                    type="text"
                    placeholder="0123456789"
                    class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-kigen-500"
                />
            </div>

            <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700">Trạng thái website</label>
                <select class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-kigen-500">
                    <option>Đang hoạt động</option>
                    <option>Bảo trì</option>
                </select>
            </div>
        </div>

        <div class="mt-6 flex justify-end">
            <button class="rounded-2xl bg-kigen-600 px-5 py-3 text-sm font-semibold text-white hover:bg-kigen-700">
                Lưu cài đặt
            </button>
        </div>
    </div>
</section>