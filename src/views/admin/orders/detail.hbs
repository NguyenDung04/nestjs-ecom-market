{{> admin/breadcrumb}}

<div class="rounded-2xl bg-white p-6 shadow-sm">
  <h2 class="text-xl font-bold text-slate-900">Đơn hàng {{order.code}}</h2>

  <div class="mt-4 space-y-2 text-sm text-slate-600">
    <p>Khách hàng: {{order.customerName}}</p>
    <p>Tổng tiền: {{formatCurrency order.total}}</p>
    <p>Trạng thái: {{orderStatusLabel order.status}}</p>
  </div>
</div>