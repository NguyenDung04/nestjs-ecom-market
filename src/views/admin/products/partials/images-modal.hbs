<div
    id="productImagesModal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/50 p-4"
>
    <div
        class="max-h-[92vh] w-full max-w-5xl overflow-y-auto rounded-3xl bg-white shadow-2xl"
    >
        <div
            class="sticky top-0 z-10 flex items-center justify-between border-b border-slate-100 bg-white px-6 py-4"
        >
            <div>
                <h2 class="text-xl font-bold text-slate-950">
                    Quản lý ảnh sản phẩm
                </h2>

                <p
                    id="imageProductText"
                    class="text-sm text-slate-500"
                >
                    Chọn ảnh phụ cho sản phẩm.
                </p>
            </div>

            <button
                id="closeProductImagesModal"
                type="button"
                class="grid h-10 w-10 place-items-center rounded-xl bg-slate-100 text-slate-600 hover:bg-slate-200"
            >
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="space-y-5 p-6">
            <input type="hidden" id="imageProductId" />

            <section class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
                <h3 class="text-base font-bold text-slate-950">
                    Thêm 1 ảnh phụ
                </h3>

                <div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-12">
                    <label class="block lg:col-span-5">
                        <span class="text-sm font-bold text-slate-700">
                            Chọn ảnh
                        </span>

                        <input
                            id="singleImageFile"
                            type="file"
                            accept="image/jpeg,image/png,image/webp"
                            class="mt-2 w-full rounded-xl border border-slate-200 bg-white p-2 text-sm"
                        />

                        <small
                            data-error="singleImageFile"
                            class="mt-1 block text-xs font-semibold text-rose-600"
                        ></small>
                    </label>

                    <label class="block lg:col-span-2">
                        <span class="text-sm font-bold text-slate-700">
                            Thứ tự
                        </span>

                        <input
                            id="singleImageSortOrder"
                            type="number"
                            min="0"
                            class="mt-2 h-11 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm outline-none focus:border-kigen-500"
                            placeholder="Tự động"
                        />
                    </label>

                    <label class="flex items-end gap-2 lg:col-span-2">
                        <input
                            id="singleImageIsPrimary"
                            type="checkbox"
                            class="mb-3 h-4 w-4 rounded border-slate-300 text-kigen-600"
                        />

                        <span class="mb-2 text-sm font-bold text-slate-700">
                            Đặt làm ảnh chính
                        </span>
                    </label>

                    <div class="flex items-end lg:col-span-3">
                        <button
                            id="uploadSingleImageBtn"
                            type="button"
                            class="h-11 w-full rounded-2xl bg-kigen-600 px-4 text-sm font-bold text-white hover:bg-kigen-700 disabled:cursor-not-allowed disabled:opacity-60"
                        >
                            Upload ảnh
                        </button>
                    </div>
                </div>
            </section>

            <section class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
                <h3 class="text-base font-bold text-slate-950">
                    Thêm nhiều ảnh phụ
                </h3>

                <div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-12">
                    <label class="block lg:col-span-6">
                        <span class="text-sm font-bold text-slate-700">
                            Chọn nhiều ảnh
                        </span>

                        <input
                            id="bulkImageFiles"
                            type="file"
                            accept="image/jpeg,image/png,image/webp"
                            multiple
                            class="mt-2 w-full rounded-xl border border-slate-200 bg-white p-2 text-sm"
                        />

                        <small
                            data-error="bulkImageFiles"
                            class="mt-1 block text-xs font-semibold text-rose-600"
                        ></small>
                    </label>

                    <label class="block lg:col-span-2">
                        <span class="text-sm font-bold text-slate-700">
                            Thứ tự bắt đầu
                        </span>

                        <input
                            id="bulkImageSortOrder"
                            type="number"
                            min="0"
                            class="mt-2 h-11 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm outline-none focus:border-kigen-500"
                            placeholder="Tự động"
                        />
                    </label>

                    <label class="flex items-end gap-2 lg:col-span-2">
                        <input
                            id="bulkImageIsPrimary"
                            type="checkbox"
                            class="mb-3 h-4 w-4 rounded border-slate-300 text-kigen-600"
                        />

                        <span class="mb-2 text-sm font-bold text-slate-700">
                            Ảnh đầu là ảnh chính
                        </span>
                    </label>

                    <div class="flex items-end lg:col-span-2">
                        <button
                            id="uploadBulkImagesBtn"
                            type="button"
                            class="h-11 w-full rounded-2xl bg-kigen-600 px-4 text-sm font-bold text-white hover:bg-kigen-700 disabled:cursor-not-allowed disabled:opacity-60"
                        >
                            Upload nhiều ảnh
                        </button>
                    </div>
                </div>
            </section>

            <section class="rounded-3xl border border-slate-200 bg-white">
                <div
                    class="flex flex-col gap-3 border-b border-slate-100 p-5 sm:flex-row sm:items-center sm:justify-between"
                >
                    <div>
                        <h3 class="text-base font-bold text-slate-950">
                            Danh sách ảnh phụ
                        </h3>

                        <p
                            id="productImagesResultText"
                            class="mt-1 text-sm font-semibold text-slate-500"
                        >
                            0 ảnh
                        </p>
                    </div>

                    <button
                        id="deleteAllProductImagesBtn"
                        type="button"
                        class="rounded-xl bg-rose-50 px-4 py-2 text-sm font-bold text-rose-700 hover:bg-rose-100"
                    >
                        Xóa toàn bộ ảnh
                    </button>
                </div>

                <div
                    id="productImagesGrid"
                    class="grid grid-cols-1 gap-4 p-5 sm:grid-cols-2 xl:grid-cols-4"
                >
                    <div class="rounded-2xl bg-slate-50 p-6 text-center text-sm font-semibold text-slate-500">
                        Chưa có ảnh phụ.
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>