<section
    class="rounded-3xl border border-slate-200 bg-white p-5 shadow-soft"
>
    <div class="grid grid-cols-1 gap-3 xl:grid-cols-12">
        <div class="relative xl:col-span-3">
            <i
                class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"
            ></i>

            <input
                id="searchInput"
                type="search"
                class="h-12 w-full rounded-2xl border border-slate-200 bg-slate-50 pl-11 pr-4 text-sm outline-none focus:border-kigen-500"
                placeholder="Tìm tên, slug hoặc SKU..."
            />
        </div>

        <select
            id="categoryFilter"
            class="h-12 rounded-2xl border border-slate-200 bg-white px-4 text-sm outline-none focus:border-kigen-500 xl:col-span-2"
        >
            <option value="">Tất cả danh mục</option>
        </select>

        <select
            id="statusFilter"
            class="h-12 rounded-2xl border border-slate-200 bg-white px-4 text-sm outline-none focus:border-kigen-500 xl:col-span-2"
        >
            <option value="">Tất cả trạng thái</option>
            <option value="active">Đang bán</option>
            <option value="inactive">Đang ẩn</option>
            <option value="out_of_stock">Hết hàng</option>
        </select>

        <select
            id="saleFilter"
            class="h-12 rounded-2xl border border-slate-200 bg-white px-4 text-sm outline-none focus:border-kigen-500 xl:col-span-2"
        >
            <option value="">Tất cả khuyến mãi</option>
            <option value="true">Đang giảm giá</option>
            <option value="false">Không giảm giá</option>
        </select>

        <select
            id="sortSelect"
            class="h-12 rounded-2xl border border-slate-200 bg-white px-4 text-sm outline-none focus:border-kigen-500 xl:col-span-2"
        >
            <option value="createdAt_DESC">Mới nhất</option>
            <option value="createdAt_ASC">Cũ nhất</option>
            <option value="price_ASC">Giá tăng dần</option>
            <option value="price_DESC">Giá giảm dần</option>
            <option value="quantity_ASC">Tồn kho thấp đến cao</option>
            <option value="quantity_DESC">Tồn kho cao đến thấp</option>
            <option value="name_ASC">Tên A-Z</option>
        </select>

        <button
            id="resetFilterBtn"
            type="button"
            class="h-12 rounded-2xl border border-slate-200 px-4 text-sm font-bold text-slate-600 hover:border-kigen-500 hover:text-kigen-700 xl:col-span-1"
            title="Đặt lại bộ lọc"
        >
            <i class="fa-solid fa-rotate-left"></i>
        </button>
    </div>

    <div class="mt-3 grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-12">
        <input
            id="minPriceInput"
            type="number"
            min="0"
            class="h-12 rounded-2xl border border-slate-200 bg-white px-4 text-sm outline-none focus:border-kigen-500 xl:col-span-3"
            placeholder="Giá thấp nhất"
        />

        <input
            id="maxPriceInput"
            type="number"
            min="0"
            class="h-12 rounded-2xl border border-slate-200 bg-white px-4 text-sm outline-none focus:border-kigen-500 xl:col-span-3"
            placeholder="Giá cao nhất"
        />

        <select
            id="limitSelect"
            class="h-12 rounded-2xl border border-slate-200 bg-white px-4 text-sm outline-none focus:border-kigen-500 xl:col-span-2"
        >
            <option value="10">10 dòng</option>
            <option value="20">20 dòng</option>
            <option value="50">50 dòng</option>
        </select>
    </div>

    <div
        class="mt-5 flex flex-col gap-3 border-t border-slate-100 pt-5 lg:flex-row lg:items-center lg:justify-between"
    >
        <div class="flex flex-wrap items-center gap-2">
            <span
                id="selectedText"
                class="text-sm font-semibold text-slate-500"
            >
                Chưa chọn sản phẩm
            </span>

            <button
                id="bulkShowBtn"
                type="button"
                class="rounded-xl bg-emerald-50 px-3 py-2 text-sm font-bold text-emerald-700 hover:bg-emerald-100"
            >
                Hiện đã chọn
            </button>

            <button
                id="bulkHideBtn"
                type="button"
                class="rounded-xl bg-amber-50 px-3 py-2 text-sm font-bold text-amber-700 hover:bg-amber-100"
            >
                Ẩn đã chọn
            </button>

            <button
                id="bulkDeleteBtn"
                type="button"
                class="rounded-xl bg-rose-50 px-3 py-2 text-sm font-bold text-rose-700 hover:bg-rose-100"
            >
                Xóa đã chọn
            </button>
        </div>

        <p
            id="resultText"
            class="text-sm font-semibold text-slate-500"
        ></p>
    </div>
</section>