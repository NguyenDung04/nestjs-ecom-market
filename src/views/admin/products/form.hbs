{{> admin/breadcrumb}}
{{> common/alert}}

<form method="POST" action="{{action}}" class="grid gap-5 rounded-2xl bg-white p-6 shadow-sm md:grid-cols-2">
  <div>
    <label class="mb-1 block text-sm font-medium">Tên sản phẩm</label>
    <input name="name" value="{{product.name}}" class="w-full rounded-xl border px-4 py-3" />
  </div>

  <div>
    <label class="mb-1 block text-sm font-medium">Slug</label>
    <input name="slug" value="{{product.slug}}" class="w-full rounded-xl border px-4 py-3" />
  </div>

  <div>
    <label class="mb-1 block text-sm font-medium">Giá</label>
    <input name="price" value="{{product.price}}" type="number" class="w-full rounded-xl border px-4 py-3" />
  </div>

  <div>
    <label class="mb-1 block text-sm font-medium">Trạng thái</label>
    <select name="status" class="w-full rounded-xl border px-4 py-3">
      <option value="active">Hiển thị</option>
      <option value="inactive">Ẩn</option>
    </select>
  </div>

  <div class="md:col-span-2">
    <label class="mb-1 block text-sm font-medium">Mô tả</label>
    <textarea name="description" rows="5" class="w-full rounded-xl border px-4 py-3">{{product.description}}</textarea>
  </div>

  <div class="md:col-span-2 flex gap-3">
    <button
      type="submit"
      class="rounded-xl px-5 py-3 font-semibold text-white"
      style="background: var(--teal-600);"
    >
      Lưu
    </button>

    <a href="/admin/products" class="rounded-xl border bg-white px-5 py-3 font-semibold">
      Quay lại
    </a>
  </div>
</form>