                    alt="Preview"
                    class="aspect-square w-full rounded-2xl border border-slate-200 object-cover"
                />
                <label class="block">
                    <span class="text-sm font-bold text-slate-700"
                        >Upload ảnh đại diện demo</span
                    >
                    <input
                        id="thumbnailFile"
                        type="file"
                        accept="image/*"
                        class="mt-2 w-full rounded-xl border border-slate-200 p-2 text-sm"
                    />
                </label>
                <label class="block">
                    <span class="text-sm font-bold text-slate-700"
                        >Ảnh phụ demo</span
                    >
                    <input
                        id="galleryFiles"
                        type="file"
                        accept="image/*"
                        multiple
                        class="mt-2 w-full rounded-xl border border-slate-200 p-2 text-sm"
                    />
                </label>
                <div id="galleryPreview" class="grid grid-cols-3 gap-2"></div>
            </div>
            <div
