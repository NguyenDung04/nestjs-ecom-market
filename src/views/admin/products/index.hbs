    function clearErrors() {
        document
            .querySelectorAll("[data-error]")
            .forEach((item) => (item.textContent = ""));
    }

    function validateProduct() {
        clearErrors();
        const id = Number($("productId").value || 0);
        const product = {
            name: $("nameInput").value.trim(),
            sku: $("skuInput").value.trim(),
            category_id: Number($("categoryInput").value),
            slug: $("slugInput").value.trim() || slugify($("nameInput").value),
            thumbnail: $("thumbnailInput").value.trim(),
            price: Number($("priceInput").value),
            sale_price:
                $("salePriceInput").value === ""
                    ? null
                    : Number($("salePriceInput").value),
            quantity: Number($("quantityInput").value),
            short_description: $("shortDescriptionInput").value.trim(),
            description: $("descriptionInput").value.trim(),
            status: $("statusInput").value,
        };
        const errors = {};
        if (!product.name) errors.nameInput = "Vui lòng nhập tên sản phẩm.";
        if (!product.sku) errors.skuInput = "Vui lòng nhập SKU.";
        if (
            products.some(
                (item) =>
                    item.sku.toLowerCase() === product.sku.toLowerCase() &&
                    item.id !== id,
            )
        )
            errors.skuInput = "SKU đã tồn tại.";
        if (!product.category_id)
            errors.categoryInput = "Vui lòng chọn danh mục.";
        if (!product.thumbnail)
            errors.thumbnailInput = "Vui lòng nhập hoặc upload ảnh đại diện.";
        if (Number.isNaN(product.price) || product.price < 0)
            errors.priceInput = "Giá bán phải là số >= 0.";
        if (
            product.sale_price !== null &&
            (product.sale_price < 0 || product.sale_price >= product.price)
        )
            errors.salePriceInput = "Giá khuyến mãi phải nhỏ hơn giá bán.";
        if (!Number.isInteger(product.quantity) || product.quantity < 0)
            errors.quantityInput = "Tồn kho phải là số nguyên >= 0.";
        if (!product.short_description)
            errors.shortDescriptionInput = "Vui lòng nhập mô tả ngắn.";
        Object.entries(errors).forEach(
            ([key, message]) =>
                (document.querySelector(`[data-error="${key}"]`).textContent =
                    message),
        );
        const firstError = Object.keys(errors)[0];
        if (firstError) $(firstError).focus();
        return { ok: !firstError, product };
    }

    function openProductModal(id = null) {
        state.editingId = id;
        clearErrors();
        $("productForm").reset();
        $("galleryPreview").innerHTML = "";
        const product = products.find((item) => item.id === id);
        $("productModalTitle").textContent = product
            ? "Sửa sản phẩm"
            : "Thêm sản phẩm";
        $("productId").value = product?.id || "";
        $("nameInput").value = product?.name || "";
        $("skuInput").value = product?.sku || "";
        $("categoryInput").value = product?.category_id || "";
        $("slugInput").value = product?.slug || "";
        $("priceInput").value = product?.price ?? "";
        $("salePriceInput").value = product?.sale_price ?? "";
        $("quantityInput").value = product?.quantity ?? "";
        $("shortDescriptionInput").value = product?.short_description || "";
        $("descriptionInput").value = product?.description || "";
        $("statusInput").value =
            product?.status === "hidden"
                ? "inactive"
                : product?.status || "active";
        $("thumbnailInput").value = product?.thumbnail || "";
        $("thumbnailPreview").src =
            product?.thumbnail ||
            "https://placehold.co/600x600/f0fdfa/0f766e?text=Preview";
        if (product) {
            $("galleryPreview").innerHTML = product_images
                .filter((image) => image.product_id === product.id)
                .map(
                    (image) =>
                        `<img src="${image.image}" class="aspect-square rounded-xl object-cover" alt="Ảnh phụ">`,
                )
                .join("");
        }
        $("productModal").classList.remove("hidden");
        $("productModal").classList.add("flex");
        setTimeout(() => $("nameInput").focus(), 50);
    }

    function closeProductModal() {
        $("productModal").classList.add("hidden");
        $("productModal").classList.remove("flex");
    }

    function saveProduct(event) {
        event.preventDefault();
        const { ok, product } = validateProduct();
        if (!ok) return;
        const id = Number($("productId").value || 0);
        const gallerySources = Array.from(
            $("galleryPreview").querySelectorAll("img"),
        ).map((image) => image.src);
        let savedId = id;
        if (id) {
            const index = products.findIndex((item) => item.id === id);
            products[index] = {
                ...products[index],
                ...product,
                updated_at: today,
            };
        } else {
            savedId = Math.max(0, ...products.map((item) => item.id)) + 1;
            products.unshift({
                id: savedId,
                ...product,
                created_at: today,
                updated_at: today,
            });
        }
        if (gallerySources.length) {
            product_images = product_images.filter(
                (image) => image.product_id !== savedId,
            );
            const nextImageId =
                Math.max(0, ...product_images.map((image) => image.id)) + 1;
            gallerySources.forEach((src, index) => {
                product_images.push({
                    id: nextImageId + index,
                    product_id: savedId,
                    image: src,
                    sort_order: index + 1,
                    created_at: today,
                    updated_at: today,
                });
            });
        }
        closeProductModal();
        state.page = 1;
        renderProducts();
        Swal.fire({
            title: "Đã lưu sản phẩm",
            icon: "success",
            confirmButtonColor: "#0d9488",
        });
    }

    function openDetail(id) {
        const product = products.find((item) => item.id === id);
        const gallery = product_images.filter(
            (image) => image.product_id === id,
        );
        $("detailBody").innerHTML = `
        <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
          <div>
            <img src="${product.thumbnail}" alt="${product.name}" class="aspect-square w-full rounded-3xl object-cover">
            <div class="mt-3 grid grid-cols-3 gap-2">${gallery.map((image) => `<img src="${image.image}" class="aspect-square rounded-xl object-cover" alt="Ảnh phụ">`).join("") || '<p class="col-span-3 text-sm text-slate-500">Chưa có ảnh phụ.</p>'}</div>
          </div>
          <div class="space-y-3 md:col-span-2">
            <h3 class="text-2xl font-bold text-slate-950">${product.name}</h3>
            <p class="text-sm text-slate-500">${product.short_description}</p>
            <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
              ${detailLine("SKU", product.sku)}
              ${detailLine("Slug", product.slug)}
              ${detailLine("Danh mục", categoryName(product.category_id))}
              ${detailLine("Giá bán", money(product.price))}
              ${detailLine("Giá khuyến mãi", money(product.sale_price))}
              ${detailLine("Tồn kho", product.quantity)}
              ${detailLine("Trạng thái", product.status)}
              ${detailLine("Ngày tạo", date(product.created_at))}
              ${detailLine("Ngày cập nhật", date(product.updated_at))}
            </div>
            <div class="rounded-2xl bg-slate-50 p-4"><p class="text-sm font-bold text-slate-700">Mô tả chi tiết</p><p class="mt-2 text-sm leading-6 text-slate-600">${product.description || "Không có"}</p></div>
            <div class="flex justify-end gap-3"><button onclick="closeDetail();openProductModal(${product.id})" class="rounded-2xl bg-kigen-600 px-5 py-3 text-sm font-bold text-white">Sửa sản phẩm</button></div>
          </div>
        </div>
      `;
        $("detailModal").classList.remove("hidden");
        $("detailModal").classList.add("flex");
    }

    function detailLine(label, value) {
        return `<div class="rounded-2xl border border-slate-100 bg-slate-50 p-3"><p class="text-xs font-bold uppercase text-slate-400">${label}</p><p class="mt-1 text-sm font-bold text-slate-800">${value}</p></div>`;
    }

    function closeDetail() {
        $("detailModal").classList.add("hidden");
        $("detailModal").classList.remove("flex");
    }

    function deleteProduct(id) {
        const product = products.find((item) => item.id === id);
        Swal.fire({
            title: "Xóa sản phẩm?",
            text: `Sản phẩm ${product.name} sẽ bị xóa khỏi dữ liệu demo.`,
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#e11d48",
            cancelButtonColor: "#64748b",
            confirmButtonText: "Xóa",
            cancelButtonText: "Hủy",
        }).then((result) => {
            if (!result.isConfirmed) return;
            products = products.filter((item) => item.id !== id);
            product_images = product_images.filter(
                (item) => item.product_id !== id,
            );
            state.selected.delete(id);
            renderProducts();
            Swal.fire({
                title: "Đã xóa",
                icon: "success",
                confirmButtonColor: "#0d9488",
            });
        });
    }

    function toggleStatus(id) {
        const product = products.find((item) => item.id === id);
        product.status = product.status === "active" ? "inactive" : "active";
        product.updated_at = today;
        renderProducts();
        Swal.fire({
            title: "Đã cập nhật trạng thái",
            text: `${product.name}: ${product.status}`,
            icon: "success",
            timer: 1200,
            showConfirmButton: false,
        });
    }

    function openStockModal(id) {
        const product = products.find((item) => item.id === id);
        $("stockProductId").value = product.id;
        $("stockProductText").textContent = `${product.name} • ${product.sku}`;
        $("currentStock").textContent = product.quantity;
        $("stockType").value = "adjust";
        $("stockQuantity").value = product.quantity;
        $("stockNote").value = "Cập nhật tồn kho thủ công";
        $("stockModal").classList.remove("hidden");
        $("stockModal").classList.add("flex");
    }

    function closeStockModal() {
        $("stockModal").classList.add("hidden");
        $("stockModal").classList.remove("flex");
    }

    function saveStock(event) {
        event.preventDefault();
        const id = Number($("stockProductId").value);
        const product = products.find((item) => item.id === id);
        const type = $("stockType").value;
        const quantity = Number($("stockQuantity").value);
        if (!Number.isInteger(quantity) || quantity < 0) {
            Swal.fire(
                "Dữ liệu chưa hợp lệ",
                "Số lượng phải là số nguyên >= 0.",
                "warning",
            );
            return;
        }
        if (type === "adjust") product.quantity = quantity;
        if (type === "import") product.quantity += quantity;
        if (type === "export")
            product.quantity = Math.max(0, product.quantity - quantity);
        product.updated_at = today;
        inventory_logs.unshift({
            id: Math.max(0, ...inventory_logs.map((item) => item.id)) + 1,
            product_id: id,
            type,
            quantity,
            note: $("stockNote").value.trim(),
            created_at: today,
            updated_at: today,
        });
        closeStockModal();
        renderProducts();
        Swal.fire({
            title: "Đã cập nhật tồn kho",
            icon: "success",
            confirmButtonColor: "#0d9488",
        });
    }

    function toggleSelect(id) {
        state.selected.has(id)
            ? state.selected.delete(id)
            : state.selected.add(id);
        renderProducts();
    }

    function bulkUpdate(status) {
        if (!state.selected.size)
            return Swal.fire(
                "Chưa chọn sản phẩm",
                "Vui lòng chọn ít nhất một sản phẩm.",
                "info",
            );
        products.forEach((product) => {
            if (state.selected.has(product.id)) {
                product.status = status;
                product.updated_at = today;
            }
        });
        state.selected.clear();
        renderProducts();
        Swal.fire({
            title: "Đã cập nhật sản phẩm đã chọn",
            icon: "success",
            confirmButtonColor: "#0d9488",
        });
    }

    function bulkDelete() {
        if (!state.selected.size)
            return Swal.fire(
                "Chưa chọn sản phẩm",
                "Vui lòng chọn ít nhất một sản phẩm.",
                "info",
            );
        Swal.fire({
            title: "Xóa các sản phẩm đã chọn?",
            text: `${state.selected.size} sản phẩm sẽ bị xóa khỏi dữ liệu demo.`,
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#e11d48",
            cancelButtonColor: "#64748b",
            confirmButtonText: "Xóa",
            cancelButtonText: "Hủy",
        }).then((result) => {
            if (!result.isConfirmed) return;
            products = products.filter(
                (product) => !state.selected.has(product.id),
            );
            product_images = product_images.filter((image) =>
                products.some((product) => product.id === image.product_id),
            );
            state.selected.clear();
            renderProducts();
            Swal.fire({
                title: "Đã xóa sản phẩm đã chọn",
                icon: "success",
                confirmButtonColor: "#0d9488",
            });
        });
    }

    function goPage(page) {
        const totalPages = Math.max(
            Math.ceil(filteredProducts().length / state.perPage),
            1,
        );
        if (page < 1 || page > totalPages) return;
        state.page = page;
        renderProducts();
    }

    function resetFilters() {
        state.search = "";
        state.category = "all";
        state.status = "all";
        state.sort = "newest";
        state.page = 1;
        $("searchInput").value = "";
        $("categoryFilter").value = "all";
        $("statusFilter").value = "all";
        $("sortSelect").value = "newest";
        renderProducts();
        Swal.fire({
            title: "Đã đặt lại bộ lọc",
            icon: "success",
            timer: 1000,
            showConfirmButton: false,
        });
    }

    function previewFile(input, onLoad) {
        const file = input.files?.[0];
        if (!file) return;
        if (!file.type.startsWith("image/")) {
            input.value = "";
            Swal.fire(
                "File không hợp lệ",
                "Vui lòng chọn file ảnh.",
                "warning",
            );
            return;
        }
        const reader = new FileReader();
        reader.onload = (event) => onLoad(event.target.result);
        reader.readAsDataURL(file);
    }

    document
        .querySelectorAll(".close-product-modal")
        .forEach((button) =>
            button.addEventListener("click", closeProductModal),
        );
    $("addProductBtn").addEventListener("click", () => openProductModal());
    $("productForm").addEventListener("submit", saveProduct);
    $("closeDetailModal").addEventListener("click", closeDetail);
    $("closeStockModal").addEventListener("click", closeStockModal);
    $("cancelStockBtn").addEventListener("click", closeStockModal);
    $("stockForm").addEventListener("submit", saveStock);
    $("nameInput").addEventListener("input", () => {
        if (!state.editingId)
            $("slugInput").value = slugify($("nameInput").value);
    });
    $("thumbnailInput").addEventListener(
        "input",
        () =>
            ($("thumbnailPreview").src =
                $("thumbnailInput").value ||
                "https://placehold.co/600x600/f0fdfa/0f766e?text=Preview"),
    );
    $("thumbnailFile").addEventListener("change", (event) =>
        previewFile(event.target, (src) => {
            $("thumbnailInput").value = src;
            $("thumbnailPreview").src = src;
        }),
    );
    $("galleryFiles").addEventListener("change", (event) => {
        const files = Array.from(event.target.files || []);
        if (files.some((file) => !file.type.startsWith("image/")))
            return Swal.fire(
                "File không hợp lệ",
                "Danh sách chỉ được chứa file ảnh.",
                "warning",
            );
        $("galleryPreview").innerHTML = "";
        files.forEach((file) => {
            const reader = new FileReader();
            reader.onload = (readerEvent) =>
                $("galleryPreview").insertAdjacentHTML(
                    "beforeend",
                    `<img src="${readerEvent.target.result}" class="aspect-square rounded-xl object-cover" alt="Ảnh phụ">`,
                );
            reader.readAsDataURL(file);
        });
    });

    ["searchInput", "categoryFilter", "statusFilter", "sortSelect"].forEach(
        (id) => {
            $(id).addEventListener(
                id === "searchInput" ? "input" : "change",
                (event) => {
                    if (id === "searchInput") state.search = event.target.value;
                    if (id === "categoryFilter")
                        state.category = event.target.value;
                    if (id === "statusFilter")
                        state.status = event.target.value;
                    if (id === "sortSelect") state.sort = event.target.value;
                    state.page = 1;
                    renderProducts();
                },
            );
        },
    );

    $("headerSearch").addEventListener("input", (event) => {
        $("searchInput").value = event.target.value;
        state.search = event.target.value;
        state.page = 1;
        renderProducts();
    });
    $("resetFilterBtn").addEventListener("click", resetFilters);
    $("selectAll").addEventListener("change", (event) => {
        filteredProducts()
            .slice((state.page - 1) * state.perPage, state.page * state.perPage)
            .forEach((product) => {
                event.target.checked
                    ? state.selected.add(product.id)
                    : state.selected.delete(product.id);
            });
        renderProducts();
    });
    $("bulkShowBtn").addEventListener("click", () => bulkUpdate("active"));
    $("bulkHideBtn").addEventListener("click", () => bulkUpdate("inactive"));
    $("bulkDeleteBtn").addEventListener("click", bulkDelete);
    $("toggleSidebar").addEventListener("click", () =>
        window.innerWidth < 1024
            ? document.body.classList.toggle("mobile-sidebar-open")
            : document.body.classList.toggle("sidebar-collapsed"),
    );
    $("sidebarOverlay").addEventListener("click", () =>
        document.body.classList.remove("mobile-sidebar-open"),
    );
    $("accountBtn").addEventListener("click", () =>
        $("accountMenu").classList.toggle("hidden"),
    );
    $("notifyBtn").addEventListener("click", () =>
        Swal.fire({
            title: "Thông báo tồn kho",
            text: `${products.filter((product) => product.quantity <= 5).length} sản phẩm cần kiểm tra tồn kho.`,
            icon: "info",
            confirmButtonColor: "#0d9488",
        }),
    );

    renderCategoryOptions();
    renderProducts();
</script>
