          <button onclick="deleteProduct(${product.id})" class="grid h-9 w-9 place-items-center rounded-xl bg-rose-50 text-rose-700 hover:bg-rose-100" title="Xóa"><i class="fa-regular fa-trash-can"></i></button>
        </div>
