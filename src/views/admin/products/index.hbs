            </div>
            <button
                id="closeStockModal"
                class="grid h-10 w-10 place-items-center rounded-xl bg-slate-100 text-slate-600 hover:bg-slate-200"
            >
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <form id="stockForm" class="space-y-4 p-6">
            <input type="hidden" id="stockProductId" />
            <div
                class="rounded-2xl bg-slate-50 p-4 text-sm font-semibold text-slate-600"
            >
                Tồn kho hiện tại:
                <span id="currentStock" class="font-bold text-slate-950"></span>
            </div>
            <label class="block">
                <span class="text-sm font-bold text-slate-700"
                    >Loại điều chỉnh</span
                >
                <select
                    id="stockType"
                    class="mt-2 h-11 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm outline-none focus:border-kigen-500"
                >
                    <option value="adjust">adjust</option>
                    <option value="import">import</option>
                    <option value="export">export</option>
                </select>
            </label>
            <label class="block">
                <span class="text-sm font-bold text-slate-700"
                    >Số lượng mới hoặc số lượng điều chỉnh</span
                >
                <input
                    id="stockQuantity"
                    type="number"
                    min="0"
                    class="mt-2 h-11 w-full rounded-xl border border-slate-200 px-3 text-sm outline-none focus:border-kigen-500"
                />
            </label>
            <label class="block">
                <span class="text-sm font-bold text-slate-700">Ghi chú</span>
                <textarea
                    id="stockNote"
                    rows="3"
                    class="mt-2 w-full rounded-xl border border-slate-200 px-3 py-2 text-sm outline-none focus:border-kigen-500"
                ></textarea>
            </label>
            <div class="flex justify-end gap-3 pt-2">
                <button
                    type="button"
                    id="cancelStockBtn"
                    class="rounded-2xl border border-slate-200 px-5 py-3 text-sm font-bold text-slate-600 hover:bg-slate-100"
                >
                    Hủy
                </button>
                <button
                    type="submit"
                    class="rounded-2xl bg-kigen-600 px-5 py-3 text-sm font-bold text-white hover:bg-kigen-700"
                >
                    Cập nhật
                </button>
            </div>
        </form>
    </div>
</div>
