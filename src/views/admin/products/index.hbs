<main class="space-y-6 p-4 pb-28 lg:p-8 lg:pb-28">
    <section
        class="flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between"
    >
        <div>
            <nav class="mb-3 text-sm font-semibold text-slate-400">
                Admin <span class="mx-2">/</span>
                <span class="text-kigen-700">Quản lý sản phẩm</span>
            </nav>

            <h1 class="text-2xl font-bold text-slate-950 sm:text-3xl">
                Quản lý sản phẩm
            </h1>

            <p class="mt-2 text-sm text-slate-500">
                Thêm, chỉnh sửa, quản lý tồn kho, trạng thái và hình ảnh sản phẩm.
            </p>
        </div>

        <button
            id="addProductBtn"
            type="button"
            class="inline-flex w-max items-center gap-2 rounded-2xl bg-kigen-600 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-kigen-600/20 hover:bg-kigen-700"
        >
            <i class="fa-solid fa-plus"></i>
            Thêm sản phẩm
        </button>
    </section>

    {{> admin/products/partials/stats}}
    {{> admin/products/partials/filter}}
    {{> admin/products/partials/table}}
</main>

{{> admin/products/partials/modal}}
{{> admin/products/partials/images-modal}}

<script>
    const APP_CONFIG = window.APP_CONFIG || {};

    const PUBLIC_BASE_URL = APP_CONFIG.APP_URL || window.location.origin;
    const API_BASE_URL = APP_CONFIG.APP_URL_API || `${PUBLIC_BASE_URL}/api`;

    const PRODUCT_API_URL = `${API_BASE_URL}/products`;
    const CATEGORY_API_URL = `${API_BASE_URL}/categories`;

    const allowedImageTypes = ["image/jpeg", "image/png", "image/webp"];
    const maxImageSize = 2 * 1024 * 1024;

    const state = {
        products: [],
        categories: [],
        selected: new Set(),

        search: "",
        categoryId: "",
        status: "",
        hasSale: "",
        minPrice: "",
        maxPrice: "",

        sortBy: "createdAt",
        sortOrder: "DESC",

        page: 1,
        limit: 10,
        meta: null,

        editingId: null,
        thumbnailFile: null,

        imageProductId: null,
        imageProductName: "",
        productImages: [],
    };

    const $ = (id) => document.getElementById(id);
    
    async function fetchJson(url, options = {}) {
        const response = await fetch(url, {
            credentials: "include",
            ...options,
        });

        const result = await response.json().catch(() => ({}));

        if (!response.ok || result.success === false) {
            throw new Error(result.message || "Thao tác thất bại");
        }

        return result;
    }

    function getItemsFromResponse(result) {
        return result?.data?.data || result?.data || [];
    }

    function getMetaFromResponse(result) {
        return result?.data?.meta || null;
    }

    function getImageUrl(image) {
        if (!image) {
            return "https://placehold.co/600x600/f0fdfa/0f766e?text=Product";
        }

        if (image.startsWith("http://") || image.startsWith("https://")) {
            return image;
        }

        return `${PUBLIC_BASE_URL}/${image.replace(/^\/+/, "")}`;
    }

    function formatCurrency(value) {
        if (value === null || value === undefined || value === "") {
            return "Không có";
        }

        return new Intl.NumberFormat("vi-VN", {
            style: "currency",
            currency: "VND",
            maximumFractionDigits: 0,
        }).format(Number(value));
    }

    function formatDate(value) {
        if (!value) return "---";

        const date = new Date(value);

        if (Number.isNaN(date.getTime())) {
            return "---";
        }

        return new Intl.DateTimeFormat("vi-VN", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
        }).format(date);
    }

    function isSale(product) {
        return (
            product.salePrice !== null &&
            product.salePrice !== undefined &&
            Number(product.salePrice) > 0 &&
            Number(product.salePrice) < Number(product.price)
        );
    }

    function categoryName(product) {
        return (
            product.category?.name ||
            state.categories.find(
                (category) =>
                    Number(category.id) === Number(product.categoryId),
            )?.name ||
            "Không xác định"
        );
    }

    function statusLabel(status) {
        const labels = {
            active: "Đang bán",
            inactive: "Đang ẩn",
            out_of_stock: "Hết hàng",
        };

        return labels[status] || status || "---";
    }

    function statusBadge(product) {
        if (product.status === "active") {
            return '<span class="rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-bold text-emerald-700 ring-1 ring-emerald-200">Đang bán</span>';
        }

        if (product.status === "out_of_stock") {
            return '<span class="rounded-full bg-rose-50 px-2.5 py-1 text-xs font-bold text-rose-700 ring-1 ring-rose-200">Hết hàng</span>';
        }

        return '<span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-bold text-slate-600 ring-1 ring-slate-200">Đang ẩn</span>';
    }

    function stockBadge(product) {
        if (Number(product.quantity) <= 0) {
            return '<span class="rounded-full bg-rose-50 px-2.5 py-1 text-xs font-bold text-rose-700 ring-1 ring-rose-200">Hết hàng</span>';
        }

        if (Number(product.quantity) <= 5) {
            return '<span class="rounded-full bg-amber-50 px-2.5 py-1 text-xs font-bold text-amber-700 ring-1 ring-amber-200">Sắp hết hàng</span>';
        }

        return '<span class="rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-bold text-emerald-700 ring-1 ring-emerald-200">Còn hàng</span>';
    }

    function statusSwitch(product) {
        const active = product.status === "active";

        return `
        <button
            type="button"
            onclick="toggleProductStatus(${product.id}, '${active ? "inactive" : "active"}')"
            class="inline-flex h-7 w-12 items-center rounded-full p-1 transition ${active ? "bg-kigen-600" : "bg-slate-300"}"
            title="Bật/tắt trạng thái"
        >
            <span class="h-5 w-5 rounded-full bg-white shadow transition ${active ? "translate-x-5" : ""}"></span>
        </button>
    `;
    }

    function rowActions(product) {
        return `
        <div class="flex justify-end gap-2">
            <button
                type="button"
                onclick="openDetail(${product.id})"
                class="grid h-9 w-9 place-items-center rounded-xl bg-slate-100 text-slate-600 hover:text-kigen-700"
                title="Xem nhanh"
            >
                <i class="fa-regular fa-eye"></i>
            </button>

            <button
                type="button"
                onclick="openProductModal(${product.id})"
                class="grid h-9 w-9 place-items-center rounded-xl bg-kigen-50 text-kigen-700 hover:bg-kigen-100"
                title="Sửa"
            >
                <i class="fa-regular fa-pen-to-square"></i>
            </button>

            <button
                type="button"
                onclick="openProductImagesModal(${product.id})"
                class="grid h-9 w-9 place-items-center rounded-xl bg-indigo-50 text-indigo-700 hover:bg-indigo-100"
                title="Quản lý ảnh"
            >
                <i class="fa-regular fa-images"></i>
            </button>

            <button
                type="button"
                onclick="deleteProduct(${product.id})"
                class="grid h-9 w-9 place-items-center rounded-xl bg-rose-50 text-rose-700 hover:bg-rose-100"
                title="Xóa"
            >
                <i class="fa-regular fa-trash-can"></i>
            </button>
        </div>
    `;
    }

    function updateStats() {
        const list = state.products;

        $("statTotalProducts").textContent =
            state.meta?.totalItems || list.length;
        $("statActiveProducts").textContent = list.filter(
            (product) => product.status === "active",
        ).length;
        $("statInactiveProducts").textContent = list.filter(
            (product) => product.status === "inactive",
        ).length;
        $("statOutOfStockProducts").textContent = list.filter(
            (product) => product.status === "out_of_stock",
        ).length;
        $("statSaleProducts").textContent = list.filter(isSale).length;
    }

    function updateSelectionInfo() {
        $("selectedText").textContent = state.selected.size
            ? `Đã chọn ${state.selected.size} sản phẩm`
            : "Chưa chọn sản phẩm";

        $("resultText").textContent =
            `${state.products.length} sản phẩm phù hợp`;

        const selectAll = $("selectAll");

        if (selectAll) {
            selectAll.checked =
                state.products.length > 0 &&
                state.products.every((product) =>
                    state.selected.has(Number(product.id)),
                );
        }
    }

    function renderProducts() {
        updateStats();
        updateSelectionInfo();
        renderPagination();

        if (!state.products.length) {
            $("productTable").innerHTML = `
            <tr>
                <td colspan="10" class="px-5 py-12 text-center text-sm font-semibold text-slate-500">
                    Không có sản phẩm phù hợp.
                </td>
            </tr>
        `;

            $("productCards").innerHTML = `
            <div class="rounded-2xl bg-slate-50 p-6 text-center text-sm font-semibold text-slate-500">
                Không có sản phẩm phù hợp.
            </div>
        `;

            return;
        }

        $("productTable").innerHTML = state.products
            .map((product) => {
                return `
                <tr class="border-t border-slate-100 hover:bg-slate-50">
                    <td class="px-5 py-4">
                        <input
                            type="checkbox"
                            ${state.selected.has(Number(product.id)) ? "checked" : ""}
                            onchange="toggleSelect(${product.id})"
                            class="h-4 w-4 rounded border-slate-300 text-kigen-600"
                        />
                    </td>

                    <td class="px-5 py-4">
                        <div class="flex items-center gap-3">
                            <img
                                src="${getImageUrl(product.thumbnail)}"
                                alt="${product.name}"
                                class="h-14 w-14 rounded-2xl object-cover ring-1 ring-slate-200"
                            />

                            <div class="min-w-0">
                                <p class="font-bold text-slate-950">${product.name}</p>
                                <p class="max-w-60 truncate text-xs text-slate-500">
                                    ${product.shortDescription || "Không có mô tả ngắn"}
                                </p>
                            </div>
                        </div>
                    </td>

                    <td class="px-5 py-4 font-semibold text-slate-600">
                        ${product.sku || "---"}
                    </td>

                    <td class="px-5 py-4 text-slate-600">
                        ${categoryName(product)}
                    </td>

                    <td class="px-5 py-4 font-bold text-slate-950">
                        ${formatCurrency(product.price)}
                    </td>

                    <td class="px-5 py-4 font-bold ${isSale(product) ? "text-kigen-700" : "text-slate-400"}">
                        ${formatCurrency(product.salePrice)}
                    </td>

                    <td class="px-5 py-4">
                        <div class="space-y-1">
                            <p class="font-bold text-slate-950">${product.quantity || 0}</p>
                            ${stockBadge(product)}
                        </div>
                    </td>

                    <td class="px-5 py-4">
                        <div class="flex items-center gap-3">
                            ${statusSwitch(product)}
                            ${statusBadge(product)}
                        </div>
                    </td>

                    <td class="px-5 py-4 text-slate-500">
                        ${formatDate(product.createdAt)}
                    </td>

                    <td class="px-5 py-4">
                        ${rowActions(product)}
                    </td>
                </tr>
            `;
            })
            .join("");

        $("productCards").innerHTML = state.products
            .map((product) => {
                return `
                <article class="rounded-3xl border border-slate-200 bg-white p-4">
                    <div class="flex gap-3">
                        <input
                            type="checkbox"
                            ${state.selected.has(Number(product.id)) ? "checked" : ""}
                            onchange="toggleSelect(${product.id})"
                            class="mt-2 h-4 w-4 rounded border-slate-300 text-kigen-600"
                        />

                        <img
                            src="${getImageUrl(product.thumbnail)}"
                            alt="${product.name}"
                            class="h-20 w-20 rounded-2xl object-cover ring-1 ring-slate-200"
                        />

                        <div class="min-w-0 flex-1">
                            <p class="font-bold text-slate-950">${product.name}</p>

                            <p class="mt-1 text-xs text-slate-500">
                                ${product.sku || "---"} • ${categoryName(product)}
                            </p>

                            <div class="mt-2 flex flex-wrap gap-2">
                                ${statusBadge(product)}
                                ${stockBadge(product)}
                                ${
                                    isSale(product)
                                        ? '<span class="rounded-full bg-kigen-50 px-2.5 py-1 text-xs font-bold text-kigen-700">Đang giảm giá</span>'
                                        : ""
                                }
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 flex items-center justify-between border-t border-slate-100 pt-4">
                        <div>
                            <p class="font-bold text-slate-950">${formatCurrency(product.price)}</p>
                            <p class="text-sm font-semibold text-kigen-700">${formatCurrency(product.salePrice)}</p>
                        </div>

                        ${statusSwitch(product)}
                    </div>

                    <div class="mt-4">${rowActions(product)}</div>
                </article>
            `;
            })
            .join("");
    }

    function renderPagination() {
        const meta = state.meta;

        if (!meta) {
            $("paginationText").textContent = `Trang ${state.page}`;
            $("prevPageBtn").disabled = state.page <= 1;
            $("nextPageBtn").disabled = true;
            return;
        }

        $("paginationText").textContent =
            `Trang ${meta.page}/${meta.totalPages} • ${meta.totalItems} sản phẩm`;

        $("prevPageBtn").disabled = !meta.hasPreviousPage;
        $("nextPageBtn").disabled = !meta.hasNextPage;
    }

    function buildProductListUrl() {
        const params = new URLSearchParams();

        params.set("page", state.page);
        params.set("limit", state.limit);
        params.set("sortBy", state.sortBy);
        params.set("sortOrder", state.sortOrder);

        if (state.search) {
            params.set("search", state.search);
        }

        if (state.categoryId) {
            params.set("categoryId", state.categoryId);
        }

        if (state.status) {
            params.set("status", state.status);
        }

        if (state.hasSale !== "") {
            params.set("hasSale", state.hasSale);
        }

        if (state.minPrice !== "") {
            params.set("minPrice", state.minPrice);
        }

        if (state.maxPrice !== "") {
            params.set("maxPrice", state.maxPrice);
        }

        return `${PRODUCT_API_URL}?${params.toString()}`;
    }

    async function fetchProducts() {
        $("productTable").innerHTML = `
        <tr>
            <td colspan="10" class="px-5 py-12 text-center text-sm font-semibold text-slate-500">
                Đang tải sản phẩm...
            </td>
        </tr>
    `;

        try {
            const result = await fetchJson(buildProductListUrl());

            state.products = getItemsFromResponse(result);
            state.meta = getMetaFromResponse(result);

            renderProducts();
        } catch (error) {
            $("productTable").innerHTML = `
            <tr>
                <td colspan="10" class="px-5 py-12 text-center text-sm font-semibold text-rose-500">
                    ${error.message}
                </td>
            </tr>
        `;

            notify("error", "Lỗi tải sản phẩm", error.message);
        }
    }

    async function fetchCategories() {
        try {
            const result = await fetchJson(`${CATEGORY_API_URL}/active`);

            state.categories = Array.isArray(result.data) ? result.data : [];

            renderCategoryOptions();
        } catch (error) {
            state.categories = [];
            renderCategoryOptions();

            notify("error", "Lỗi tải danh mục", error.message);
        }
    }

    function renderCategoryOptions() {
        const options = state.categories
            .map((category) => {
                return `<option value="${category.id}">${category.name}</option>`;
            })
            .join("");

        $("categoryFilter").innerHTML =
            '<option value="">Tất cả danh mục</option>' + options;

        $("categoryInput").innerHTML =
            '<option value="">Chọn danh mục</option>' + options;
    }

    function clearErrors() {
        document.querySelectorAll("[data-error]").forEach((item) => {
            item.textContent = "";
        });

        document.querySelectorAll(".field-error").forEach((item) => {
            item.classList.remove("field-error");
        });
    }

    function setError(id, message, errors) {
        errors[id] = message;

        const input = $(id);

        if (input) {
            input.classList.add("field-error");
        }

        const error = document.querySelector(`[data-error="${id}"]`);

        if (error) {
            error.textContent = message;
        }
    }

    function validateImageFile(file, fieldId, errors) {
        if (!file) return;

        if (!allowedImageTypes.includes(file.type)) {
            setError(fieldId, "Chỉ chấp nhận ảnh JPG, PNG hoặc WEBP.", errors);
        }

        if (file.size > maxImageSize) {
            setError(fieldId, "Ảnh không được vượt quá 2MB.", errors);
        }
    }

    function validateProduct() {
        clearErrors();

        const name = $("nameInput").value.trim();
        const sku = $("skuInput").value.trim();
        const categoryId = $("categoryInput").value;
        const price = $("priceInput").value;
        const salePrice = $("salePriceInput").value;
        const quantity = $("quantityInput").value;
        const shortDescription = $("shortDescriptionInput").value.trim();
        const status = $("statusInput").value;
        const errors = {};

        if (!name) {
            setError("nameInput", "Vui lòng nhập tên sản phẩm.", errors);
        } else if (name.length > 200) {
            setError(
                "nameInput",
                "Tên sản phẩm không được vượt quá 200 ký tự.",
                errors,
            );
        }

        if (!sku) {
            setError("skuInput", "Vui lòng nhập SKU.", errors);
        } else if (sku.length > 80) {
            setError("skuInput", "SKU không được vượt quá 80 ký tự.", errors);
        }

        if (!categoryId) {
            setError("categoryInput", "Vui lòng chọn danh mục.", errors);
        }

        if (price === "" || Number.isNaN(Number(price)) || Number(price) < 0) {
            setError("priceInput", "Giá bán phải là số >= 0.", errors);
        }

        if (
            salePrice !== "" &&
            (Number.isNaN(Number(salePrice)) ||
                Number(salePrice) < 0 ||
                Number(salePrice) > Number(price))
        ) {
            setError(
                "salePriceInput",
                "Giá khuyến mãi phải là số >= 0 và không lớn hơn giá bán.",
                errors,
            );
        }

        if (
            quantity === "" ||
            !Number.isInteger(Number(quantity)) ||
            Number(quantity) < 0
        ) {
            setError(
                "quantityInput",
                "Tồn kho phải là số nguyên >= 0.",
                errors,
            );
        }

        if (shortDescription.length > 500) {
            setError(
                "shortDescriptionInput",
                "Mô tả ngắn không được vượt quá 500 ký tự.",
                errors,
            );
        }

        if (!["active", "inactive", "out_of_stock"].includes(status)) {
            setError(
                "statusInput",
                "Trạng thái sản phẩm không hợp lệ.",
                errors,
            );
        }

        validateImageFile(state.thumbnailFile, "thumbnailFile", errors);

        const firstError = Object.keys(errors)[0];

        if (firstError) {
            $(firstError)?.focus();

            notify(
                "warning",
                "Dữ liệu chưa hợp lệ",
                "Vui lòng kiểm tra lại thông tin sản phẩm.",
            );
        }

        return !firstError;
    }

    function buildProductFormData() {
        const formData = new FormData();

        formData.append("categoryId", $("categoryInput").value);
        formData.append("name", $("nameInput").value.trim());
        formData.append("sku", $("skuInput").value.trim());
        formData.append("price", $("priceInput").value);
        formData.append("salePrice", $("salePriceInput").value || "");
        formData.append("quantity", $("quantityInput").value);
        formData.append(
            "shortDescription",
            $("shortDescriptionInput").value.trim(),
        );
        formData.append("description", $("descriptionInput").value.trim());
        formData.append("status", $("statusInput").value);

        if (state.thumbnailFile) {
            formData.append("thumbnail", state.thumbnailFile);
        }

        return formData;
    }

    function resetThumbnailPreview() {
        state.thumbnailFile = null;
        $("thumbnailFile").value = "";
        $("thumbnailPreview").src =
            "https://placehold.co/600x600/f0fdfa/0f766e?text=Product";
    }

    function openProductModal(id = null) {
        state.editingId = id;

        clearErrors();
        $("productForm").reset();
        resetThumbnailPreview();

        const product = state.products.find(
            (item) => Number(item.id) === Number(id),
        );

        $("productModalTitle").textContent = product
            ? "Sửa sản phẩm"
            : "Thêm sản phẩm";

        $("productId").value = product?.id || "";
        $("nameInput").value = product?.name || "";
        $("skuInput").value = product?.sku || "";
        $("categoryInput").value = product?.categoryId || "";
        $("priceInput").value = product?.price ?? "";
        $("salePriceInput").value = product?.salePrice ?? "";
        $("quantityInput").value = product?.quantity ?? "";
        $("shortDescriptionInput").value = product?.shortDescription || "";
        $("descriptionInput").value = product?.description || "";
        $("statusInput").value = product?.status || "active";

        if (product?.thumbnail) {
            $("thumbnailPreview").src = getImageUrl(product.thumbnail);
        }

        $("productModal").classList.remove("hidden");
        $("productModal").classList.add("flex");

        setTimeout(() => $("nameInput").focus(), 50);
    }

    function closeProductModal() {
        $("productModal").classList.add("hidden");
        $("productModal").classList.remove("flex");
    }

    async function saveProduct(event) {
        event.preventDefault();

        if (!validateProduct()) return;

        const id = $("productId").value;
        const isEdit = Boolean(id);

        $("saveProductBtn").disabled = true;

        try {
            await fetchJson(
                isEdit ? `${PRODUCT_API_URL}/${id}` : PRODUCT_API_URL,
                {
                    method: isEdit ? "PATCH" : "POST",
                    body: buildProductFormData(),
                },
            );

            closeProductModal();
            await fetchProducts();

            notify(
                "success",
                "Đã lưu sản phẩm",
                isEdit
                    ? "Cập nhật sản phẩm thành công."
                    : "Thêm sản phẩm thành công.",
            );
        } catch (error) {
            notify("error", "Lỗi lưu sản phẩm", error.message);
        } finally {
            $("saveProductBtn").disabled = false;
        }
    }

    async function openDetail(id) {
        try {
            const result = await fetchJson(`${PRODUCT_API_URL}/${id}`);
            const product = result.data || result;

            const images = Array.isArray(product.images) ? product.images : [];

            $("detailBody").innerHTML = `
            <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
                <div>
                    <img
                        src="${getImageUrl(product.thumbnail)}"
                        alt="${product.name}"
                        class="aspect-square w-full rounded-3xl object-cover ring-1 ring-slate-200"
                    />

                    <div class="mt-3 grid grid-cols-3 gap-2">
                        ${
                            images.length
                                ? images
                                      .map(
                                          (image) => `
                                            <img
                                                src="${getImageUrl(image.imageUrl)}"
                                                class="aspect-square rounded-xl object-cover ring-1 ring-slate-200"
                                                alt="Ảnh phụ"
                                            />
                                        `,
                                      )
                                      .join("")
                                : '<p class="col-span-3 text-sm text-slate-500">Chưa có ảnh phụ.</p>'
                        }
                    </div>
                </div>

                <div class="space-y-3 md:col-span-2">
                    <h3 class="text-2xl font-bold text-slate-950">${product.name}</h3>

                    <p class="text-sm text-slate-500">
                        ${product.shortDescription || "Không có mô tả ngắn"}
                    </p>

                    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                        ${detailLine("SKU", product.sku)}
                        ${detailLine("Slug", product.slug)}
                        ${detailLine("Danh mục", categoryName(product))}
                        ${detailLine("Giá bán", formatCurrency(product.price))}
                        ${detailLine("Giá khuyến mãi", formatCurrency(product.salePrice))}
                        ${detailLine("Tồn kho", product.quantity || 0)}
                        ${detailLine("Trạng thái", statusLabel(product.status))}
                        ${detailLine("Ngày tạo", formatDate(product.createdAt))}
                        ${detailLine("Ngày cập nhật", formatDate(product.updatedAt))}
                    </div>

                    <div class="rounded-2xl bg-slate-50 p-4">
                        <p class="text-sm font-bold text-slate-700">
                            Mô tả chi tiết
                        </p>

                        <p class="mt-2 text-sm leading-6 text-slate-600">
                            ${product.description || "Không có"}
                        </p>
                    </div>

                    <div class="flex justify-end gap-3">
                        <button
                            type="button"
                            onclick="closeDetail();openProductImagesModal(${product.id})"
                            class="rounded-2xl border border-slate-200 px-5 py-3 text-sm font-bold text-slate-700 hover:bg-slate-100"
                        >
                            Quản lý ảnh
                        </button>

                        <button
                            type="button"
                            onclick="closeDetail();openProductModal(${product.id})"
                            class="rounded-2xl bg-kigen-600 px-5 py-3 text-sm font-bold text-white"
                        >
                            Sửa sản phẩm
                        </button>
                    </div>
                </div>
            </div>
        `;

            $("detailModal").classList.remove("hidden");
            $("detailModal").classList.add("flex");
        } catch (error) {
            notify("error", "Lỗi tải chi tiết", error.message);
        }
    }

    function detailLine(label, value) {
        return `
        <div class="rounded-2xl border border-slate-100 bg-slate-50 p-3">
            <p class="text-xs font-bold uppercase text-slate-400">${label}</p>
            <p class="mt-1 text-sm font-bold text-slate-800">${value ?? "---"}</p>
        </div>
    `;
    }

    function closeDetail() {
        $("detailModal").classList.add("hidden");
        $("detailModal").classList.remove("flex");
    }

    async function toggleProductStatus(id, status) {
        try {
            await fetchJson(`${PRODUCT_API_URL}/${id}/status`, {
                method: "PATCH",
                headers: {
                    "Content-Type": "application/json",
                },
                body: JSON.stringify({ status }),
            });

            await fetchProducts();

            notify(
                "success",
                "Đã cập nhật trạng thái",
                `Sản phẩm đã được chuyển sang trạng thái ${statusLabel(status)}.`,
            );
        } catch (error) {
            notify("error", "Lỗi trạng thái", error.message);
        }
    }

    async function deleteProduct(id) {
        const product = state.products.find(
            (item) => Number(item.id) === Number(id),
        );

        if (!product) return;

        const confirmed = await confirmAction({
            title: "Xóa sản phẩm?",
            message: `Sản phẩm "${product.name}" sẽ được chuyển vào thùng rác.`,
            confirmText: "Xóa sản phẩm",
            cancelText: "Hủy",
            icon: "warning",
        });

        if (!confirmed) return;

        try {
            await fetchJson(`${PRODUCT_API_URL}/${id}`, {
                method: "DELETE",
            });

            state.selected.delete(Number(id));

            await fetchProducts();

            notify(
                "success",
                "Đã xóa sản phẩm",
                "Sản phẩm đã được chuyển vào thùng rác.",
            );
        } catch (error) {
            notify("error", "Lỗi xóa sản phẩm", error.message);
        }
    }

    function toggleSelect(id) {
        const productId = Number(id);

        state.selected.has(productId)
            ? state.selected.delete(productId)
            : state.selected.add(productId);

        renderProducts();
    }

    async function bulkUpdate(status) {
        if (!state.selected.size) {
            notify(
                "info",
                "Chưa chọn sản phẩm",
                "Vui lòng chọn ít nhất một sản phẩm.",
            );
            return;
        }

        const selectedIds = Array.from(state.selected);

        try {
            for (const id of selectedIds) {
                await fetchJson(`${PRODUCT_API_URL}/${id}/status`, {
                    method: "PATCH",
                    headers: {
                        "Content-Type": "application/json",
                    },
                    body: JSON.stringify({ status }),
                });
            }

            state.selected.clear();

            await fetchProducts();

            notify(
                "success",
                "Đã cập nhật",
                "Sản phẩm đã chọn đã được cập nhật trạng thái.",
            );
        } catch (error) {
            notify("error", "Lỗi cập nhật", error.message);
        }
    }

    async function bulkDelete() {
        if (!state.selected.size) {
            notify(
                "info",
                "Chưa chọn sản phẩm",
                "Vui lòng chọn ít nhất một sản phẩm.",
            );
            return;
        }

        const confirmed = await confirmAction({
            title: "Xóa sản phẩm đã chọn?",
            message: `${state.selected.size} sản phẩm sẽ được chuyển vào thùng rác.`,
            confirmText: "Xóa đã chọn",
            cancelText: "Hủy",
            icon: "warning",
        });

        if (!confirmed) return;

        const selectedIds = Array.from(state.selected);

        try {
            for (const id of selectedIds) {
                await fetchJson(`${PRODUCT_API_URL}/${id}`, {
                    method: "DELETE",
                });
            }

            state.selected.clear();

            await fetchProducts();

            notify(
                "success",
                "Đã xóa",
                "Các sản phẩm đã chọn đã được chuyển vào thùng rác.",
            );
        } catch (error) {
            notify("error", "Lỗi xóa hàng loạt", error.message);
        }
    }

    function resetFilters() {
        state.search = "";
        state.categoryId = "";
        state.status = "";
        state.hasSale = "";
        state.minPrice = "";
        state.maxPrice = "";
        state.sortBy = "createdAt";
        state.sortOrder = "DESC";
        state.page = 1;
        state.limit = 10;
        state.selected.clear();

        $("searchInput").value = "";
        $("categoryFilter").value = "";
        $("statusFilter").value = "";
        $("saleFilter").value = "";
        $("minPriceInput").value = "";
        $("maxPriceInput").value = "";
        $("sortSelect").value = "createdAt_DESC";
        $("limitSelect").value = "10";

        const headerSearch = $("headerSearch");

        if (headerSearch) {
            headerSearch.value = "";
        }

        fetchProducts();

        notify("success", "Đã đặt lại", "Bộ lọc đã được đặt lại.");
    }

    function handleThumbnailChange(event) {
        const file = event.target.files?.[0];

        state.thumbnailFile = null;

        if (!file) {
            $("thumbnailPreview").src =
                "https://placehold.co/600x600/f0fdfa/0f766e?text=Product";
            return;
        }

        const errors = {};

        validateImageFile(file, "thumbnailFile", errors);

        if (Object.keys(errors).length) {
            $("thumbnailFile").value = "";
            notify("warning", "File không hợp lệ", errors.thumbnailFile);
            return;
        }

        state.thumbnailFile = file;

        const reader = new FileReader();

        reader.onload = function (readerEvent) {
            $("thumbnailPreview").src = readerEvent.target.result;
        };

        reader.readAsDataURL(file);
    }

    async function openProductImagesModal(productId) {
        const product = state.products.find(
            (item) => Number(item.id) === Number(productId),
        );

        state.imageProductId = productId;
        state.imageProductName = product?.name || `Sản phẩm #${productId}`;

        $("imageProductId").value = productId;
        $("imageProductText").textContent =
            `${state.imageProductName} • ID ${productId}`;

        resetProductImageForms();

        $("productImagesModal").classList.remove("hidden");
        $("productImagesModal").classList.add("flex");

        await fetchProductImages(productId);
    }

    function closeProductImagesModal() {
        $("productImagesModal").classList.add("hidden");
        $("productImagesModal").classList.remove("flex");
    }

    function resetProductImageForms() {
        $("singleImageFile").value = "";
        $("singleImageSortOrder").value = "";
        $("singleImageIsPrimary").checked = false;

        $("bulkImageFiles").value = "";
        $("bulkImageSortOrder").value = "";
        $("bulkImageIsPrimary").checked = false;

        document.querySelectorAll("[data-error]").forEach((item) => {
            if (
                item.dataset.error === "singleImageFile" ||
                item.dataset.error === "bulkImageFiles"
            ) {
                item.textContent = "";
            }
        });
    }

    async function fetchProductImages(productId) {
        try {
            const result = await fetchJson(
                `${PRODUCT_API_URL}/${productId}/images`,
            );

            state.productImages = Array.isArray(result.data)
                ? result.data
                : result;

            if (!Array.isArray(state.productImages)) {
                state.productImages = [];
            }

            renderProductImages();
        } catch (error) {
            state.productImages = [];
            renderProductImages();

            notify("error", "Lỗi tải ảnh sản phẩm", error.message);
        }
    }

    function renderProductImages() {
        $("productImagesResultText").textContent =
            `${state.productImages.length} ảnh`;

        if (!state.productImages.length) {
            $("productImagesGrid").innerHTML = `
            <div class="rounded-2xl bg-slate-50 p-6 text-center text-sm font-semibold text-slate-500 sm:col-span-2 xl:col-span-4">
                Chưa có ảnh phụ.
            </div>
        `;

            return;
        }

        $("productImagesGrid").innerHTML = state.productImages
            .map((image) => {
                return `
                <article class="rounded-3xl border border-slate-200 bg-white p-3">
                    <div class="relative">
                        <img
                            src="${getImageUrl(image.imageUrl)}"
                            alt="Ảnh sản phẩm"
                            class="aspect-square w-full rounded-2xl object-cover ring-1 ring-slate-200"
                        />

                        ${
                            image.isPrimary
                                ? '<span class="absolute left-3 top-3 rounded-full bg-kigen-600 px-2.5 py-1 text-xs font-bold text-white">Ảnh chính</span>'
                                : ""
                        }
                    </div>

                    <div class="mt-3 space-y-3">
                        <label class="block">
                            <span class="text-xs font-bold uppercase text-slate-400">
                                Thứ tự
                            </span>

                            <input
                                id="imageSortOrder-${image.id}"
                                type="number"
                                min="0"
                                value="${image.sortOrder || 0}"
                                class="mt-1 h-10 w-full rounded-xl border border-slate-200 px-3 text-sm outline-none focus:border-kigen-500"
                            />
                        </label>

                        <div class="grid grid-cols-2 gap-2">
                            <button
                                type="button"
                                onclick="updateProductImage(${image.id})"
                                class="rounded-xl bg-kigen-50 px-3 py-2 text-sm font-bold text-kigen-700 hover:bg-kigen-100"
                            >
                                Lưu
                            </button>

                            <button
                                type="button"
                                onclick="setPrimaryProductImage(${image.id})"
                                class="rounded-xl bg-indigo-50 px-3 py-2 text-sm font-bold text-indigo-700 hover:bg-indigo-100"
                            >
                                Ảnh chính
                            </button>

                            <button
                                type="button"
                                onclick="deleteProductImage(${image.id})"
                                class="col-span-2 rounded-xl bg-rose-50 px-3 py-2 text-sm font-bold text-rose-700 hover:bg-rose-100"
                            >
                                Xóa ảnh
                            </button>
                        </div>
                    </div>
                </article>
            `;
            })
            .join("");
    }

    function validateUploadFiles(files, errorKey) {
        const errors = {};

        if (!files.length) {
            errors[errorKey] = "Vui lòng chọn ảnh sản phẩm.";
        }

        files.forEach((file) => {
            if (!allowedImageTypes.includes(file.type)) {
                errors[errorKey] = "Chỉ chấp nhận ảnh JPG, PNG hoặc WEBP.";
            }

            if (file.size > maxImageSize) {
                errors[errorKey] = "Mỗi ảnh không được vượt quá 2MB.";
            }
        });

        const errorElement = document.querySelector(
            `[data-error="${errorKey}"]`,
        );

        if (errorElement) {
            errorElement.textContent = errors[errorKey] || "";
        }

        if (errors[errorKey]) {
            notify("warning", "File không hợp lệ", errors[errorKey]);
            return false;
        }

        return true;
    }

    async function uploadSingleProductImage() {
        const productId = state.imageProductId;
        const file = $("singleImageFile").files?.[0];

        if (!productId) return;

        if (!validateUploadFiles(file ? [file] : [], "singleImageFile")) {
            return;
        }

        const formData = new FormData();

        formData.append("image", file);
        formData.append("sortOrder", $("singleImageSortOrder").value || "");
        formData.append(
            "isPrimary",
            $("singleImageIsPrimary").checked ? "true" : "false",
        );

        $("uploadSingleImageBtn").disabled = true;

        try {
            await fetchJson(`${PRODUCT_API_URL}/${productId}/images`, {
                method: "POST",
                body: formData,
            });

            resetProductImageForms();

            await fetchProductImages(productId);
            await fetchProducts();

            notify("success", "Đã upload ảnh", "Ảnh sản phẩm đã được thêm.");
        } catch (error) {
            notify("error", "Lỗi upload ảnh", error.message);
        } finally {
            $("uploadSingleImageBtn").disabled = false;
        }
    }

    async function uploadBulkProductImages() {
        const productId = state.imageProductId;
        const files = Array.from($("bulkImageFiles").files || []);

        if (!productId) return;

        if (!validateUploadFiles(files, "bulkImageFiles")) {
            return;
        }

        const formData = new FormData();

        files.forEach((file) => {
            formData.append("images", file);
        });

        formData.append("sortOrder", $("bulkImageSortOrder").value || "");
        formData.append(
            "isPrimary",
            $("bulkImageIsPrimary").checked ? "true" : "false",
        );

        $("uploadBulkImagesBtn").disabled = true;

        try {
            await fetchJson(`${PRODUCT_API_URL}/${productId}/images/bulk`, {
                method: "POST",
                body: formData,
            });

            resetProductImageForms();

            await fetchProductImages(productId);
            await fetchProducts();

            notify(
                "success",
                "Đã upload ảnh",
                "Các ảnh sản phẩm đã được thêm.",
            );
        } catch (error) {
            notify("error", "Lỗi upload nhiều ảnh", error.message);
        } finally {
            $("uploadBulkImagesBtn").disabled = false;
        }
    }

    async function updateProductImage(imageId) {
        const productId = state.imageProductId;
        const sortOrderInput = $(`imageSortOrder-${imageId}`);

        if (!productId || !sortOrderInput) return;

        const sortOrder = Number(sortOrderInput.value);

        if (!Number.isInteger(sortOrder) || sortOrder < 0) {
            notify(
                "warning",
                "Dữ liệu chưa hợp lệ",
                "Thứ tự ảnh phải là số nguyên >= 0.",
            );
            return;
        }

        try {
            await fetchJson(
                `${PRODUCT_API_URL}/${productId}/images/${imageId}`,
                {
                    method: "PATCH",
                    headers: {
                        "Content-Type": "application/json",
                    },
                    body: JSON.stringify({
                        sortOrder,
                    }),
                },
            );

            await fetchProductImages(productId);

            notify(
                "success",
                "Đã cập nhật ảnh",
                "Thứ tự ảnh đã được cập nhật.",
            );
        } catch (error) {
            notify("error", "Lỗi cập nhật ảnh", error.message);
        }
    }

    async function setPrimaryProductImage(imageId) {
        const productId = state.imageProductId;

        if (!productId) return;

        try {
            await fetchJson(
                `${PRODUCT_API_URL}/${productId}/images/${imageId}`,
                {
                    method: "PATCH",
                    headers: {
                        "Content-Type": "application/json",
                    },
                    body: JSON.stringify({
                        isPrimary: true,
                    }),
                },
            );

            await fetchProductImages(productId);

            notify(
                "success",
                "Đã đặt ảnh chính",
                "Ảnh chính đã được cập nhật.",
            );
        } catch (error) {
            notify("error", "Lỗi đặt ảnh chính", error.message);
        }
    }

    async function deleteProductImage(imageId) {
        const productId = state.imageProductId;

        if (!productId) return;

        const confirmed = await confirmAction({
            title: "Xóa ảnh sản phẩm?",
            message: "Ảnh này sẽ được xóa khỏi gallery sản phẩm.",
            confirmText: "Xóa ảnh",
            cancelText: "Hủy",
            icon: "warning",
        });

        if (!confirmed) return;

        try {
            await fetchJson(
                `${PRODUCT_API_URL}/${productId}/images/${imageId}`,
                {
                    method: "DELETE",
                },
            );

            await fetchProductImages(productId);
            await fetchProducts();

            notify("success", "Đã xóa ảnh", "Ảnh sản phẩm đã được xóa.");
        } catch (error) {
            notify("error", "Lỗi xóa ảnh", error.message);
        }
    }

    async function deleteAllProductImages() {
        const productId = state.imageProductId;

        if (!productId) return;

        if (!state.productImages.length) {
            notify("info", "Không có ảnh", "Sản phẩm này chưa có ảnh phụ.");
            return;
        }

        const confirmed = await confirmAction({
            title: "Xóa toàn bộ ảnh?",
            message: "Toàn bộ ảnh phụ của sản phẩm sẽ bị xóa.",
            confirmText: "Xóa toàn bộ",
            cancelText: "Hủy",
            icon: "warning",
        });

        if (!confirmed) return;

        try {
            await fetchJson(`${PRODUCT_API_URL}/${productId}/images`, {
                method: "DELETE",
            });

            await fetchProductImages(productId);
            await fetchProducts();

            notify("success", "Đã xóa ảnh", "Toàn bộ ảnh phụ đã được xóa.");
        } catch (error) {
            notify("error", "Lỗi xóa ảnh", error.message);
        }
    }

    function bindEvents() {
        $("addProductBtn").addEventListener("click", () => openProductModal());

        document.querySelectorAll(".close-product-modal").forEach((button) => {
            button.addEventListener("click", closeProductModal);
        });

        $("productForm").addEventListener("submit", saveProduct);
        $("thumbnailFile").addEventListener("change", handleThumbnailChange);

        $("closeDetailModal").addEventListener("click", closeDetail);

        $("searchInput").addEventListener("input", (event) => {
            state.search = event.target.value.trim();
            state.page = 1;
            state.selected.clear();
            fetchProducts();
        });

        $("categoryFilter").addEventListener("change", (event) => {
            state.categoryId = event.target.value;
            state.page = 1;
            state.selected.clear();
            fetchProducts();
        });

        $("statusFilter").addEventListener("change", (event) => {
            state.status = event.target.value;
            state.page = 1;
            state.selected.clear();
            fetchProducts();
        });

        $("saleFilter").addEventListener("change", (event) => {
            state.hasSale = event.target.value;
            state.page = 1;
            state.selected.clear();
            fetchProducts();
        });

        $("minPriceInput").addEventListener("change", (event) => {
            state.minPrice = event.target.value;
            state.page = 1;
            fetchProducts();
        });

        $("maxPriceInput").addEventListener("change", (event) => {
            state.maxPrice = event.target.value;
            state.page = 1;
            fetchProducts();
        });

        $("sortSelect").addEventListener("change", (event) => {
            const [sortBy, sortOrder] = event.target.value.split("_");

            state.sortBy = sortBy || "createdAt";
            state.sortOrder = sortOrder || "DESC";
            state.page = 1;

            fetchProducts();
        });

        $("limitSelect").addEventListener("change", (event) => {
            state.limit = Number(event.target.value || 10);
            state.page = 1;
            fetchProducts();
        });

        $("resetFilterBtn").addEventListener("click", resetFilters);

        $("selectAll").addEventListener("change", (event) => {
            state.products.forEach((product) => {
                event.target.checked
                    ? state.selected.add(Number(product.id))
                    : state.selected.delete(Number(product.id));
            });

            renderProducts();
        });

        $("bulkShowBtn").addEventListener("click", () => bulkUpdate("active"));
        $("bulkHideBtn").addEventListener("click", () =>
            bulkUpdate("inactive"),
        );
        $("bulkDeleteBtn").addEventListener("click", bulkDelete);

        $("prevPageBtn").addEventListener("click", () => {
            if (state.page <= 1) return;

            state.page -= 1;
            fetchProducts();
        });

        $("nextPageBtn").addEventListener("click", () => {
            if (state.meta && !state.meta.hasNextPage) return;

            state.page += 1;
            fetchProducts();
        });

        $("closeProductImagesModal").addEventListener(
            "click",
            closeProductImagesModal,
        );

        $("uploadSingleImageBtn").addEventListener(
            "click",
            uploadSingleProductImage,
        );

        $("uploadBulkImagesBtn").addEventListener(
            "click",
            uploadBulkProductImages,
        );

        $("deleteAllProductImagesBtn").addEventListener(
            "click",
            deleteAllProductImages,
        );

        const headerSearch = $("headerSearch");

        if (headerSearch) {
            headerSearch.addEventListener("input", (event) => {
                $("searchInput").value = event.target.value;
                state.search = event.target.value.trim();
                state.page = 1;
                state.selected.clear();

                fetchProducts();
            });
        }
    }

    document.addEventListener("DOMContentLoaded", async function () {
        bindEvents();

        await fetchCategories();
        await fetchProducts();
    });
</script>
