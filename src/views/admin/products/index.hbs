    function filteredProducts() {
        let list = [...products];
        const keyword = state.search.toLowerCase();
        if (keyword)
            list = list.filter(
                (product) =>
                    product.name.toLowerCase().includes(keyword) ||
                    product.sku.toLowerCase().includes(keyword),
            );
        if (state.category !== "all")
            list = list.filter(
                (product) => product.category_id === Number(state.category),
            );
        if (state.status === "active")
            list = list.filter((product) => product.status === "active");
        if (state.status === "hidden") list = list.filter(isHidden);
        if (state.status === "out")
            list = list.filter((product) => product.quantity === 0);
        if (state.status === "low")
            list = list.filter(
                (product) => product.quantity > 0 && product.quantity <= 5,
            );
        if (state.status === "sale") list = list.filter(isSale);
        const sorters = {
            newest: (a, b) => new Date(b.created_at) - new Date(a.created_at),
            oldest: (a, b) => new Date(a.created_at) - new Date(b.created_at),
            priceAsc: (a, b) => a.price - b.price,
            priceDesc: (a, b) => b.price - a.price,
            stockAsc: (a, b) => a.quantity - b.quantity,
            stockDesc: (a, b) => b.quantity - a.quantity,
            nameAsc: (a, b) => a.name.localeCompare(b.name, "vi"),
        };
        return list.sort(sorters[state.sort]);
    }

