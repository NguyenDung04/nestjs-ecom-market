<main class="space-y-6 p-4 lg:p-8">
    <section
        class="flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between"
    >
        <div>
            <nav class="mb-3 text-sm font-semibold text-slate-400">
                Admin <span class="mx-2">/</span>
                <span class="text-kigen-700">Quản lý sản phẩm</span>
            </nav>
            <h1 class="text-2xl font-bold text-slate-950 sm:text-3xl">
                Quản lý sản phẩm
            </h1>
            <p class="mt-2 text-sm text-slate-500">
                Thêm, chỉnh sửa, kiểm soát tồn kho và trạng thái hiển thị sản
                phẩm
            </p>
        </div>
        <button
            id="addProductBtn"
            class="inline-flex w-max items-center gap-2 rounded-2xl bg-kigen-600 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-kigen-600/20 hover:bg-kigen-700"
        >
            <i class="fa-solid fa-plus"></i> Thêm sản phẩm
        </button>
    </section>

    <section
        id="statsGrid"
        class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-5"
    ></section>

    <section
        class="rounded-3xl border border-slate-200 bg-white p-5 shadow-soft"
    >
        <div class="grid grid-cols-1 gap-3 xl:grid-cols-12">
            <div class="relative xl:col-span-4">
                <i
                    class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"
                ></i>
                <input
                    id="searchInput"
                    class="h-12 w-full rounded-2xl border border-slate-200 bg-slate-50 pl-11 pr-4 text-sm outline-none focus:border-kigen-500"
                    placeholder="Tìm theo tên hoặc mã sản phẩm..."
                />
            </div>
            <select
                id="categoryFilter"
                class="h-12 rounded-2xl border border-slate-200 bg-white px-4 text-sm outline-none focus:border-kigen-500 xl:col-span-2"
            ></select>
            <select
                id="statusFilter"
                class="h-12 rounded-2xl border border-slate-200 bg-white px-4 text-sm outline-none focus:border-kigen-500 xl:col-span-2"
            >
                <option value="all">Tất cả trạng thái</option>
                <option value="active">Đang hiển thị</option>
                <option value="hidden">Đang ẩn</option>
                <option value="out">Hết hàng</option>
                <option value="low">Sắp hết hàng</option>
                <option value="sale">Đang giảm giá</option>
            </select>
            <select
                id="sortSelect"
                class="h-12 rounded-2xl border border-slate-200 bg-white px-4 text-sm outline-none focus:border-kigen-500 xl:col-span-2"
            >
                <option value="newest">Mới nhất</option>
                <option value="oldest">Cũ nhất</option>
                <option value="priceAsc">Giá tăng dần</option>
                <option value="priceDesc">Giá giảm dần</option>
                <option value="stockAsc">Tồn kho thấp đến cao</option>
                <option value="stockDesc">Tồn kho cao đến thấp</option>
                <option value="nameAsc">Tên A-Z</option>
            </select>
            <button
                id="resetFilterBtn"
                class="h-12 rounded-2xl border border-slate-200 px-4 text-sm font-bold text-slate-600 hover:border-kigen-500 hover:text-kigen-700 xl:col-span-2"
            >
                <i class="fa-solid fa-rotate-left mr-2"></i>Đặt lại
            </button>
        </div>

        <div
            class="mt-5 flex flex-col gap-3 border-t border-slate-100 pt-5 lg:flex-row lg:items-center lg:justify-between"
        >
            <div class="flex flex-wrap items-center gap-2">
                <span
                    id="selectedText"
                    class="text-sm font-semibold text-slate-500"
                    >Chưa chọn sản phẩm</span
                >
                <button
                    id="bulkShowBtn"
                    class="rounded-xl bg-emerald-50 px-3 py-2 text-sm font-bold text-emerald-700 hover:bg-emerald-100"
                >
                    Hiện đã chọn
                </button>
                <button
                    id="bulkHideBtn"
                    class="rounded-xl bg-amber-50 px-3 py-2 text-sm font-bold text-amber-700 hover:bg-amber-100"
                >
                    Ẩn đã chọn
                </button>
                <button
                    id="bulkDeleteBtn"
                    class="rounded-xl bg-rose-50 px-3 py-2 text-sm font-bold text-rose-700 hover:bg-rose-100"
                >
                    Xóa đã chọn
                </button>
            </div>
            <p id="resultText" class="text-sm font-semibold text-slate-500"></p>
        </div>
    </section>

    <section class="rounded-3xl border border-slate-200 bg-white shadow-soft">
        <div class="hidden overflow-x-auto lg:block">
            <table class="min-w-full text-left text-sm">
                <thead class="bg-slate-50 text-xs uppercase text-slate-400">
                    <tr>
                        <th class="px-5 py-4">
                            <input
                                id="selectAll"
                                type="checkbox"
                                class="h-4 w-4 rounded border-slate-300 text-kigen-600"
                            />
                        </th>
                        <th class="px-5 py-4">Sản phẩm</th>
                        <th class="px-5 py-4">SKU</th>
                        <th class="px-5 py-4">Danh mục</th>
                        <th class="px-5 py-4">Giá bán</th>
                        <th class="px-5 py-4">Giá khuyến mãi</th>
                        <th class="px-5 py-4">Tồn kho</th>
                        <th class="px-5 py-4">Trạng thái</th>
                        <th class="px-5 py-4">Ngày tạo</th>
                        <th class="px-5 py-4 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="productTable"></tbody>
            </table>
        </div>
        <div id="productCards" class="space-y-4 p-4 lg:hidden"></div>
        <div
            class="flex flex-col gap-3 border-t border-slate-100 p-5 sm:flex-row sm:items-center sm:justify-between"
        >
            <p id="pageText" class="text-sm font-semibold text-slate-500"></p>
            <div id="pagination" class="flex flex-wrap gap-2"></div>
        </div>
    </section>
</main>
<div
    id="productModal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/50 p-4"
>
    <div
        class="max-h-[92vh] w-full max-w-5xl overflow-y-auto rounded-3xl bg-white shadow-2xl"
    >
        <div
            class="sticky top-0 z-10 flex items-center justify-between border-b border-slate-100 bg-white px-6 py-4"
        >
            <div>
                <h2
                    id="productModalTitle"
                    class="text-xl font-bold text-slate-950"
                >
                    Thêm sản phẩm
                </h2>
                <p class="text-sm text-slate-500">
                    Backend NestJS sẽ xử lý upload thật; giao diện này preview
                    ảnh demo bằng trình duyệt.
                </p>
            </div>
            <button
                class="close-product-modal grid h-10 w-10 place-items-center rounded-xl bg-slate-100 text-slate-600 hover:bg-slate-200"
            >
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <form
            id="productForm"
            class="grid grid-cols-1 gap-5 p-6 lg:grid-cols-3"
        >
            <input type="hidden" id="productId" />
            <div class="space-y-5 lg:col-span-2">
                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                    <label class="block">
                        <span class="text-sm font-bold text-slate-700"
                            >Tên sản phẩm</span
                        >
                        <input
                            id="nameInput"
                            class="mt-2 h-11 w-full rounded-xl border border-slate-200 px-3 text-sm outline-none focus:border-kigen-500"
                        />
                        <small
                            data-error="nameInput"
                            class="mt-1 block text-xs font-semibold text-rose-600"
                        ></small>
                    </label>
                    <label class="block">
                        <span class="text-sm font-bold text-slate-700"
                            >Mã sản phẩm / SKU</span
                        >
                        <input
                            id="skuInput"
                            class="mt-2 h-11 w-full rounded-xl border border-slate-200 px-3 text-sm outline-none focus:border-kigen-500"
                        />
                        <small
                            data-error="skuInput"
                            class="mt-1 block text-xs font-semibold text-rose-600"
                        ></small>
                    </label>
                    <label class="block">
                        <span class="text-sm font-bold text-slate-700"
                            >Danh mục</span
                        >
                        <select
                            id="categoryInput"
                            class="mt-2 h-11 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm outline-none focus:border-kigen-500"
                        ></select>
                        <small
                            data-error="categoryInput"
                            class="mt-1 block text-xs font-semibold text-rose-600"
                        ></small>
                    </label>
                    <label class="block">
                        <span class="text-sm font-bold text-slate-700"
                            >Slug</span
                        >
                        <input
                            id="slugInput"
                            class="mt-2 h-11 w-full rounded-xl border border-slate-200 px-3 text-sm outline-none focus:border-kigen-500"
                        />
                    </label>
                    <label class="block">
                        <span class="text-sm font-bold text-slate-700"
                            >Giá bán</span
                        >
                        <input
                            id="priceInput"
                            type="number"
                            min="0"
                            class="mt-2 h-11 w-full rounded-xl border border-slate-200 px-3 text-sm outline-none focus:border-kigen-500"
                        />
                        <small
                            data-error="priceInput"
                            class="mt-1 block text-xs font-semibold text-rose-600"
                        ></small>
                    </label>
                    <label class="block">
                        <span class="text-sm font-bold text-slate-700"
                            >Giá khuyến mãi</span
                        >
                        <input
                            id="salePriceInput"
                            type="number"
                            min="0"
                            class="mt-2 h-11 w-full rounded-xl border border-slate-200 px-3 text-sm outline-none focus:border-kigen-500"
                        />
                        <small
                            data-error="salePriceInput"
                            class="mt-1 block text-xs font-semibold text-rose-600"
                        ></small>
                    </label>
                    <label class="block">
                        <span class="text-sm font-bold text-slate-700"
