<main
    class="relative z-10 flex-1 flex items-center justify-center py-8 sm:py-12 px-4 sm:px-6"
>
    <div
        class="max-w-5xl w-full grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center"
    >
        {{> auth/benefits}}

        <section
            class="w-full max-w-[480px] mx-auto lg:mx-0 lg:ml-auto"
            aria-label="Form đăng nhập"
        >
            <div
                class="form-card bg-white rounded-2xl shadow-lg shadow-gray-200/50 border border-gray-100 p-6 sm:p-8"
            >
                <div class="text-center mb-6">
                    <div
                        class="w-14 h-14 rounded-2xl mx-auto mb-4 flex items-center justify-center"
                        style="
                            background: linear-gradient(
                                135deg,
                                var(--teal-50),
                                var(--teal-100)
                            );
                            border: 1px solid rgba(0, 122, 122, 0.1);
                        "
                    >
                        <i
                            class="fa-solid fa-right-to-bracket text-xl"
                            style="color: var(--teal-600)"
                        ></i>
                    </div>

                    <h2 class="text-xl font-bold text-gray-900">
                        Đăng nhập tài khoản
                    </h2>

                    <p class="text-sm text-gray-500 mt-1.5">
                        Chào mừng bạn quay lại, vui lòng đăng nhập để tiếp tục mua sắm.
                    </p>
                </div>

                {{> common/alert}}

                <form
                    id="loginForm"
                    method="POST"
                    action="/login"
                    novalidate
                    autocomplete="off"
                    class="space-y-4"
                >
                    <div>
                        <label
                            for="loginEmail"
                            class="block text-sm font-medium text-gray-700 mb-1.5"
                        >
                            Email hoặc số điện thoại
                        </label>

                        <div class="relative">
                            <span
                                class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"
                            >
                                <i class="fa-solid fa-envelope"></i>
                            </span>

                            <input
                                type="text"
                                id="loginEmail"
                                name="email"
                                placeholder="Nhập email hoặc số điện thoại"
                                class="input-teal w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800 placeholder-gray-400 outline-none transition-all"
                                aria-label="Email hoặc số điện thoại"
                            />
                        </div>
                    </div>

                    <div>
                        <label
                            for="loginPassword"
                            class="block text-sm font-medium text-gray-700 mb-1.5"
                        >
                            Mật khẩu
                        </label>

                        <div class="relative">
                            <span
                                class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"
                            >
                                <i class="fa-solid fa-lock"></i>
                            </span>

                            <input
                                type="password"
                                id="loginPassword"
                                name="password"
                                placeholder="Nhập mật khẩu"
                                class="input-teal w-full pl-10 pr-11 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800 placeholder-gray-400 outline-none transition-all"
                                aria-label="Mật khẩu"
                            />

                            <button
                                type="button"
                                class="toggle-pw"
                                onclick="togglePassword('loginPassword', this)"
                                aria-label="Hiển thị mật khẩu"
                            >
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="flex items-center justify-between pt-1">
                        <label
                            class="flex items-center gap-2 cursor-pointer select-none"
                        >
                            <input
                                type="checkbox"
                                id="rememberMe"
                                name="remember"
                                class="custom-checkbox"
                            />

                            <span class="text-sm text-gray-600">
                                Ghi nhớ đăng nhập
                            </span>
                        </label>

                        <a
                            href="/forgot-password"
                            class="link-teal text-sm font-medium"
                        >
                            Quên mật khẩu?
                        </a>
                    </div>

                    <div class="pt-2">
                        <button
                            type="submit"
                            id="loginBtn"
                            class="w-full py-3 rounded-xl text-white font-semibold text-sm flex items-center justify-center gap-2 transition-all active:scale-[0.98]"
                            style="
                                background: var(--teal-500);
                                box-shadow: 0 4px 14px rgba(0, 122, 122, 0.25);
                            "
                            onmouseover="
                                if (!this.classList.contains('btn-loading')) {
                                    this.style.background = 'var(--teal-600)';
                                    this.style.boxShadow =
                                        '0 6px 20px rgba(0,122,122,0.3)';
                                }
                            "
                            onmouseout="
                                if (!this.classList.contains('btn-loading')) {
                                    this.style.background = 'var(--teal-500)';
                                    this.style.boxShadow =
                                        '0 4px 14px rgba(0,122,122,0.25)';
                                }
                            "
                        >
                            <i
                                class="fa-solid fa-right-to-bracket text-sm"
                                id="loginBtnIcon"
                            ></i>
                            <span id="loginBtnText">Đăng nhập</span>
                        </button>
                    </div>
                </form>

                <div class="flex items-center gap-3 my-5">
                    <div class="divider-line"></div>
                    <span class="text-xs text-gray-400 font-medium whitespace-nowrap">
                        hoặc đăng nhập bằng
                    </span>
                    <div class="divider-line"></div>
                </div>

                <button
                    type="button"
                    id="googleLoginBtn"
                    class="btn-google w-full py-3 rounded-xl font-medium text-sm flex items-center justify-center gap-2.5 text-gray-700"
                >
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path
                            d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"
                            fill="#4285F4"
                        />
                        <path
                            d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                            fill="#34A853"
                        />
                        <path
                            d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                            fill="#FBBC05"
                        />
                        <path
                            d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                            fill="#EA4335"
                        />
                    </svg>

                    Đăng nhập bằng Google
                </button>

                <div class="mt-5 pt-5 border-t border-gray-100 text-center">
                    <p class="text-sm text-gray-500">
                        Chưa có tài khoản?
                        <a
                            href="/register"
                            class="link-teal font-semibold hover:underline"
                        >
                            Đăng ký ngay
                        </a>
                    </p>
                </div>
            </div>
        </section>
    </div>
</main>

<script>
    
    // =============================================
    // DOM ELEMENTS
    // =============================================
    const loginForm = document.getElementById("loginForm");
    const loginEmailInput = document.getElementById("loginEmail");
    const loginPasswordInput = document.getElementById("loginPassword");
    const emailError = document.getElementById("emailError");
    const passwordError = document.getElementById("passwordError");
    const rememberMeCheckbox = document.getElementById("rememberMe");
    const togglePasswordBtn = document.getElementById("togglePassword");
    const loginBtn = document.getElementById("loginBtn");
    const loginBtnText = document.getElementById("loginBtnText");
    const loginSpinner = document.getElementById("loginSpinner");
    const googleLoginBtn = document.getElementById("googleLoginBtn");
    const forgotPasswordLink = document.getElementById("forgotPasswordLink");

    // =============================================
    // GHI NHÓ ĐĂNG NHẬP - localStorage
    // =============================================
    const REMEMBER_KEY = "kigen_remember_email";

    // Tự điền email/phone khi load trang nếu có lưu
    (function loadRememberedEmail() {
        const saved = localStorage.getItem(REMEMBER_KEY);
        if (saved) {
            loginEmailInput.value = saved;
            rememberMeCheckbox.checked = true;
        }
    })();

    // =============================================
    // HIỆN / ẨN MẬT KHẨU
    // =============================================
    togglePasswordBtn.addEventListener("click", function () {
        const icon = this.querySelector("i");
        if (loginPasswordInput.type === "password") {
            loginPasswordInput.type = "text";
            icon.classList.remove("fa-eye");
            icon.classList.add("fa-eye-slash");
        } else {
            loginPasswordInput.type = "password";
            icon.classList.remove("fa-eye-slash");
            icon.classList.add("fa-eye");
        }
    });

    // =============================================
    // VALIDATE HELPER
    // =============================================
    function showError(errorEl, message) {
        errorEl.querySelector("span").textContent = message;
        errorEl.classList.add("show");
        // Thêm class error cho input liền trước
        const inputWrapper = errorEl.previousElementSibling;
        if (inputWrapper) {
            const input = inputWrapper.querySelector("input");
            if (input) input.classList.add("input-error");
        }
    }

    function clearError(errorEl) {
        errorEl.classList.remove("show");
        const inputWrapper = errorEl.previousElementSibling;
        if (inputWrapper) {
            const input = inputWrapper.querySelector("input");
            if (input) input.classList.remove("input-error");
        }
    }

    function clearAllErrors() {
        clearError(emailError);
        clearError(passwordError);
    }

    // Xóa lỗi khi người dùng gõ lại
    loginEmailInput.addEventListener("input", function () {
        clearError(emailError);
    });
    loginPasswordInput.addEventListener("input", function () {
        clearError(passwordError);
    });

    /**
     * Validate email hoặc số điện thoại
     * - Không được để trống
     * - Nếu có @ thì kiểm tra định dạng email cơ bản
     * - Nếu là số điện thoại thì kiểm tra độ dài cơ bản (9-11 số)
     */
    function validateEmailOrPhone(value) {
        if (!value || value.trim() === "") {
            return "Vui long nhap email hoac so dien thoai.";
        }
        const trimmed = value.trim();
        // Nếu chứa ký tự @ → kiểm tra email
        if (trimmed.includes("@")) {
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(trimmed)) {
                return "Dinh dang email khong hop le.";
            }
        } else {
            // Không có @ → kiểm tra số điện thoại
            const phoneRegex = /^[0-9]+$/;
            if (!phoneRegex.test(trimmed)) {
                return "So dien thoai chi duoc chua chu so.";
            }
            if (trimmed.length < 9 || trimmed.length > 11) {
                return "So dien thoai phai tu 9 den 11 chu so.";
            }
        }
        return "";
    }

    /**
     * Validate mật khẩu
     * - Không được để trống
     * - Tối thiểu 6 ký tự
     */
    function validatePassword(value) {
        if (!value || value === "") {
            return "Vui long nhap mat khau.";
        }
        if (value.length < 6) {
            return "Mat khau phai co it nhat 6 ky tu.";
        }
        return "";
    }

    // =============================================
    // TÌM USER THEO EMAIL HOẶC PHONE
    // =============================================
    function findUserByEmailOrPhone(input) {
        const trimmed = input.trim().toLowerCase();
        return users.find(function (u) {
            return u.email.toLowerCase() === trimmed || u.phone === trimmed;
        });
    }

    // =============================================
    // LẤY ROLE TỪ ROLE_ID
    // =============================================
    function getRoleById(roleId) {
        return roles.find(function (r) {
            return r.id === roleId;
        });
    }

    // =============================================
    // XỬ LÝ ĐĂNG NHẬP
    // =============================================
    loginForm.addEventListener("submit", function (e) {
        e.preventDefault();
        clearAllErrors();

        const emailOrPhone = loginEmailInput.value.trim();
        const password = loginPasswordInput.value;

        // Validate
        const emailErr = validateEmailOrPhone(emailOrPhone);
        if (emailErr) {
            showError(emailError, emailErr);
            loginEmailInput.focus();
            return;
        }

        const pwErr = validatePassword(password);
        if (pwErr) {
            showError(passwordError, pwErr);
            loginPasswordInput.focus();
            return;
        }

        // Hiển thị trạng thái loading
        setLoading(true);

        // Mô phỏng độ trễ mạng
        setTimeout(function () {
            // Tìm user
            const user = findUserByEmailOrPhone(emailOrPhone);

            if (!user) {
                setLoading(false);
                Swal.fire({
                    icon: "warning",
                    title: "Thong tin khong chinh xac",
                    text: "Email hoac so dien thoai khong ton tai trong he thong.",
                    confirmButtonColor: "#007a7a",
                    confirmButtonText: "Thu lai",
                    customClass: { popup: "rounded-2xl" },
                });
                return;
            }

            // Kiểm tra trạng thái tài khoản
            if (user.status !== "active") {
                setLoading(false);
                Swal.fire({
                    icon: "error",
                    title: "Tai khoan bi khoa",
                    text: "Tai khoan cua ban dang bi khoa hoac chua kich hoat. Vui long lien he ho tro.",
                    confirmButtonColor: "#007a7a",
                    confirmButtonText: "Hieu ro",
                    customClass: { popup: "rounded-2xl" },
                });
                return;
            }

            // Kiểm tra mật khẩu
            if (user.password !== password) {
                setLoading(false);
                Swal.fire({
                    icon: "warning",
                    title: "Sai mat khau",
                    text: "Mat khau ban vua nhap khong chinh xac. Vui long thu lai.",
                    confirmButtonColor: "#007a7a",
                    confirmButtonText: "Thu lai",
                    customClass: { popup: "rounded-2xl" },
                });
                return;
            }

            // Ghi nhớ đăng nhập
            if (rememberMeCheckbox.checked) {
                localStorage.setItem(REMEMBER_KEY, emailOrPhone);
            } else {
                localStorage.removeItem(REMEMBER_KEY);
            }

            // Lấy vai trò và phân quyền
            const role = getRoleById(user.role_id);
            const roleName = role ? role.name : "customer";

            setLoading(false);

            if (roleName === "admin") {
                Swal.fire({
                    icon: "success",
                    title: "Dang nhap admin thanh cong",
                    text:
                        "Xin chao " +
                        user.name +
                        "! Dang chuyen den trang quan tri...",
                    confirmButtonColor: "#007a7a",
                    confirmButtonText: "Tiep tuc",
                    showConfirmButton: false,
                    timer: 2000,
                    timerProgressBar: true,
                    customClass: { popup: "rounded-2xl" },
                }).then(function () {
                    window.location.href = "/admin/dashboard";
                });
            } else {
                Swal.fire({
                    icon: "success",
                    title: "Dang nhap thanh cong",
                    text:
                        "Xin chao " +
                        user.name +
                        "! Dang chuyen ve trang chu...",
                    confirmButtonColor: "#007a7a",
                    confirmButtonText: "Tiep tuc",
                    showConfirmButton: false,
                    timer: 2000,
                    timerProgressBar: true,
                    customClass: { popup: "rounded-2xl" },
                }).then(function () {
                    window.location.href = "/";
                });
            }
        }, 1200);
    });

    // =============================================
    // LOADING STATE
    // =============================================
    function setLoading(loading) {
        if (loading) {
            loginBtn.disabled = true;
            loginBtnText.textContent = "Dang dang nhap...";
            loginSpinner.classList.remove("hidden");
        } else {
            loginBtn.disabled = false;
            loginBtnText.textContent = "Dang nhap";
            loginSpinner.classList.add("hidden");
        }
    }

    // =============================================
    // QUÊN MẬT KHẨU
    // =============================================
    forgotPasswordLink.addEventListener("click", function (e) {
        e.preventDefault();
        Swal.fire({
            icon: "info",
            title: "Quen mat khau?",
            text: "Ban se duoc chuyen den trang khoi phuc mat khau.",
            confirmButtonColor: "#007a7a",
            confirmButtonText: "Tiep tuc",
            showCancelButton: true,
            cancelButtonText: "Huy bo",
            cancelButtonColor: "#6b7280",
            customClass: { popup: "rounded-2xl" },
        }).then(function (result) {
            if (result.isConfirmed) {
                window.location.href = "/forgot-password";
            }
        });
    });

    // =============================================
    // ĐĂNG NHẬP GOOGLE
    // =============================================
    googleLoginBtn.addEventListener("click", function () {
        Swal.fire({
            icon: "info",
            title: "Dang nhap Google",
            html: '<p class="text-sm text-gray-500">Dang chuyen den trang xac thuc Google...</p>',
            showConfirmButton: false,
            allowOutsideClick: false,
            didOpen: function () {
                Swal.showLoading();
            },
            customClass: { popup: "rounded-2xl" },
        });

        // Mô phỏng chuyển đến /auth/google sau 1.5s
        setTimeout(function () {
            Swal.close();
            window.location.href = "/auth/google";
        }, 1500);
    });

    // =============================================
    // ENTER KEY TRÊN INPUT
    // =============================================
    loginPasswordInput.addEventListener("keydown", function (e) {
        if (e.key === "Enter") {
            loginForm.dispatchEvent(new Event("submit"));
        }
    });
</script>
