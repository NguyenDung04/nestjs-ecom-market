<main
    class="relative z-10 flex-1 flex items-center justify-center py-8 sm:py-12 px-4 sm:px-6"
>
    <div
        class="max-w-5xl w-full grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center"
    >
        {{> auth/benefits}}

        <section
            class="w-full max-w-[480px] mx-auto lg:mx-0 lg:ml-auto"
            aria-label="Form đăng nhập"
        >
            <div
                class="auth-login-card bg-white rounded-2xl shadow-lg shadow-gray-200/50 border border-gray-100 p-6 sm:p-8"
            >
                <div class="text-center mb-6">
                    <div
                        class="w-14 h-14 rounded-2xl mx-auto mb-4 flex items-center justify-center"
                        style="
                            background: linear-gradient(
                                135deg,
                                var(--teal-50),
                                var(--teal-100)
                            );
                            border: 1px solid rgba(0, 122, 122, 0.1);
                        "
                    >
                        <i
                            class="fa-solid fa-right-to-bracket text-xl"
                            style="color: var(--teal-600)"
                        ></i>
                    </div>

                    <h2 class="text-xl font-bold text-gray-900">
                        Đăng nhập tài khoản
                    </h2>

                    <p class="text-sm text-gray-500 mt-1.5">
                        Chào mừng bạn quay lại, vui lòng đăng nhập để tiếp tục
                        mua sắm.
                    </p>
                </div>

                {{> common/alert}}

                <form
                    id="auth-login-form"
                    method="post"
                    action="/login"
                    novalidate
                    autocomplete="off"
                    class="space-y-4"
                >
                    <div>
                        <label
                            for="auth-login-email"
                            class="block text-sm font-medium text-gray-700 mb-1.5"
                        >
                            Email
                        </label>

                        <div class="relative">
                            <span
                                class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"
                            >
                                <i class="fa-solid fa-envelope"></i>
                            </span>

                            <input
                                type="email"
                                id="auth-login-email"
                                name="email"
                                placeholder="Nhập email"
                                class="input-teal w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800 placeholder-gray-400 outline-none transition-all"
                                aria-label="Email"
                            />
                        </div>

                        <p
                            id="auth-login-email-error"
                            class="hidden mt-1.5 text-xs text-red-500"
                        ></p>
                    </div>

                    <div>
                        <label
                            for="auth-login-password"
                            class="block text-sm font-medium text-gray-700 mb-1.5"
                        >
                            Mật khẩu
                        </label>

                        <div class="relative">
                            <span
                                class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"
                            >
                                <i class="fa-solid fa-lock"></i>
                            </span>

                            <input
                                type="password"
                                id="auth-login-password"
                                name="password"
                                placeholder="Nhập mật khẩu"
                                class="input-teal w-full pl-10 pr-11 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800 placeholder-gray-400 outline-none transition-all"
                                aria-label="Mật khẩu"
                            />

                            <button
                                type="button"
                                id="auth-login-toggle-password"
                                class="absolute right-3 top-1/2 -translate-y-1/2 w-8 h-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-[var(--teal-600)] hover:bg-teal-50 transition"
                                aria-label="Hiển thị mật khẩu"
                            >
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>

                        <p
                            id="auth-login-password-error"
                            class="hidden mt-1.5 text-xs text-red-500"
                        ></p>
                    </div>

                    <div class="flex items-center justify-between pt-1">
                        <label
                            class="flex items-center gap-2 cursor-pointer select-none"
                        >
                            <input
                                type="checkbox"
                                id="auth-login-remember"
                                name="remember"
                                class="custom-checkbox"
                            />

                            <span class="text-sm text-gray-600">
                                Ghi nhớ email
                            </span>
                        </label>

                        <a
                            href="/forgot-password"
                            class="link-teal text-sm font-medium"
                        >
                            Quên mật khẩu?
                        </a>
                    </div>

                    <div class="pt-2">
                        <button
                            type="submit"
                            id="auth-login-submit"
                            class="w-full py-3 rounded-xl text-white font-semibold text-sm flex items-center justify-center gap-2 transition-all active:scale-[0.98] hover:shadow-lg disabled:opacity-70 disabled:cursor-not-allowed"
                            style="
                                background: var(--teal-500);
                                box-shadow: 0 4px 14px rgba(0, 122, 122, 0.25);
                            "
                        >
                            <i
                                class="fa-solid fa-right-to-bracket text-sm"
                                id="auth-login-submit-icon"
                            ></i>
                            <span id="auth-login-submit-text">Đăng nhập</span>
                        </button>
                    </div>
                </form>

                <div class="flex items-center gap-3 my-5">
                    <div class="divider-line"></div>
                    <span
                        class="text-xs text-gray-400 font-medium whitespace-nowrap"
                    >
                        hoặc đăng nhập bằng
                    </span>
                    <div class="divider-line"></div>
                </div>

                <button
                    type="button"
                    id="auth-login-google"
                    class="btn-google w-full py-3 rounded-xl font-medium text-sm flex items-center justify-center gap-2.5 text-gray-700"
                >
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path
                            d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"
                            fill="#4285F4"
                        />
                        <path
                            d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                            fill="#34A853"
                        />
                        <path
                            d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                            fill="#FBBC05"
                        />
                        <path
                            d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                            fill="#EA4335"
                        />
                    </svg>

                    Đăng nhập bằng Google
                </button>

                <div class="mt-5 pt-5 border-t border-gray-100 text-center">
                    <p class="text-sm text-gray-500">
                        Chưa có tài khoản?
                        <a
                            href="/register"
                            class="link-teal font-semibold hover:underline"
                        >
                            Đăng ký ngay
                        </a>
                    </p>
                </div>
            </div>
        </section>
    </div>
</main>

<script>
    (function AuthLoginPage() {
        var selectors = {
            form: "auth-login-form",
            email: "auth-login-email",
            password: "auth-login-password",
            remember: "auth-login-remember",
            togglePassword: "auth-login-toggle-password",
            submit: "auth-login-submit",
            submitIcon: "auth-login-submit-icon",
            submitText: "auth-login-submit-text",
            google: "auth-login-google",
            emailError: "auth-login-email-error",
            passwordError: "auth-login-password-error",
        };

        var config = {
            apiUrl: "/api/auth/login",
            rememberEmailKey: "ecom_market_remember_email",
            redirects: {
                admin: "/admin",
                staff: "/admin/orders",
                member: "/",
                default: "/",
            },
            redirectLabels: {
                admin: "trang quản trị",
                staff: "trang quản lý đơn hàng",
                member: "trang chủ",
                default: "trang chủ",
            },
        };

        var state = {
            isSubmitting: false,
        };

        var elements = {};

        function init() {
            mapElements();

            if (!elements.form || !elements.email || !elements.password) {
                return;
            }

            loadRememberedEmail();
            bindEvents();
        }

        function mapElements() {
            Object.keys(selectors).forEach(function (key) {
                elements[key] = document.getElementById(selectors[key]);
            });
        }

        function bindEvents() {
            elements.form.addEventListener("submit", handleSubmit);

            if (elements.togglePassword) {
                elements.togglePassword.addEventListener(
                    "click",
                    togglePassword,
                );
            }

            if (elements.google) {
                elements.google.addEventListener("click", handleGoogleLogin);
            }

            elements.email.addEventListener("input", function () {
                clearFieldError(elements.email, elements.emailError);
            });

            elements.password.addEventListener("input", function () {
                clearFieldError(elements.password, elements.passwordError);
            });
        }

        function notify(type, title, message, duration, callback) {
            if (typeof window.showAlert24 === "function") {
                window.showAlert24(
                    type,
                    title,
                    message,
                    duration || 3500,
                    callback,
                );
                return;
            }

            alert((title ? title + "\n" : "") + (message || ""));

            if (typeof callback === "function") {
                callback();
            }
        }

        function setFieldError(input, errorElement, message) {
            if (!input || !errorElement) return;

            errorElement.textContent = message || "";
            errorElement.classList.toggle("hidden", !message);
            input.classList.toggle("input-error", !!message);
        }

        function clearFieldError(input, errorElement) {
            setFieldError(input, errorElement, "");
        }

        function clearAllErrors() {
            clearFieldError(elements.email, elements.emailError);
            clearFieldError(elements.password, elements.passwordError);
        }

        function validateForm() {
            clearAllErrors();

            var email = elements.email.value.trim();
            var password = elements.password.value;

            if (!email) {
                setFieldError(
                    elements.email,
                    elements.emailError,
                    "Vui lòng nhập email.",
                );

                notify(
                    "warning",
                    "Thiếu email",
                    "Vui lòng nhập email để đăng nhập.",
                    3500,
                );

                elements.email.focus();
                return false;
            }

            if (!isValidEmail(email)) {
                setFieldError(
                    elements.email,
                    elements.emailError,
                    "Email không đúng định dạng.",
                );

                notify(
                    "warning",
                    "Email không hợp lệ",
                    "Vui lòng nhập email đúng định dạng. Ví dụ: user@example.com.",
                    3500,
                );

                elements.email.focus();
                return false;
            }

            if (!password) {
                setFieldError(
                    elements.password,
                    elements.passwordError,
                    "Vui lòng nhập mật khẩu.",
                );

                notify(
                    "warning",
                    "Thiếu mật khẩu",
                    "Vui lòng nhập mật khẩu để đăng nhập.",
                    3500,
                );

                elements.password.focus();
                return false;
            }

            if (password.length < 6) {
                setFieldError(
                    elements.password,
                    elements.passwordError,
                    "Mật khẩu phải có ít nhất 6 ký tự.",
                );

                notify(
                    "warning",
                    "Mật khẩu chưa hợp lệ",
                    "Mật khẩu phải có ít nhất 6 ký tự.",
                    3500,
                );

                elements.password.focus();
                return false;
            }

            return true;
        }

        function isValidEmail(email) {
            return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
        }

        function setLoading(isLoading) {
            if (!elements.submit) return;

            elements.submit.disabled = isLoading;

            if (elements.submitIcon) {
                elements.submitIcon.className = isLoading
                    ? "fa-solid fa-spinner fa-spin text-sm"
                    : "fa-solid fa-right-to-bracket text-sm";
            }

            if (elements.submitText) {
                elements.submitText.textContent = isLoading
                    ? "Đang đăng nhập..."
                    : "Đăng nhập";
            }
        }

        async function handleSubmit(event) {
            event.preventDefault();

            if (state.isSubmitting) return;

            if (!validateForm()) {
                return;
            }

            state.isSubmitting = true;
            setLoading(true);

            try {
                var result = await login();

                var user = getUserFromResponse(result);

                if (!user) {
                    throw new Error(
                        "Không lấy được thông tin tài khoản sau khi đăng nhập.",
                    );
                }

                var roleName = normalizeRoleName(user.role && user.role.name);
                var redirectUrl = getRedirectUrl(roleName);
                var redirectLabel = getRedirectLabel(roleName);

                saveRememberedEmail();

                notify(
                    "success",
                    "Đăng nhập thành công",
                    user.name
                        ? "Xin chào " +
                              user.name +
                              ". Xác thực tài khoản thành công."
                        : "Xác thực tài khoản thành công.",
                    1600,
                );

                window.setTimeout(function () {
                    notify(
                        "info",
                        "Đang chuyển hướng",
                        "Bạn sẽ được chuyển đến " + redirectLabel + ".",
                        1200,
                    );
                }, 500);

                window.setTimeout(function () {
                    window.location.href = redirectUrl;
                }, 1500);
            } catch (error) {
                state.isSubmitting = false;
                setLoading(false);

                notify(
                    "error",
                    "Đăng nhập thất bại",
                    error.message || "Vui lòng kiểm tra lại email và mật khẩu.",
                    4000,
                );
            }
        }

        async function login() {
            var response = await fetch(config.apiUrl, {
                method: "POST",
                credentials: "include",
                headers: {
                    "Content-Type": "application/json",
                },
                body: JSON.stringify({
                    email: elements.email.value.trim(),
                    password: elements.password.value,
                }),
            });

            var result = await readJsonResponse(response);

            if (!response.ok || !result || result.success === false) {
                throw new Error(
                    (result && result.message) ||
                        "Email hoặc mật khẩu không đúng.",
                );
            }

            return result;
        }

        async function readJsonResponse(response) {
            try {
                return await response.json();
            } catch (error) {
                return null;
            }
        }

        function getUserFromResponse(result) {
            if (!result) return null;

            if (result.data && result.data.user) {
                return result.data.user;
            }

            return null;
        }

        function normalizeRoleName(roleName) {
            return String(roleName || "")
                .trim()
                .toLowerCase();
        }

        function getRedirectUrl(roleName) {
            var normalizedRole = normalizeRoleName(roleName);

            return config.redirects[normalizedRole] || config.redirects.default;
        }

        function getRedirectLabel(roleName) {
            var normalizedRole = normalizeRoleName(roleName);

            return (
                config.redirectLabels[normalizedRole] ||
                config.redirectLabels.default
            );
        }

        function saveRememberedEmail() {
            if (!elements.remember) return;

            var email = elements.email.value.trim();

            if (elements.remember.checked) {
                localStorage.setItem(config.rememberEmailKey, email);
                return;
            }

            localStorage.removeItem(config.rememberEmailKey);
        }

        function loadRememberedEmail() {
            if (!elements.remember) return;

            var savedEmail = localStorage.getItem(config.rememberEmailKey);

            if (!savedEmail) return;

            elements.email.value = savedEmail;
            elements.remember.checked = true;
        }

        function togglePassword() {
            var icon = elements.togglePassword.querySelector("i");
            var isHidden = elements.password.type === "password";

            elements.password.type = isHidden ? "text" : "password";

            if (icon) {
                icon.className = isHidden
                    ? "fa-solid fa-eye-slash"
                    : "fa-solid fa-eye";
            }

            elements.togglePassword.setAttribute(
                "aria-label",
                isHidden ? "Ẩn mật khẩu" : "Hiển thị mật khẩu",
            );
        }

        function handleGoogleLogin() {
            notify(
                "info",
                "Chưa hỗ trợ Google",
                "Đăng nhập Google sẽ được triển khai ở phase sau.",
                3500,
            );
        }

        init();
    })();
</script>
