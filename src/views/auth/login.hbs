<div class="relative overflow-hidden rounded-[32px] border border-white/70 bg-white/95 p-8 shadow-[0_30px_80px_rgba(15,23,42,0.08)] backdrop-blur sm:p-9">
  <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-primary-500 via-sky-500 to-emerald-500"></div>

  <div class="mb-8">
    <div class="mb-5 inline-flex h-16 w-16 items-center justify-center rounded-[24px] bg-gradient-to-br from-primary-500 to-sky-500 text-white shadow-lg shadow-primary-500/20">
      <i class="fa-solid fa-right-to-bracket text-2xl"></i>
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <span class="rounded-full bg-primary-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-primary-700">
        Secure Login
      </span>
      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
        Admin & User Access
      </span>
    </div>

    <h1 class="mt-4 text-3xl font-black tracking-tight text-slate-900">
      Đăng nhập
    </h1>

    <p class="mt-3 text-sm leading-7 text-slate-500">
      Truy cập hệ thống nhanh hơn với biểu mẫu gọn gàng, rõ trạng thái và sẵn sàng xử lý lỗi khi xác thực.
    </p>
  </div>

  <form id="loginForm" class="space-y-5">
    <div>
      <div class="mb-2 flex items-center justify-between gap-3">
        <label class="block text-sm font-semibold text-slate-700">
          Email
        </label>
        <span class="text-xs font-medium text-slate-400">Bắt buộc</span>
      </div>

      <div class="relative">
        <i class="fa-regular fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-sm text-slate-400"></i>

        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          class="block w-full rounded-2xl border border-slate-300 bg-slate-50 py-3.5 pl-11 pr-4 text-sm text-slate-700 outline-none transition focus:border-primary-500 focus:bg-white focus:ring-4 focus:ring-primary-100"
          placeholder="admin1@example.com"
        />
      </div>
    </div>

    <div>
      <div class="mb-2 flex items-center justify-between gap-3">
        <label class="block text-sm font-semibold text-slate-700">
          Mật khẩu
        </label>
        <a href="/auth/forgot-password" class="text-xs font-semibold text-primary-600 transition hover:text-primary-700">
          Quên mật khẩu?
        </a>
      </div>

      <div class="relative">
        <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-sm text-slate-400"></i>

        <input
          id="password"
          name="password"
          type="password"
          required
          autocomplete="current-password"
          class="block w-full rounded-2xl border border-slate-300 bg-slate-50 py-3.5 pl-11 pr-12 text-sm text-slate-700 outline-none transition focus:border-primary-500 focus:bg-white focus:ring-4 focus:ring-primary-100"
          placeholder="Nhập mật khẩu của bạn"
        />

        <button
          type="button"
          onclick="togglePassword('password', 'passwordEye')"
          class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 transition hover:text-slate-700"
        >
          <i id="passwordEye" class="fa-regular fa-eye"></i>
        </button>
      </div>
    </div>

    <div class="flex items-center justify-between rounded-2xl border border-slate-200 bg-slate-50/80 px-4 py-3 text-sm">
      <div class="flex items-center gap-2 text-slate-600">
        <i class="fa-solid fa-shield-halved text-primary-600"></i>
        Phiên đăng nhập được bảo vệ qua API xác thực
      </div>
      <span class="font-semibold text-emerald-600">An toàn</span>
    </div>

    <button
      id="loginButton"
      type="submit"
      class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-primary-600 px-5 py-3.5 text-sm font-bold text-white shadow-lg shadow-primary-600/20 transition hover:-translate-y-0.5 hover:bg-primary-700 disabled:cursor-not-allowed disabled:opacity-70"
    >
      <i class="fa-solid fa-right-to-bracket"></i>
      Đăng nhập
    </button>
  </form>

  <div class="mt-6 grid gap-3 sm:grid-cols-2">
    <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
        Tip
      </p>
      <p class="mt-2 text-sm leading-6 text-slate-600">
        Nếu bạn là admin, sau khi đăng nhập thành công hệ thống sẽ chuyển tới khu vực quản trị.
      </p>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
        New Here
      </p>
      <p class="mt-2 text-sm leading-6 text-slate-600">
        Chưa có tài khoản?
        <a href="/auth/register" class="font-semibold text-primary-600 hover:text-primary-700">
          Tạo tài khoản mới
        </a>
      </p>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const loginForm = document.getElementById('loginForm');
    const loginButton = document.getElementById('loginButton');

    if (!loginForm) {
      console.error('Khong tim thay form loginForm');
      return;
    }

    loginForm.addEventListener('submit', async function (event) {
      event.preventDefault();

      const email = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;

      loginButton.disabled = true;
      loginButton.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang đăng nhập...';

      try {
        const response = await fetch('/api/auth/login', {
          method: 'POST',
          credentials: 'include',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            email,
            password,
          }),
        });

        const result = await response.json();

        console.log('LOGIN_RESPONSE:', result);

        if (!response.ok || result.success === false) {
          const errorMessage = result.message || 'Đăng nhập thất bại';

          if (typeof showToast === 'function') {
            showToast(errorMessage, 'error');
          } else {
            alert(errorMessage);
          }

          return;
        }

        const user = result.data?.user;

        if (!user) {
          if (typeof showToast === 'function') {
            showToast('Không lấy được thông tin người dùng', 'error');
          } else {
            alert('Không lấy được thông tin người dùng');
          }

          return;
        }

        if (typeof showToast === 'function') {
          showToast('Đăng nhập thành công', 'success');
        } else {
          alert('Đăng nhập thành công');
        }

        setTimeout(function () {
          if (user.role === 'admin') {
            window.location.href = '/admin';
          } else {
            window.location.href = '/';
          }
        }, 700);
      } catch (error) {
        console.error(error);

        if (typeof showToast === 'function') {
          showToast('Không thể kết nối tới máy chủ', 'error');
        } else {
          alert('Không thể kết nối tới máy chủ');
        }
      } finally {
        loginButton.disabled = false;
        loginButton.innerHTML = '<i class="fa-solid fa-right-to-bracket"></i> Đăng nhập';
      }
    });
  });

  function togglePassword(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon = document.getElementById(iconId);

    if (input.type === 'password') {
      input.type = 'text';
      icon.classList.remove('fa-eye');
      icon.classList.add('fa-eye-slash');
    } else {
      input.type = 'password';
      icon.classList.remove('fa-eye-slash');
      icon.classList.add('fa-eye');
    }
  }
</script>
