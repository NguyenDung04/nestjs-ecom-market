<div class="w-full max-w-md rounded-3xl bg-white p-8 shadow-sm">
  <h1 class="text-2xl font-bold text-slate-900">Đăng ký</h1>
  <p class="mt-1 text-sm text-slate-500">Tạo tài khoản khách hàng mới.</p>

  {{> common/alert}}

  <form method="POST" action="/auth/register" class="mt-6 space-y-4">
    <div>
      <label class="mb-1 block text-sm font-medium">Họ tên</label>
      <input
        name="name"
        class="w-full rounded-xl border px-4 py-3"
        placeholder="Nguyễn Văn A"
      />
    </div>

    <div>
      <label class="mb-1 block text-sm font-medium">Email</label>
      <input
        name="email"
        type="email"
        class="w-full rounded-xl border px-4 py-3"
        placeholder="email@example.com"
      />
    </div>

    <div>
      <label class="mb-1 block text-sm font-medium">Số điện thoại</label>
      <input
        name="phone"
        class="w-full rounded-xl border px-4 py-3"
        placeholder="0900000000"
      />
    </div>

    <div>
      <label class="mb-1 block text-sm font-medium">Mật khẩu</label>
      <input
        name="password"
        type="password"
        class="w-full rounded-xl border px-4 py-3"
        placeholder="••••••••"
      />
    </div>

    <button
      type="submit"
      class="w-full rounded-xl px-4 py-3 font-semibold text-white"
      style="background: var(--teal-600);"
    >
      Tạo tài khoản
    </button>
  </form>

  <div class="mt-5 text-center text-sm">
    Đã có tài khoản?
    <a href="/auth/login" class="font-semibold" style="color: var(--teal-600);">
      Đăng nhập
    </a>
  </div>
</div>