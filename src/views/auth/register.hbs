<!-- Main register -->
<main
    class="relative z-10 flex-1 flex items-center justify-center py-8 sm:py-12 px-4 sm:px-6"
>
    <div
        class="max-w-5xl w-full grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center"
    >
        {{> auth/benefits}}

        <section
            class="w-full max-w-[480px] mx-auto lg:mx-0 lg:ml-auto"
            aria-label="Form đăng ký"
        >
            <div
                class="form-card bg-white rounded-2xl shadow-lg shadow-gray-200/50 border border-gray-100 p-6 sm:p-8"
            >
                <div class="text-center mb-6">
                    <div
                        class="w-14 h-14 rounded-2xl mx-auto mb-4 flex items-center justify-center"
                        style="
                            background: linear-gradient(
                                135deg,
                                var(--teal-50),
                                var(--teal-100)
                            );
                            border: 1px solid rgba(0, 122, 122, 0.1);
                        "
                    >
                        <i
                            class="fa-solid fa-user-plus text-xl"
                            style="color: var(--teal-600)"
                        ></i>
                    </div>

                    <h2 class="text-xl font-bold text-gray-900">
                        Tạo tài khoản mới
                    </h2>

                    <p class="text-sm text-gray-500 mt-1.5">
                        Đăng ký để theo dõi đơn hàng, lưu địa chỉ và nhận ưu
                        đãi.
                    </p>
                </div>

                {{> common/alert}}

                <form
                    id="auth-register-form"
                    method="post"
                    action="/register"
                    novalidate
                    autocomplete="off"
                    class="space-y-4"
                >
                    <div>
                        <label
                            for="auth-register-name"
                            class="block text-sm font-medium text-gray-700 mb-1.5"
                        >
                            Họ tên
                        </label>

                        <div class="relative">
                            <span
                                class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"
                            >
                                <i class="fa-solid fa-user"></i>
                            </span>

                            <input
                                type="text"
                                id="auth-register-name"
                                name="name"
                                placeholder="Nhập họ tên của bạn"
                                class="input-teal w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800 placeholder-gray-400 outline-none transition-all"
                                aria-label="Họ tên"
                            />
                        </div>

                        <p
                            id="auth-register-name-error"
                            class="hidden mt-1.5 text-xs text-red-500"
                        ></p>
                    </div>

                    <div>
                        <label
                            for="auth-register-email"
                            class="block text-sm font-medium text-gray-700 mb-1.5"
                        >
                            Email
                        </label>

                        <div class="relative">
                            <span
                                class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"
                            >
                                <i class="fa-solid fa-envelope"></i>
                            </span>

                            <input
                                type="email"
                                id="auth-register-email"
                                name="email"
                                placeholder="Nhập email của bạn"
                                class="input-teal w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800 placeholder-gray-400 outline-none transition-all"
                                aria-label="Email"
                            />
                        </div>

                        <p
                            id="auth-register-email-error"
                            class="hidden mt-1.5 text-xs text-red-500"
                        ></p>
                    </div>

                    <div>
                        <label
                            for="auth-register-phone"
                            class="block text-sm font-medium text-gray-700 mb-1.5"
                        >
                            Số điện thoại
                        </label>

                        <div class="relative">
                            <span
                                class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"
                            >
                                <i class="fa-solid fa-phone"></i>
                            </span>

                            <input
                                type="tel"
                                id="auth-register-phone"
                                name="phone"
                                placeholder="Nhập số điện thoại"
                                class="input-teal w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800 placeholder-gray-400 outline-none transition-all"
                                aria-label="Số điện thoại"
                            />
                        </div>

                        <p
                            id="auth-register-phone-error"
                            class="hidden mt-1.5 text-xs text-red-500"
                        ></p>
                    </div>

                    <div>
                        <label
                            for="auth-register-password"
                            class="block text-sm font-medium text-gray-700 mb-1.5"
                        >
                            Mật khẩu
                        </label>

                        <div class="relative">
                            <span
                                class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"
                            >
                                <i class="fa-solid fa-lock"></i>
                            </span>

                            <input
                                type="password"
                                id="auth-register-password"
                                name="password"
                                placeholder="Nhập mật khẩu"
                                class="input-teal w-full pl-10 pr-11 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800 placeholder-gray-400 outline-none transition-all"
                                aria-label="Mật khẩu"
                            />

                            <button
                                type="button"
                                id="auth-register-toggle-password"
                                class="absolute right-3 top-1/2 -translate-y-1/2 w-8 h-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-[var(--teal-600)] hover:bg-teal-50 transition"
                                aria-label="Hiển thị mật khẩu"
                            >
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>

                        <div class="mt-2">
                            <div class="strength-bar">
                                <div
                                    id="auth-register-strength-fill"
                                    class="strength-fill"
                                    style="width: 0%; background: #e5e7eb"
                                ></div>
                            </div>

                            <p
                                id="auth-register-strength-text"
                                class="text-xs mt-1 text-gray-400"
                            >
                                Nhập mật khẩu để kiểm tra độ mạnh
                            </p>
                        </div>

                        <p
                            id="auth-register-password-error"
                            class="hidden mt-1.5 text-xs text-red-500"
                        ></p>
                    </div>

                    <div>
                        <label
                            for="auth-register-confirm-password"
                            class="block text-sm font-medium text-gray-700 mb-1.5"
                        >
                            Xác nhận mật khẩu
                        </label>

                        <div class="relative">
                            <span
                                class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"
                            >
                                <i class="fa-solid fa-lock"></i>
                            </span>

                            <input
                                type="password"
                                id="auth-register-confirm-password"
                                name="confirmPassword"
                                placeholder="Nhập lại mật khẩu"
                                class="input-teal w-full pl-10 pr-11 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800 placeholder-gray-400 outline-none transition-all"
                                aria-label="Xác nhận mật khẩu"
                            />

                            <button
                                type="button"
                                id="auth-register-toggle-confirm-password"
                                class="absolute right-3 top-1/2 -translate-y-1/2 w-8 h-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-[var(--teal-600)] hover:bg-teal-50 transition"
                                aria-label="Hiển thị xác nhận mật khẩu"
                            >
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>

                        <p
                            id="auth-register-confirm-password-error"
                            class="hidden mt-1.5 text-xs text-red-500"
                        ></p>
                    </div>

                    <div class="pt-1">
                        <label
                            class="flex items-start gap-2.5 cursor-pointer select-none"
                        >
                            <input
                                type="checkbox"
                                id="auth-register-agree-terms"
                                class="custom-checkbox mt-0.5"
                            />

                            <span class="text-sm text-gray-600 leading-relaxed">
                                Tôi đồng ý với
                                <a
                                    href="#"
                                    id="auth-register-terms-link"
                                    class="link-teal font-medium"
                                >
                                    Điều khoản sử dụng
                                </a>
                                và
                                <a
                                    href="#"
                                    id="auth-register-policy-link"
                                    class="link-teal font-medium"
                                >
                                    Chính sách bảo mật
                                </a>
                            </span>
                        </label>

                        <p
                            id="auth-register-terms-error"
                            class="hidden mt-1.5 text-xs text-red-500"
                        ></p>
                    </div>

                    <div class="pt-2">
                        <button
                            type="submit"
                            id="auth-register-submit"
                            class="w-full py-3 rounded-xl text-white font-semibold text-sm flex items-center justify-center gap-2 transition-all active:scale-[0.98] hover:shadow-lg disabled:opacity-70 disabled:cursor-not-allowed"
                            style="
                                background: var(--teal-500);
                                box-shadow: 0 4px 14px rgba(0, 122, 122, 0.25);
                            "
                        >
                            <i
                                class="fa-solid fa-user-plus text-sm"
                                id="auth-register-submit-icon"
                            ></i>

                            <span id="auth-register-submit-text">Đăng ký</span>
                        </button>
                    </div>
                </form>

                <div class="mt-5 pt-5 border-t border-gray-100 text-center">
                    <p class="text-sm text-gray-500">
                        Đã có tài khoản?
                        <a
                            href="/login"
                            class="link-teal font-semibold hover:underline"
                        >
                            Đăng nhập
                        </a>
                    </p>
                </div>
            </div>
        </section>
    </div>
</main>

<script>
    (function AuthRegisterPage(window, document) {
        "use strict";

        var Auth = window.AuthCommon;

        if (!Auth) return;

        var selectors = {
            form: "auth-register-form",
            name: "auth-register-name",
            email: "auth-register-email",
            phone: "auth-register-phone",
            password: "auth-register-password",
            confirmPassword: "auth-register-confirm-password",
            agreeTerms: "auth-register-agree-terms",

            togglePassword: "auth-register-toggle-password",
            toggleConfirmPassword: "auth-register-toggle-confirm-password",

            submit: "auth-register-submit",
            submitIcon: "auth-register-submit-icon",
            submitText: "auth-register-submit-text",

            strengthFill: "auth-register-strength-fill",
            strengthText: "auth-register-strength-text",

            termsLink: "auth-register-terms-link",
            policyLink: "auth-register-policy-link",

            nameError: "auth-register-name-error",
            emailError: "auth-register-email-error",
            phoneError: "auth-register-phone-error",
            passwordError: "auth-register-password-error",
            confirmPasswordError: "auth-register-confirm-password-error",
            termsError: "auth-register-terms-error",
        };

        var config = {
            apiUrl: Auth.buildApiUrl("/auth/register"),
            redirectUrl: "/login",
            redirectDelay: 1800,
        };

        var state = {
            isSubmitting: false,
        };

        var elements = {};

        function init() {
            elements = Auth.mapElements(selectors);

            if (
                !elements.form ||
                !elements.name ||
                !elements.email ||
                !elements.phone ||
                !elements.password ||
                !elements.confirmPassword ||
                !elements.submit
            ) {
                return;
            }

            bindEvents();
            updatePasswordStrength();
        }

        function bindEvents() {
            elements.form.addEventListener("submit", handleSubmit);

            if (elements.togglePassword) {
                elements.togglePassword.addEventListener("click", function () {
                    Auth.togglePassword(
                        elements.password,
                        elements.togglePassword,
                    );
                });
            }

            if (elements.toggleConfirmPassword) {
                elements.toggleConfirmPassword.addEventListener(
                    "click",
                    function () {
                        Auth.togglePassword(
                            elements.confirmPassword,
                            elements.toggleConfirmPassword,
                        );
                    },
                );
            }

            elements.name.addEventListener("input", function () {
                if (elements.name.value.trim().length >= 2) {
                    Auth.clearFieldError(elements.name, elements.nameError);
                }
            });

            elements.email.addEventListener("input", function () {
                if (elements.email.value.trim().length > 3) {
                    Auth.clearFieldError(elements.email, elements.emailError);
                }
            });

            elements.phone.addEventListener("input", function () {
                elements.phone.value = Auth.onlyDigits(elements.phone.value);

                if (elements.phone.value.trim().length >= 10) {
                    Auth.clearFieldError(elements.phone, elements.phoneError);
                }
            });

            elements.password.addEventListener("input", function () {
                updatePasswordStrength();

                if (elements.password.value.length >= 6) {
                    Auth.clearFieldError(
                        elements.password,
                        elements.passwordError,
                    );
                }
            });

            elements.confirmPassword.addEventListener("input", function () {
                if (
                    elements.confirmPassword.value &&
                    elements.confirmPassword.value === elements.password.value
                ) {
                    Auth.setFieldValid(
                        elements.confirmPassword,
                        elements.confirmPasswordError,
                    );
                }
            });

            if (elements.agreeTerms) {
                elements.agreeTerms.addEventListener("change", function () {
                    if (elements.agreeTerms.checked) {
                        Auth.clearTextError(elements.termsError);
                    }
                });
            }

            if (elements.termsLink) {
                elements.termsLink.addEventListener("click", function (event) {
                    event.preventDefault();

                    Auth.notify(
                        "info",
                        "Điều khoản sử dụng",
                        "Trang điều khoản sử dụng đang được cập nhật.",
                        3500,
                    );
                });
            }

            if (elements.policyLink) {
                elements.policyLink.addEventListener("click", function (event) {
                    event.preventDefault();

                    Auth.notify(
                        "info",
                        "Chính sách bảo mật",
                        "Trang chính sách bảo mật đang được cập nhật.",
                        3500,
                    );
                });
            }
        }

        function clearAllErrors() {
            Auth.clearFieldError(elements.name, elements.nameError);
            Auth.clearFieldError(elements.email, elements.emailError);
            Auth.clearFieldError(elements.phone, elements.phoneError);
            Auth.clearFieldError(elements.password, elements.passwordError);
            Auth.clearFieldError(
                elements.confirmPassword,
                elements.confirmPasswordError,
            );
            Auth.clearTextError(elements.termsError);
        }

        function validateForm() {
            clearAllErrors();

            if (!validateName()) {
                elements.name.focus();
                return false;
            }

            if (!validateEmail()) {
                elements.email.focus();
                return false;
            }

            if (!validatePhone()) {
                elements.phone.focus();
                return false;
            }

            if (!validatePassword()) {
                elements.password.focus();
                return false;
            }

            if (!validateConfirmPassword()) {
                elements.confirmPassword.focus();
                return false;
            }

            if (!validateTerms()) {
                return false;
            }

            return true;
        }

        function validateName() {
            var value = elements.name.value.trim();

            if (!value) {
                Auth.setFieldError(
                    elements.name,
                    elements.nameError,
                    "Vui lòng nhập họ tên.",
                );

                Auth.notify(
                    "warning",
                    "Thiếu họ tên",
                    "Vui lòng nhập họ tên để đăng ký.",
                    3500,
                );

                return false;
            }

            if (value.length < 2) {
                Auth.setFieldError(
                    elements.name,
                    elements.nameError,
                    "Họ tên phải có ít nhất 2 ký tự.",
                );

                Auth.notify(
                    "warning",
                    "Họ tên chưa hợp lệ",
                    "Họ tên phải có ít nhất 2 ký tự.",
                    3500,
                );

                return false;
            }

            Auth.setFieldValid(elements.name, elements.nameError);
            return true;
        }

        function validateEmail() {
            var value = elements.email.value.trim();

            if (!value) {
                Auth.setFieldError(
                    elements.email,
                    elements.emailError,
                    "Vui lòng nhập email.",
                );

                Auth.notify(
                    "warning",
                    "Thiếu email",
                    "Vui lòng nhập email để đăng ký.",
                    3500,
                );

                return false;
            }

            if (!Auth.isValidEmail(value)) {
                Auth.setFieldError(
                    elements.email,
                    elements.emailError,
                    "Email không đúng định dạng.",
                );

                Auth.notify(
                    "warning",
                    "Email không hợp lệ",
                    "Vui lòng nhập email đúng định dạng. Ví dụ: user@example.com.",
                    3500,
                );

                return false;
            }

            Auth.setFieldValid(elements.email, elements.emailError);
            return true;
        }

        function validatePhone() {
            var value = elements.phone.value.trim();

            if (!value) {
                Auth.setFieldError(
                    elements.phone,
                    elements.phoneError,
                    "Vui lòng nhập số điện thoại.",
                );

                Auth.notify(
                    "warning",
                    "Thiếu số điện thoại",
                    "Vui lòng nhập số điện thoại để đăng ký.",
                    3500,
                );

                return false;
            }

            if (!Auth.isValidVietnamesePhone(value)) {
                Auth.setFieldError(
                    elements.phone,
                    elements.phoneError,
                    "Số điện thoại không đúng định dạng. Ví dụ: 0912345678.",
                );

                Auth.notify(
                    "warning",
                    "Số điện thoại không hợp lệ",
                    "Vui lòng nhập số điện thoại Việt Nam hợp lệ.",
                    3500,
                );

                return false;
            }

            Auth.setFieldValid(elements.phone, elements.phoneError);
            return true;
        }

        function validatePassword() {
            var value = elements.password.value;

            if (!value) {
                Auth.setFieldError(
                    elements.password,
                    elements.passwordError,
                    "Vui lòng nhập mật khẩu.",
                );

                Auth.notify(
                    "warning",
                    "Thiếu mật khẩu",
                    "Vui lòng nhập mật khẩu để đăng ký.",
                    3500,
                );

                return false;
            }

            if (value.length < 6) {
                Auth.setFieldError(
                    elements.password,
                    elements.passwordError,
                    "Mật khẩu phải có ít nhất 6 ký tự.",
                );

                Auth.notify(
                    "warning",
                    "Mật khẩu chưa hợp lệ",
                    "Mật khẩu phải có ít nhất 6 ký tự.",
                    3500,
                );

                return false;
            }

            Auth.setFieldValid(elements.password, elements.passwordError);
            return true;
        }

        function validateConfirmPassword() {
            var value = elements.confirmPassword.value;

            if (!value) {
                Auth.setFieldError(
                    elements.confirmPassword,
                    elements.confirmPasswordError,
                    "Vui lòng nhập lại mật khẩu.",
                );

                Auth.notify(
                    "warning",
                    "Thiếu xác nhận mật khẩu",
                    "Vui lòng nhập lại mật khẩu.",
                    3500,
                );

                return false;
            }

            if (value !== elements.password.value) {
                Auth.setFieldError(
                    elements.confirmPassword,
                    elements.confirmPasswordError,
                    "Mật khẩu xác nhận không khớp.",
                );

                Auth.notify(
                    "warning",
                    "Mật khẩu không khớp",
                    "Mật khẩu xác nhận phải trùng với mật khẩu.",
                    3500,
                );

                return false;
            }

            Auth.setFieldValid(
                elements.confirmPassword,
                elements.confirmPasswordError,
            );
            return true;
        }

        function validateTerms() {
            if (!elements.agreeTerms || elements.agreeTerms.checked) {
                Auth.clearTextError(elements.termsError);
                return true;
            }

            Auth.setTextError(
                elements.termsError,
                "Bạn cần đồng ý với Điều khoản và Chính sách bảo mật.",
            );

            Auth.notify(
                "warning",
                "Chưa đồng ý điều khoản",
                "Bạn cần đồng ý với Điều khoản và Chính sách bảo mật.",
                3500,
            );

            return false;
        }

        function updatePasswordStrength() {
            Auth.updatePasswordStrength(
                elements.password.value,
                elements.strengthFill,
                elements.strengthText,
            );
        }

        function setLoading(isLoading) {
            Auth.setButtonLoading(
                elements.submit,
                elements.submitIcon,
                elements.submitText,
                isLoading,
                {
                    defaultIcon: "fa-solid fa-user-plus text-sm",
                    loadingText: "Đang tạo tài khoản...",
                    defaultText: "Đăng ký",
                },
            );
        }

        async function handleSubmit(event) {
            event.preventDefault();

            if (state.isSubmitting) return;
            if (!validateForm()) return;

            state.isSubmitting = true;
            setLoading(true);

            try {
                var result = await register();
                var registeredUser = result && result.data ? result.data : null;

                Auth.redirectWithNotice({
                    successTitle: "Đăng ký thành công",
                    successMessage:
                        registeredUser && registeredUser.name
                            ? "Tài khoản " +
                              registeredUser.name +
                              " đã được tạo. Vui lòng đăng nhập để tiếp tục."
                            : result.message ||
                              "Tài khoản đã được tạo. Vui lòng đăng nhập để tiếp tục.",
                    infoMessage: "Bạn sẽ được chuyển đến trang đăng nhập.",
                    redirectUrl: config.redirectUrl,
                    redirectDelay: config.redirectDelay,
                });
            } catch (error) {
                state.isSubmitting = false;
                setLoading(false);
                handleRegisterError(error);
            }
        }

        function register() {
            return Auth.requestJson(
                config.apiUrl,
                {
                    method: "POST",
                    body: JSON.stringify({
                        name: elements.name.value.trim(),
                        email: elements.email.value.trim(),
                        phone: elements.phone.value.trim(),
                        password: elements.password.value,
                        confirmPassword: elements.confirmPassword.value,
                    }),
                },
                "Đăng ký tài khoản thất bại.",
            );
        }

        function handleRegisterError(error) {
            var message = error.message || "Đăng ký tài khoản thất bại.";
            var lowerMessage = message.toLowerCase();

            if (lowerMessage.includes("email")) {
                Auth.setFieldError(
                    elements.email,
                    elements.emailError,
                    message,
                );
                elements.email.focus();
            } else if (
                lowerMessage.includes("phone") ||
                lowerMessage.includes("số điện thoại")
            ) {
                Auth.setFieldError(
                    elements.phone,
                    elements.phoneError,
                    message,
                );
                elements.phone.focus();
            }

            Auth.notify("error", "Đăng ký thất bại", message, 4000);
        }

        init();
    })(window, document);
</script>
