<div class="relative overflow-hidden rounded-[32px] border border-white/70 bg-white/95 p-8 shadow-[0_30px_80px_rgba(15,23,42,0.08)] backdrop-blur sm:p-9">
  <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-amber-500 via-primary-500 to-emerald-500"></div>

  <div class="mb-8">
    <div class="mb-5 inline-flex h-16 w-16 items-center justify-center rounded-[24px] bg-gradient-to-br from-amber-500 to-primary-500 text-white shadow-lg shadow-amber-500/20">
      <i class="fa-solid fa-key text-2xl"></i>
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-amber-700">
        Password Recovery
      </span>
      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
        Secure Reset Flow
      </span>
    </div>

    <h1 class="mt-4 text-3xl font-black tracking-tight text-slate-900">
      Quên mật khẩu?
    </h1>

    <p class="mt-3 text-sm leading-7 text-slate-500">
      Nhập email tài khoản để hệ thống tạo yêu cầu đặt lại mật khẩu. Giao diện này ưu tiên rõ ràng, ít bước và dễ kiểm tra token trong môi trường development.
    </p>
  </div>

  <form id="forgotPasswordForm" class="space-y-5">
    <div>
      <label class="mb-2 block text-sm font-semibold text-slate-700">
        Email
      </label>

      <div class="relative">
        <i class="fa-regular fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-sm text-slate-400"></i>

        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          class="block w-full rounded-2xl border border-slate-300 bg-slate-50 py-3.5 pl-11 pr-4 text-sm text-slate-700 outline-none transition focus:border-primary-500 focus:bg-white focus:ring-4 focus:ring-primary-100"
          placeholder="example@email.com"
        />
      </div>
    </div>

    <div class="grid gap-3 sm:grid-cols-2">
      <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
          Step 1
        </p>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Gửi email để hệ thống kiểm tra tài khoản và tạo yêu cầu đặt lại mật khẩu.
        </p>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
          Step 2
        </p>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Nếu có token phản hồi, bạn có thể đi tiếp sang màn hình reset-password để test nhanh.
        </p>
      </div>
    </div>

    <button
      id="forgotPasswordButton"
      type="submit"
      class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-primary-600 px-5 py-3.5 text-sm font-bold text-white shadow-lg shadow-primary-600/20 transition hover:-translate-y-0.5 hover:bg-primary-700 active:scale-[0.99] disabled:cursor-not-allowed disabled:opacity-70"
    >
      <i class="fa-solid fa-paper-plane"></i>
      Gửi yêu cầu đặt lại mật khẩu
    </button>
  </form>

  <div class="mt-6 rounded-2xl border border-amber-100 bg-amber-50/80 p-4 text-sm leading-6 text-amber-900">
    <div class="flex gap-3">
      <div class="mt-0.5 text-amber-600">
        <i class="fa-solid fa-circle-info"></i>
      </div>

      <p>
        Trong môi trường development, nếu bật
        <span class="font-semibold">SHOW_RESET_TOKEN_IN_RESPONSE</span>,
        API có thể trả về token đặt lại mật khẩu để kiểm thử nhanh hơn.
      </p>
    </div>
  </div>

  <div id="resetTokenBox" class="mt-5 hidden rounded-2xl border border-emerald-200 bg-emerald-50 p-4">
    <p class="text-sm font-bold text-emerald-800">
      Token đặt lại mật khẩu
    </p>

    <div class="mt-3 flex gap-2">
      <input
        id="resetTokenInput"
        type="text"
        readonly
        class="w-full rounded-xl border border-emerald-200 bg-white px-3 py-2 text-xs text-emerald-800 focus:border-emerald-500 focus:ring-emerald-500"
      />

      <button
        type="button"
        onclick="copyResetToken()"
        class="rounded-xl bg-emerald-600 px-4 py-2 text-xs font-bold text-white transition hover:bg-emerald-700"
      >
        Copy
      </button>
    </div>

    <a
      id="goResetPasswordLink"
      href="/auth/reset-password"
      class="mt-3 inline-flex items-center gap-2 text-sm font-bold text-emerald-700 hover:text-emerald-800"
    >
      Sang trang đặt lại mật khẩu
      <i class="fa-solid fa-arrow-right"></i>
    </a>
  </div>

  <div class="mt-6 text-center text-sm">
    <a href="/auth/login" class="font-semibold text-primary-600 hover:text-primary-700">
      <i class="fa-solid fa-arrow-left mr-1"></i>
      Quay lại đăng nhập
    </a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const forgotPasswordForm = document.getElementById('forgotPasswordForm');
    const forgotPasswordButton = document.getElementById('forgotPasswordButton');
    const resetTokenBox = document.getElementById('resetTokenBox');
    const resetTokenInput = document.getElementById('resetTokenInput');
    const goResetPasswordLink = document.getElementById('goResetPasswordLink');

    forgotPasswordForm.addEventListener('submit', async function (event) {
      event.preventDefault();

      const email = document.getElementById('email').value.trim();

      forgotPasswordButton.disabled = true;
      forgotPasswordButton.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang gửi yêu cầu...';

      try {
        const response = await fetch('/api/auth/forgot-password', {
          method: 'POST',
          credentials: 'include',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ email }),
        });

        const result = await response.json();

        console.log('FORGOT_PASSWORD_RESPONSE:', result);

        if (!response.ok || result.success === false) {
          const message = result.message || 'Không thể gửi yêu cầu đặt lại mật khẩu';

          if (typeof showToast === 'function') {
            showToast(message, 'error');
          } else {
            alert(message);
          }

          return;
        }

        if (typeof showToast === 'function') {
          showToast(result.message || 'Gửi yêu cầu đặt lại mật khẩu thành công', 'success');
        } else {
          alert(result.message || 'Gửi yêu cầu đặt lại mật khẩu thành công');
        }

        const data = result.data?.data || result.data || {};
        const resetToken =
          data.resetToken ||
          data.reset_password_token ||
          data.token ||
          data.resetPasswordToken;

        if (resetToken) {
          resetTokenBox.classList.remove('hidden');
          resetTokenInput.value = resetToken;
          goResetPasswordLink.href = '/auth/reset-password?token=' + encodeURIComponent(resetToken);
        }
      } catch (error) {
        console.error(error);

        if (typeof showToast === 'function') {
          showToast('Không thể kết nối tới máy chủ', 'error');
        } else {
          alert('Không thể kết nối tới máy chủ');
        }
      } finally {
        forgotPasswordButton.disabled = false;
        forgotPasswordButton.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Gửi yêu cầu đặt lại mật khẩu';
      }
    });
  });

  function copyResetToken() {
    const resetTokenInput = document.getElementById('resetTokenInput');

    resetTokenInput.select();
    resetTokenInput.setSelectionRange(0, 99999);

    navigator.clipboard.writeText(resetTokenInput.value);

    if (typeof showToast === 'function') {
      showToast('Đã copy token đặt lại mật khẩu', 'success');
    } else {
      alert('Đã copy token đặt lại mật khẩu');
    }
  }
</script>
