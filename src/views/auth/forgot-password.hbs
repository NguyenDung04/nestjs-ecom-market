<main
    class="relative z-10 flex-1 flex items-center justify-center py-8 sm:py-12 px-4 sm:px-6"
>
    <div
        class="max-w-5xl w-full grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center"
    >
        {{> auth/benefits}}

        <!-- Bên phải: Form quên mật khẩu -->
        <section
            class="w-full max-w-[480px] mx-auto lg:mx-0 lg:ml-auto"
            aria-label="Form quên mật khẩu"
        >
            <div
                class="form-card bg-white rounded-2xl shadow-lg shadow-gray-200/50 border border-gray-100 p-6 sm:p-8"
            >
                <!-- Tiêu đề form -->
                <div class="text-center mb-6">
                    <div
                        class="w-14 h-14 rounded-2xl mx-auto mb-4 flex items-center justify-center"
                        style="
                            background: linear-gradient(
                                135deg,
                                var(--teal-50),
                                var(--teal-100)
                            );
                            border: 1px solid rgba(0, 122, 122, 0.1);
                        "
                    >
                        <i
                            class="fa-solid fa-shield-halved text-xl"
                            style="color: var(--teal-600)"
                        ></i>
                    </div>

                    <h2 class="text-xl font-bold text-gray-900">
                        Quên mật khẩu
                    </h2>

                    <p class="text-sm text-gray-500 mt-1.5">
                        Nhập email để nhận mã xác minh và đặt lại mật khẩu.
                    </p>
                </div>

                {{> common/alert}}

                <!-- ===== STEP PROGRESS ===== -->
                <div class="mb-8">
                    <div class="hidden sm:flex items-center justify-between">
                        <div class="flex flex-col items-center" style="min-width: 60px">
                            <div class="step-circle active" id="sc-1">1</div>
                            <span
                                class="step-label text-xs mt-2 font-medium text-gray-500"
                                id="sl-1"
                            >
                                Email
                            </span>
                        </div>

                        <div class="step-line" id="line-1">
                            <div class="step-line-fill"></div>
                        </div>

                        <div class="flex flex-col items-center" style="min-width: 60px">
                            <div class="step-circle" id="sc-2">2</div>
                            <span
                                class="step-label text-xs mt-2 font-medium text-gray-500"
                                id="sl-2"
                            >
                                Gửi OTP
                            </span>
                        </div>

                        <div class="step-line" id="line-2">
                            <div class="step-line-fill"></div>
                        </div>

                        <div class="flex flex-col items-center" style="min-width: 60px">
                            <div class="step-circle" id="sc-3">3</div>
                            <span
                                class="step-label text-xs mt-2 font-medium text-gray-500"
                                id="sl-3"
                            >
                                Xác minh
                            </span>
                        </div>

                        <div class="step-line" id="line-3">
                            <div class="step-line-fill"></div>
                        </div>

                        <div class="flex flex-col items-center" style="min-width: 60px">
                            <div class="step-circle" id="sc-4">4</div>
                            <span
                                class="step-label text-xs mt-2 font-medium text-gray-500"
                                id="sl-4"
                            >
                                Mật khẩu
                            </span>
                        </div>
                    </div>

                    <div class="sm:hidden">
                        <div class="flex items-center gap-2 mb-2">
                            <div
                                class="step-circle active"
                                id="sc-1m"
                                style="
                                    width: 32px;
                                    height: 32px;
                                    font-size: 12px;
                                    border-width: 2px;
                                "
                            >
                                1
                            </div>

                            <div class="step-line" id="line-1m" style="height: 2px">
                                <div class="step-line-fill"></div>
                            </div>

                            <div
                                class="step-circle"
                                id="sc-2m"
                                style="
                                    width: 32px;
                                    height: 32px;
                                    font-size: 12px;
                                    border-width: 2px;
                                "
                            >
                                2
                            </div>

                            <div class="step-line" id="line-2m" style="height: 2px">
                                <div class="step-line-fill"></div>
                            </div>

                            <div
                                class="step-circle"
                                id="sc-3m"
                                style="
                                    width: 32px;
                                    height: 32px;
                                    font-size: 12px;
                                    border-width: 2px;
                                "
                            >
                                3
                            </div>

                            <div class="step-line" id="line-3m" style="height: 2px">
                                <div class="step-line-fill"></div>
                            </div>

                            <div
                                class="step-circle"
                                id="sc-4m"
                                style="
                                    width: 32px;
                                    height: 32px;
                                    font-size: 12px;
                                    border-width: 2px;
                                "
                            >
                                4
                            </div>
                        </div>

                        <p
                            class="step-label-mobile text-xs font-medium text-center"
                            style="color: var(--teal-600)"
                            id="sl-mobile"
                        >
                            Bước 1: Nhập email
                        </p>
                    </div>
                </div>

                <!-- ===== STEP 1: NHẬP EMAIL ===== -->
                <div class="step-content active" id="step-1">
                    <div class="text-center mb-6">
                        <div
                            class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-3"
                            style="
                                background: linear-gradient(
                                    135deg,
                                    var(--teal-50),
                                    #e0f2f1
                                );
                            "
                        >
                            <i
                                class="fa-solid fa-envelope text-lg"
                                style="color: var(--teal-500)"
                            ></i>
                        </div>

                        <h2 class="text-lg font-bold text-gray-800">
                            Nhập email tài khoản
                        </h2>

                        <p class="text-sm text-gray-400 mt-1">
                            Vui lòng nhập email đã đăng ký để nhận hướng dẫn lấy lại mật khẩu.
                        </p>
                    </div>

                    <form id="form-email" onsubmit="return false;" novalidate>
                        <div class="mb-1">
                            <label
                                class="block text-sm font-medium text-gray-700 mb-1.5"
                                for="fp-email"
                            >
                                Email tài khoản
                            </label>

                            <div class="relative">
                                <span
                                    class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"
                                >
                                    <i class="fa-solid fa-envelope"></i>
                                </span>

                                <input
                                    type="email"
                                    id="fp-email"
                                    name="email"
                                    class="input-teal w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800 placeholder-gray-400 outline-none transition-all"
                                    placeholder="Nhập email đã đăng ký"
                                    autocomplete="email"
                                />
                            </div>

                            <div class="field-error" id="err-email">
                                <i class="fa-solid fa-circle-exclamation"></i>
                                <span></span>
                            </div>
                        </div>

                        <div class="pt-2">
                            <button
                                type="button"
                                class="w-full py-3 rounded-xl text-white font-semibold text-sm flex items-center justify-center gap-2 transition-all active:scale-[0.98]"
                                id="btn-email"
                                onclick="handleStep1()"
                                style="
                                    background: var(--teal-500);
                                    box-shadow: 0 4px 14px rgba(0, 122, 122, 0.25);
                                "
                                onmouseover="
                                    if (!this.classList.contains('btn-loading')) {
                                        this.style.background = 'var(--teal-600)';
                                        this.style.boxShadow =
                                            '0 6px 20px rgba(0,122,122,0.3)';
                                    }
                                "
                                onmouseout="
                                    if (!this.classList.contains('btn-loading')) {
                                        this.style.background = 'var(--teal-500)';
                                        this.style.boxShadow =
                                            '0 4px 14px rgba(0,122,122,0.25)';
                                    }
                                "
                            >
                                <span class="btn-text">Tiếp tục</span>
                                <span class="spinner"></span>
                                <i class="fa-solid fa-arrow-right btn-text text-sm"></i>
                            </button>
                        </div>
                    </form>

                    <div class="mt-5 text-center">
                        <a
                            href="/login"
                            class="link-teal text-sm inline-flex items-center gap-1.5"
                        >
                            <i class="fa-solid fa-arrow-left text-xs"></i>
                            Quay lại đăng nhập
                        </a>
                    </div>
                </div>

                <!-- ===== STEP 2: GỬI MÃ OTP ===== -->
                <div class="step-content" id="step-2">
                    <div class="text-center mb-6">
                        <div
                            class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-3"
                            style="
                                background: linear-gradient(
                                    135deg,
                                    var(--teal-50),
                                    #e0f2f1
                                );
                            "
                        >
                            <i
                                class="fa-solid fa-paper-plane text-lg"
                                style="color: var(--teal-500)"
                            ></i>
                        </div>

                        <h2 class="text-lg font-bold text-gray-800">
                            Gửi mã xác minh OTP
                        </h2>

                        <p class="text-sm text-gray-400 mt-1">
                            Mã OTP sẽ được gửi đến email của bạn.
                        </p>
                    </div>

                    <div
                        class="p-4 rounded-xl mb-5"
                        style="
                            background: linear-gradient(
                                135deg,
                                var(--teal-50),
                                #f0fdfa
                            );
                            border: 1px solid var(--teal-100);
                        "
                    >
                        <div class="flex items-center gap-3">
                            <div
                                class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0"
                                style="
                                    background: white;
                                    border: 2px solid var(--teal-200);
                                "
                            >
                                <i
                                    class="fa-solid fa-envelope-open text-sm"
                                    style="color: var(--teal-500)"
                                ></i>
                            </div>

                            <div>
                                <p class="text-xs text-gray-500">
                                    Mã OTP sẽ được gửi đến:
                                </p>

                                <p
                                    class="text-sm font-bold"
                                    style="color: var(--teal-700)"
                                    id="display-email"
                                >
                                    user@example.com
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mb-4">
                        <div
                            class="countdown-badge"
                            id="otp-expiry-badge"
                            style="display: none"
                        >
                            <i class="fa-solid fa-clock"></i>
                            <span>
                                Mã OTP có hiệu lực trong
                                <strong id="otp-expiry-text">5:00</strong>
                            </span>
                        </div>
                    </div>

                    <button
                        type="button"
                        class="w-full py-3 rounded-xl text-white font-semibold text-sm flex items-center justify-center gap-2 transition-all active:scale-[0.98]"
                        id="btn-send-otp"
                        onclick="handleSendOtp()"
                        style="
                            background: var(--teal-500);
                            box-shadow: 0 4px 14px rgba(0, 122, 122, 0.25);
                        "
                    >
                        <span class="btn-text">
                            <i class="fa-solid fa-paper-plane mr-1.5"></i>
                            Gửi mã OTP
                        </span>
                        <span class="spinner"></span>
                    </button>

                    <div class="mt-4 text-center">
                        <button
                            type="button"
                            class="text-sm text-gray-400 hover:text-gray-600 transition-colors"
                            onclick="goBackToStep(1)"
                        >
                            <i class="fa-solid fa-arrow-left text-xs mr-1"></i>
                            Thay đổi email
                        </button>
                    </div>
                </div>

                <!-- ===== STEP 3: XÁC MINH MÃ OTP ===== -->
                <div class="step-content" id="step-3">
                    <div class="text-center mb-6">
                        <div
                            class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-3"
                            style="
                                background: linear-gradient(
                                    135deg,
                                    var(--teal-50),
                                    #e0f2f1
                                );
                            "
                        >
                            <i
                                class="fa-solid fa-fingerprint text-lg"
                                style="color: var(--teal-500)"
                            ></i>
                        </div>

                        <h2 class="text-lg font-bold text-gray-800">
                            Xác minh mã OTP
                        </h2>

                        <p class="text-sm text-gray-400 mt-1">
                            Nhập 6 số mã OTP đã gửi đến email của bạn.
                        </p>
                    </div>

                    <div class="text-center mb-4">
                        <p
                            class="text-xs px-3 py-2 rounded-lg inline-block"
                            style="background: #fef3c7; color: #92400e"
                        >
                            <i class="fa-solid fa-lightbulb mr-1"></i>
                            Mã OTP demo:
                            <strong id="otp-hint-text">------</strong>
                        </p>
                    </div>

                    <div
                        class="flex justify-center gap-2 sm:gap-3 mb-2"
                        id="otp-container"
                    >
                        <input
                            type="text"
                            maxlength="1"
                            class="otp-input"
                            data-idx="0"
                            inputmode="numeric"
                            autocomplete="one-time-code"
                        />
                        <input
                            type="text"
                            maxlength="1"
                            class="otp-input"
                            data-idx="1"
                            inputmode="numeric"
                        />
                        <input
                            type="text"
                            maxlength="1"
                            class="otp-input"
                            data-idx="2"
                            inputmode="numeric"
                        />

                        <div
                            class="flex items-center text-gray-300 text-lg font-light mx-1"
                        >
                            -
                        </div>

                        <input
                            type="text"
                            maxlength="1"
                            class="otp-input"
                            data-idx="3"
                            inputmode="numeric"
                        />
                        <input
                            type="text"
                            maxlength="1"
                            class="otp-input"
                            data-idx="4"
                            inputmode="numeric"
                        />
                        <input
                            type="text"
                            maxlength="1"
                            class="otp-input"
                            data-idx="5"
                            inputmode="numeric"
                        />
                    </div>

                    <div class="field-error justify-center mb-4" id="err-otp">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span></span>
                    </div>

                    <div class="text-center mb-5">
                        <p class="text-sm text-gray-400" id="resend-info">
                            Gửi lại mã sau
                            <span
                                class="font-bold"
                                style="color: var(--teal-600)"
                                id="resend-countdown"
                            >
                                60
                            </span>s
                        </p>

                        <button
                            type="button"
                            class="link-teal text-sm mt-1 hidden"
                            id="btn-resend-otp"
                            onclick="handleResendOtp()"
                        >
                            <i class="fa-solid fa-redo mr-1 text-xs"></i>
                            Gửi lại mã OTP
                        </button>
                    </div>

                    <button
                        type="button"
                        class="w-full py-3 rounded-xl text-white font-semibold text-sm flex items-center justify-center gap-2 transition-all active:scale-[0.98]"
                        id="btn-verify-otp"
                        onclick="handleVerifyOtp()"
                        style="
                            background: var(--teal-500);
                            box-shadow: 0 4px 14px rgba(0, 122, 122, 0.25);
                        "
                    >
                        <span class="btn-text">
                            <i class="fa-solid fa-check-circle mr-1.5"></i>
                            Xác minh mã
                        </span>
                        <span class="spinner"></span>
                    </button>
                </div>

                <!-- ===== STEP 4: ĐỔI MẬT KHẨU MỚI ===== -->
                <div class="step-content" id="step-4">
                    <div class="text-center mb-6">
                        <div
                            class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-3"
                            style="
                                background: linear-gradient(
                                    135deg,
                                    var(--teal-50),
                                    #e0f2f1
                                );
                            "
                        >
                            <i
                                class="fa-solid fa-lock-open text-lg"
                                style="color: var(--teal-500)"
                            ></i>
                        </div>

                        <h2 class="text-lg font-bold text-gray-800">
                            Đặt mật khẩu mới
                        </h2>

                        <p class="text-sm text-gray-400 mt-1">
                            Tạo mật khẩu mới an toàn cho tài khoản của bạn.
                        </p>
                    </div>

                    <form id="form-password" onsubmit="return false;" novalidate>
                        <div class="mb-1">
                            <label
                                class="block text-sm font-medium text-gray-700 mb-1.5"
                                for="fp-new-pw"
                            >
                                Mật khẩu mới
                            </label>

                            <div class="relative">
                                <span
                                    class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"
                                >
                                    <i class="fa-solid fa-lock"></i>
                                </span>

                                <input
                                    type="password"
                                    id="fp-new-pw"
                                    class="input-teal w-full pl-10 pr-11 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800 placeholder-gray-400 outline-none transition-all"
                                    placeholder="Nhập mật khẩu mới"
                                    oninput="checkPasswordStrength()"
                                />

                                <button
                                    type="button"
                                    class="toggle-pw"
                                    onclick="togglePassword('fp-new-pw', this)"
                                    aria-label="Hiện/ẩn mật khẩu"
                                >
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </div>

                            <div class="field-error" id="err-new-pw">
                                <i class="fa-solid fa-circle-exclamation"></i>
                                <span></span>
                            </div>
                        </div>

                        <div class="mb-5 mt-2">
                            <div class="flex gap-1.5 mb-1.5">
                                <div class="strength-bar flex-1 bg-gray-200" id="str-bar-1"></div>
                                <div class="strength-bar flex-1 bg-gray-200" id="str-bar-2"></div>
                                <div class="strength-bar flex-1 bg-gray-200" id="str-bar-3"></div>
                                <div class="strength-bar flex-1 bg-gray-200" id="str-bar-4"></div>
                            </div>

                            <p
                                class="text-xs font-medium"
                                id="str-text"
                                style="color: #9ca3af"
                            >
                                Nhập mật khẩu để kiểm tra độ mạnh
                            </p>
                        </div>

                        <div class="mb-1">
                            <label
                                class="block text-sm font-medium text-gray-700 mb-1.5"
                                for="fp-confirm-pw"
                            >
                                Xác nhận mật khẩu mới
                            </label>

                            <div class="relative">
                                <span
                                    class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"
                                >
                                    <i class="fa-solid fa-lock"></i>
                                </span>

                                <input
                                    type="password"
                                    id="fp-confirm-pw"
                                    class="input-teal w-full pl-10 pr-11 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800 placeholder-gray-400 outline-none transition-all"
                                    placeholder="Nhập lại mật khẩu mới"
                                />

                                <button
                                    type="button"
                                    class="toggle-pw"
                                    onclick="togglePassword('fp-confirm-pw', this)"
                                    aria-label="Hiện/ẩn mật khẩu"
                                >
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </div>

                            <div class="field-error" id="err-confirm-pw">
                                <i class="fa-solid fa-circle-exclamation"></i>
                                <span></span>
                            </div>
                        </div>

                        <div class="pt-2">
                            <button
                                type="button"
                                class="w-full py-3 rounded-xl text-white font-semibold text-sm flex items-center justify-center gap-2 transition-all active:scale-[0.98]"
                                id="btn-change-pw"
                                onclick="handleChangePassword()"
                                style="
                                    background: var(--teal-500);
                                    box-shadow: 0 4px 14px rgba(0, 122, 122, 0.25);
                                "
                            >
                                <span class="btn-text">
                                    <i class="fa-solid fa-check mr-1.5"></i>
                                    Đổi mật khẩu
                                </span>
                                <span class="spinner"></span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </section>
    </div>
</main>

<!-- ========== SCRIPT ========== -->
<script>
    // ============================================================
    // DỮ LIỆU DEMO - Bám theo DB nestjs_ecom_market.sql
    // Bảng users: id, role_id, name, email, phone, password, avatar, status, email_verified_at, created_at, updated_at
    // ============================================================
    const users = [
        {
            id: 1,
            role_id: 2,
            name: "Nguyễn Văn A",
            email: "customer@example.com",
            phone: "0900000002",
            password: "hashed_123456",
            avatar: null,
            status: "active",
            email_verified_at: null,
            created_at: "2026-04-01",
            updated_at: "2026-04-01",
        },
        {
            id: 2,
            role_id: 2,
            name: "Trần Văn B",
            email: "tranvanb@example.com",
            phone: "0912345678",
            password: "hashed_abcdef",
            avatar: null,
            status: "active",
            email_verified_at: null,
            created_at: "2026-04-01",
            updated_at: "2026-04-01",
        },
        {
            id: 3,
            role_id: 2,
            name: "Lê Thị C",
            email: "lethic@example.com",
            phone: "0987654321",
            password: "hashed_password3",
            avatar: null,
            status: "active",
            email_verified_at: "2026-04-05",
            created_at: "2026-04-03",
            updated_at: "2026-04-05",
        },
        {
            id: 4,
            role_id: 1,
            name: "Admin",
            email: "admin@kigenmarket.com",
            phone: "0900000001",
            password: "hashed_admin123",
            avatar: null,
            status: "active",
            email_verified_at: "2026-01-01",
            created_at: "2026-01-01",
            updated_at: "2026-01-01",
        },
    ];

    // ============================================================
    // BIẾN TRẠNG THÁI QUÉN MẬT KHẨU
    // Lưu ý: OTP thực tế nên được lưu trong Redis/cache/session phía backend,
    // KHÔNG lưu trực tiếp vào bảng users vì DB không có field otp/reset_token.
    // ============================================================
    let currentStep = 1;
    let selectedUser = null;
    let currentOtp = null;
    let otpExpiredAt = null;
    let otpVerified = false;

    // Countdown gửi lại OTP
    let resendCountdownInterval = null;
    let resendSecondsLeft = 60;

    // Countdown hết hạn OTP
    let otpExpiryInterval = null;

    // ============================================================
    // TIỆN ÍCH
    // ============================================================

    // Hiển thị lỗi field
    function showFieldError(id, message) {
        const el = document.getElementById(id);
        if (!el) return;
        el.querySelector("span").textContent = message;
        el.classList.add("show");
        // Tìm input gần nhất để thêm class error
        const parent = el.parentElement;
        const input = parent.querySelector(".form-input, .otp-input");
        if (input) input.classList.add("input-error");
    }

    function clearFieldError(id) {
        const el = document.getElementById(id);
        if (!el) return;
        el.classList.remove("show");
        const parent = el.parentElement;
        const input = parent.querySelector(".form-input, .otp-input");
        if (input) input.classList.remove("input-error");
    }

    function clearAllOtpErrors() {
        clearFieldError("err-otp");
        document
            .querySelectorAll(".otp-input")
            .forEach((inp) => inp.classList.remove("error"));
    }

    // Validate email cơ bản
    function isValidEmail(email) {
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    // Tạo OTP 6 số ngẫu nhiên
    function generateOtp() {
        return String(Math.floor(100000 + Math.random() * 900000));
    }

    // Đặt loading cho button
    function setBtnLoading(btnId, loading) {
        const btn = document.getElementById(btnId);
        if (!btn) return;
        if (loading) {
            btn.classList.add("loading");
            btn.disabled = true;
        } else {
            btn.classList.remove("loading");
            btn.disabled = false;
        }
    }

    // ============================================================
    // STEP PROGRESS - CẬP NHẬT GIAO DIỆN
    // ============================================================
    const stepLabelsMobile = {
        1: "Bước 1: Nhập email",
        2: "Bước 2: Gửi mã OTP",
        3: "Bước 3: Xác minh mã",
        4: "Bước 4: Đặt mật khẩu mới",
    };

    function updateStepProgress(step) {
        // Desktop
        for (let i = 1; i <= 4; i++) {
            const circle = document.getElementById("sc-" + i);
            const label = document.getElementById("sl-" + i);
            if (!circle) continue;

            circle.className = "step-circle";
            if (label) label.style.color = "#6b7280";

            if (i < step) {
                // Đã hoàn thành
                circle.classList.add("completed");
                circle.innerHTML = '<i class="fas fa-check text-sm"></i>';
                if (label) label.style.color = "var(--teal-500)";
            } else if (i === step) {
                // Đang active
                circle.classList.add("active");
                circle.textContent = i;
                if (label) label.style.color = "var(--teal-600)";
            } else {
                // Chưa tới
                circle.textContent = i;
            }

            // Line trước step
            if (i < 4) {
                const line = document.getElementById("line-" + i);
                if (line) {
                    if (i < step) {
                        line.classList.add("completed");
                    } else {
                        line.classList.remove("completed");
                    }
                }
            }
        }

        // Mobile
        for (let i = 1; i <= 4; i++) {
            const circle = document.getElementById("sc-" + i + "m");
            if (!circle) continue;
            circle.className = "step-circle";
            circle.style.width = "32px";
            circle.style.height = "32px";
            circle.style.fontSize = "12px";
            circle.style.borderWidth = "2px";

            if (i < step) {
                circle.classList.add("completed");
                circle.innerHTML =
                    '<i class="fas fa-check" style="font-size:10px;"></i>';
            } else if (i === step) {
                circle.classList.add("active");
                circle.textContent = i;
            } else {
                circle.textContent = i;
            }

            if (i < 4) {
                const line = document.getElementById("line-" + i + "m");
                if (line) {
                    if (i < step) line.classList.add("completed");
                    else line.classList.remove("completed");
                }
            }
        }

        // Mobile label
        const mobileLabel = document.getElementById("sl-mobile");
        if (mobileLabel) {
            mobileLabel.textContent = stepLabelsMobile[step] || "";
        }
    }

    // Chuyển step
    function goToStep(step) {
        // Ẩn tất cả step content
        document.querySelectorAll(".step-content").forEach((el) => {
            el.classList.remove("active");
        });
        // Hiện step mới
        const target = document.getElementById("step-" + step);
        if (target) {
            target.classList.remove("active");
            // Force reflow để animation chạy lại
            void target.offsetWidth;
            target.classList.add("active");
        }
        currentStep = step;
        updateStepProgress(step);
    }

    // Quay lại step (cho nút "Thay đổi email")
    function goBackToStep(step) {
        // Dừng các countdown nếu quay lại
        if (step <= 2) {
            clearResendCountdown();
            clearOtpExpiry();
        }
        goToStep(step);
    }

    // ============================================================
    // STEP 1 - NHẬP EMAIL
    // ============================================================
    function handleStep1() {
        clearFieldError("err-email");
        const emailInput = document.getElementById("fp-email");
        const email = emailInput.value.trim();

        // Validate rỗng
        if (!email) {
            showFieldError("err-email", "Vui lòng nhập email tài khoản");
            emailInput.focus();
            return;
        }

        // Validate định dạng
        if (!isValidEmail(email)) {
            showFieldError("err-email", "Email không đúng định dạng");
            emailInput.focus();
            return;
        }

        // Kiểm tra email tồn tại trong users demo (theo users.email)
        const foundUser = users.find(
            (u) => u.email.toLowerCase() === email.toLowerCase(),
        );

        if (!foundUser) {
            showFieldError("err-email", "Email không tồn tại trong hệ thống");
            emailInput.focus();
            Swal.fire({
                icon: "warning",
                title: "Email không tồn tại",
                text:
                    'Không tìm thấy tài khoản với email "' +
                    email +
                    '" trong hệ thống. Vui lòng kiểm tra lại.',
                confirmButtonColor: "var(--teal-600)",
                confirmButtonText: "Đã hiểu",
                customClass: { popup: "rounded-2xl" },
            });
            return;
        }

        // Kiểm tra trạng thái tài khoản
        if (foundUser.status !== "active") {
            showFieldError(
                "err-email",
                "Tài khoản đã bị khóa hoặc vô hiệu hóa",
            );
            Swal.fire({
                icon: "error",
                title: "Tài khoản không khả dụng",
                text: "Tài khoản của bạn hiện không hoạt động. Vui lòng liên hệ hỗ trợ.",
                confirmButtonColor: "var(--teal-600)",
                confirmButtonText: "Đã hiểu",
                customClass: { popup: "rounded-2xl" },
            });
            return;
        }

        // Lưu user đã chọn
        selectedUser = foundUser;

        // Loading
        setBtnLoading("btn-email", true);
        setTimeout(() => {
            setBtnLoading("btn-email", false);
            // Hiển thị email ở Step 2
            document.getElementById("display-email").textContent =
                selectedUser.email;
            goToStep(2);
        }, 600);
    }

    // Enter trên input email
    document.addEventListener("DOMContentLoaded", function () {
        document
            .getElementById("fp-email")
            .addEventListener("keydown", function (e) {
                if (e.key === "Enter") {
                    e.preventDefault();
                    handleStep1();
                }
            });
    });

    // ============================================================
    // STEP 2 - GỬI MÃ OTP
    // ============================================================
    function handleSendOtp() {
        if (!selectedUser) return;

        setBtnLoading("btn-send-otp", true);

        // Mô phỏng delay gửi OTP
        setTimeout(() => {
            // Tạo OTP demo 6 số
            currentOtp = generateOtp();
            // Thời gian hết hạn: 5 phút
            otpExpiredAt = Date.now() + 5 * 60 * 1000;
            otpVerified = false;

            // Hiển thị OTP hint cho demo
            document.getElementById("otp-hint-text").textContent = currentOtp;

            setBtnLoading("btn-send-otp", false);

            // Hiển thị SweetAlert2 thông báo
            Swal.fire({
                icon: "success",
                title: "Gửi mã OTP thành công",
                html:
                    "Mã OTP đã được gửi đến email <strong>" +
                    selectedUser.email +
                    '</strong>.<br><small style="color:#6b7280;">Mã có hiệu lực trong 5 phút.</small>',
                confirmButtonColor: "var(--teal-600)",
                confirmButtonText: "Nhập mã OTP",
                customClass: { popup: "rounded-2xl" },
            }).then(() => {
                // Chuyển sang Step 3
                goToStep(3);
                // Focus ô OTP đầu tiên
                const firstOtp = document.querySelector(
                    '.otp-input[data-idx="0"]',
                );
                if (firstOtp) firstOtp.focus();
            });

            // Bắt đầu countdown hết hạn OTP
            startOtpExpiry();

            // Bắt đầu countdown gửi lại OTP
            startResendCountdown();

            /*
             * GHI CHÚ BACKEND:
             * Thực tế backend nên:
             * 1. Tạo OTP ngẫu nhiên 6 số
             * 2. Lưu OTP vào Redis với key = "otp:forgot:{email}", TTL = 300s
             * 3. Gửi OTP qua email service (SendGrid, AWS SES, v.v.)
             * 4. KHÔNG lưu OTP vào bảng users vì DB không có field otp
             */
        }, 1200);
    }

    // ============================================================
    // COUNTDOWN HẾT HẠN OTP
    // ============================================================
    function startOtpExpiry() {
        clearOtpExpiry();
        const badge = document.getElementById("otp-expiry-badge");
        const text = document.getElementById("otp-expiry-text");
        badge.style.display = "inline-flex";

        otpExpiryInterval = setInterval(() => {
            const remaining = otpExpiredAt - Date.now();
            if (remaining <= 0) {
                clearOtpExpiry();
                badge.style.display = "none";
                // Nếu đang ở step 3, cảnh báo
                if (currentStep === 3) {
                    Swal.fire({
                        icon: "warning",
                        title: "Mã OTP đã hết hạn",
                        text: "Mã OTP không còn hiệu lực. Vui lòng gửi lại mã mới.",
                        confirmButtonColor: "var(--teal-600)",
                        confirmButtonText: "Gửi lại mã",
                        customClass: { popup: "rounded-2xl" },
                    }).then(() => {
                        goToStep(2);
                        clearResendCountdown();
                    });
                }
                return;
            }
            const mins = Math.floor(remaining / 60000);
            const secs = Math.floor((remaining % 60000) / 1000);
            text.textContent = mins + ":" + String(secs).padStart(2, "0");
        }, 1000);
    }

    function clearOtpExpiry() {
        if (otpExpiryInterval) {
            clearInterval(otpExpiryInterval);
            otpExpiryInterval = null;
        }
    }

    // ============================================================
    // COUNTDOWN GỬI LẠI OTP
    // ============================================================
    function startResendCountdown() {
        clearResendCountdown();
        resendSecondsLeft = 60;
        const btnResend = document.getElementById("btn-resend-otp");
        const resendInfo = document.getElementById("resend-info");
        const countdownText = document.getElementById("resend-countdown");

        btnResend.classList.add("hidden");
        resendInfo.style.display = "block";
        countdownText.textContent = resendSecondsLeft;

        resendCountdownInterval = setInterval(() => {
            resendSecondsLeft--;
            if (resendSecondsLeft <= 0) {
                clearResendCountdown();
                // Hiện nút gửi lại
                btnResend.classList.remove("hidden");
                resendInfo.style.display = "none";
            } else {
                countdownText.textContent = resendSecondsLeft;
            }
        }, 1000);
    }

    function clearResendCountdown() {
        if (resendCountdownInterval) {
            clearInterval(resendCountdownInterval);
            resendCountdownInterval = null;
        }
    }

    // Gửi lại OTP
    function handleResendOtp() {
        if (!selectedUser) return;

        // Tạo OTP mới
        currentOtp = generateOtp();
        otpExpiredAt = Date.now() + 5 * 60 * 1000;
        otpVerified = false;

        // Cập nhật hint
        document.getElementById("otp-hint-text").textContent = currentOtp;

        // Reset OTP inputs
        document.querySelectorAll(".otp-input").forEach((inp) => {
            inp.value = "";
            inp.classList.remove("filled", "error");
        });
        clearAllOtpErrors();

        Swal.fire({
            icon: "success",
            title: "Đã gửi lại mã OTP",
            html:
                "Mã OTP mới đã được gửi đến <strong>" +
                selectedUser.email +
                "</strong>",
            confirmButtonColor: "var(--teal-600)",
            confirmButtonText: "Đã hiểu",
            customClass: { popup: "rounded-2xl" },
            timer: 3000,
            timerProgressBar: true,
        });

        // Reset countdowns
        startResendCountdown();
        startOtpExpiry();

        // Focus ô đầu
        const firstOtp = document.querySelector('.otp-input[data-idx="0"]');
        if (firstOtp) firstOtp.focus();
    }

    // ============================================================
    // STEP 3 - XÁC MINH MÃ OTP (6 ô input thông minh)
    // ============================================================
    document.addEventListener("DOMContentLoaded", function () {
        const otpInputs = document.querySelectorAll(".otp-input");

        otpInputs.forEach((input, idx) => {
            // Chỉ nhận số
            input.addEventListener("input", function (e) {
                const val = this.value.replace(/\D/g, "");
                this.value = val.slice(0, 1);

                if (val) {
                    this.classList.add("filled");
                    // Focus ô tiếp theo
                    const nextIdx = idx + 1;
                    if (nextIdx < otpInputs.length) {
                        otpInputs[nextIdx].focus();
                    }
                } else {
                    this.classList.remove("filled");
                }

                clearAllOtpErrors();
            });

            // Backspace quay về ô trước
            input.addEventListener("keydown", function (e) {
                if (e.key === "Backspace") {
                    if (!this.value && idx > 0) {
                        otpInputs[idx - 1].focus();
                        otpInputs[idx - 1].value = "";
                        otpInputs[idx - 1].classList.remove("filled");
                    }
                    clearAllOtpErrors();
                }
                // Enter xác minh
                if (e.key === "Enter") {
                    e.preventDefault();
                    handleVerifyOtp();
                }
            });

            // Hỗ trợ paste
            input.addEventListener("paste", function (e) {
                e.preventDefault();
                const pasted = (e.clipboardData || window.clipboardData)
                    .getData("text")
                    .replace(/\D/g, "")
                    .slice(0, 6);
                if (pasted.length > 0) {
                    for (let i = 0; i < otpInputs.length; i++) {
                        if (i < pasted.length) {
                            otpInputs[i].value = pasted[i];
                            otpInputs[i].classList.add("filled");
                        } else {
                            otpInputs[i].value = "";
                            otpInputs[i].classList.remove("filled");
                        }
                    }
                    // Focus ô cuối đã nhập hoặc ô cuối
                    const focusIdx =
                        Math.min(pasted.length, otpInputs.length) - 1;
                    otpInputs[Math.max(0, focusIdx)].focus();
                    clearAllOtpErrors();
                }
            });

            // Focus highlight
            input.addEventListener("focus", function () {
                this.select();
            });
        });
    });

    // Lấy giá trị OTP từ 6 ô
    function getOtpValue() {
        let otp = "";
        document.querySelectorAll(".otp-input").forEach((inp) => {
            otp += inp.value;
        });
        return otp;
    }

    // Xác minh OTP
    function handleVerifyOtp() {
        clearAllOtpErrors();
        const otp = getOtpValue();

        // Validate đủ 6 ký tự
        if (otp.length < 6) {
            showFieldError("err-otp", "Vui lòng nhập đủ 6 số mã OTP");
            // Highlight ô trống đầu tiên
            const inputs = document.querySelectorAll(".otp-input");
            for (let inp of inputs) {
                if (!inp.value) {
                    inp.classList.add("error");
                    inp.focus();
                    break;
                }
            }
            return;
        }

        // Kiểm tra hết hạn
        if (otpExpiredAt && Date.now() > otpExpiredAt) {
            showFieldError("err-otp", "Mã OTP đã hết hạn, vui lòng gửi lại mã");
            document
                .querySelectorAll(".otp-input")
                .forEach((inp) => inp.classList.add("error"));

            Swal.fire({
                icon: "warning",
                title: "Mã OTP đã hết hạn",
                text: "Mã OTP không còn hiệu lực. Vui lòng gửi lại mã mới.",
                confirmButtonColor: "var(--teal-600)",
                confirmButtonText: "Gửi lại mã",
                customClass: { popup: "rounded-2xl" },
            }).then(() => {
                goToStep(2);
                clearResendCountdown();
            });
            return;
        }

        // So khớp OTP
        if (otp !== currentOtp) {
            showFieldError(
                "err-otp",
                "Mã OTP không chính xác, vui lòng nhập lại",
            );
            document
                .querySelectorAll(".otp-input")
                .forEach((inp) => inp.classList.add("error"));

            // Clear inputs sau animation shake
            setTimeout(() => {
                document.querySelectorAll(".otp-input").forEach((inp) => {
                    inp.value = "";
                    inp.classList.remove("filled", "error");
                });
                const first = document.querySelector(
                    '.otp-input[data-idx="0"]',
                );
                if (first) first.focus();
            }, 500);

            Swal.fire({
                icon: "error",
                title: "Mã OTP không đúng",
                text: "Mã bạn nhập không khớp với mã đã gửi. Vui lòng kiểm tra lại.",
                confirmButtonColor: "var(--teal-600)",
                confirmButtonText: "Nhập lại",
                customClass: { popup: "rounded-2xl" },
            });
            return;
        }

        // OTP đúng
        setBtnLoading("btn-verify-otp", true);
        setTimeout(() => {
            setBtnLoading("btn-verify-otp", false);
            otpVerified = true;

            // Dừng countdowns
            clearResendCountdown();
            clearOtpExpiry();

            Swal.fire({
                icon: "success",
                title: "Xác minh thành công",
                text: "Mã OTP chính xác. Bạn có thể đặt mật khẩu mới ngay bây giờ.",
                confirmButtonColor: "var(--teal-600)",
                confirmButtonText: "Tiếp tục",
                customClass: { popup: "rounded-2xl" },
            }).then(() => {
                goToStep(4);
                // Focus input mật khẩu mới
                document.getElementById("fp-new-pw").focus();
            });
        }, 800);
    }

    // ============================================================
    // STEP 4 - ĐỔI MẬT KHẨU MỚI
    // ============================================================

    // Bật/tắt hiển thị mật khẩu
    function togglePassword(inputId, btn) {
        const input = document.getElementById(inputId);
        if (!input) return;
        const icon = btn.querySelector("i");
        if (input.type === "password") {
            input.type = "text";
            icon.classList.remove("fa-eye");
            icon.classList.add("fa-eye-slash");
        } else {
            input.type = "password";
            icon.classList.remove("fa-eye-slash");
            icon.classList.add("fa-eye");
        }
    }

    // Thanh độ mạnh mật khẩu
    function checkPasswordStrength() {
        const pw = document.getElementById("fp-new-pw").value;
        const bars = [
            document.getElementById("str-bar-1"),
            document.getElementById("str-bar-2"),
            document.getElementById("str-bar-3"),
            document.getElementById("str-bar-4"),
        ];
        const text = document.getElementById("str-text");

        // Reset
        bars.forEach((b) => {
            b.style.background = "#e5e7eb";
        });

        if (!pw) {
            text.textContent = "Nhập mật khẩu để kiểm tra độ mạnh";
            text.style.color = "#9ca3af";
            return 0;
        }

        let score = 0;
        if (pw.length >= 6) score++;
        if (pw.length >= 8) score++;
        if (/[A-Z]/.test(pw) && /[a-z]/.test(pw)) score++;
        if (/[0-9]/.test(pw)) score++;
        if (/[^A-Za-z0-9]/.test(pw)) score++;

        // Max 4 mức
        let level = 0;
        if (score <= 1)
            level = 1; // Yếu
        else if (score <= 2)
            level = 2; // Trung bình
        else if (score <= 3)
            level = 3; // Khá
        else level = 4; // Mạnh

        const colors = {
            1: "#ef4444", // Đỏ - yếu
            2: "#f59e0b", // Cam - trung bình
            3: "#00b4b4", // Teal - khá
            4: "#059669", // Xanh - mạnh
        };
        const labels = {
            1: "Mật khẩu yếu",
            2: "Mật khẩu trung bình",
            3: "Mật khẩu khá",
            4: "Mật khẩu mạnh",
        };

        for (let i = 0; i < level; i++) {
            bars[i].style.background = colors[level];
        }
        text.textContent = labels[level];
        text.style.color = colors[level];

        return level;
    }

    // Xử lý đổi mật khẩu
    function handleChangePassword() {
        clearFieldError("err-new-pw");
        clearFieldError("err-confirm-pw");

        const newPw = document.getElementById("fp-new-pw").value;
        const confirmPw = document.getElementById("fp-confirm-pw").value;

        // Kiểm tra verified
        if (!otpVerified) {
            Swal.fire({
                icon: "error",
                title: "Chưa xác minh OTP",
                text: "Vui lòng hoàn thành xác minh OTP trước khi đổi mật khẩu.",
                confirmButtonColor: "var(--teal-600)",
                customClass: { popup: "rounded-2xl" },
            });
            return;
        }

        // Validate mật khẩu mới rỗng
        if (!newPw) {
            showFieldError("err-new-pw", "Vui lòng nhập mật khẩu mới");
            document.getElementById("fp-new-pw").focus();
            return;
        }

        // Validate độ dài
        if (newPw.length < 6) {
            showFieldError("err-new-pw", "Mật khẩu phải có ít nhất 6 ký tự");
            document.getElementById("fp-new-pw").focus();
            return;
        }

        // Validate xác nhận rỗng
        if (!confirmPw) {
            showFieldError("err-confirm-pw", "Vui lòng xác nhận mật khẩu mới");
            document.getElementById("fp-confirm-pw").focus();
            return;
        }

        // Validate trùng khớp
        if (newPw !== confirmPw) {
            showFieldError(
                "err-confirm-pw",
                "Xác nhận mật khẩu không trùng khớp",
            );
            document.getElementById("fp-confirm-pw").focus();
            return;
        }

        // Loading
        setBtnLoading("btn-change-pw", true);

        setTimeout(() => {
            setBtnLoading("btn-change-pw", false);

            /*
             * GHI CHÚ BACKEND:
             * Thực tế backend nên:
             * 1. Nhận newPassword từ request body
             * 2. Mã hóa bằng bcrypt: const hashedPassword = await bcrypt.hash(newPassword, 10);
             * 3. Cập nhật DB: UPDATE users SET password = hashedPassword, updated_at = NOW() WHERE id = selectedUser.id
             * 4. Xóa OTP trong Redis
             * 5. Gửi email thông báo đổi mật khẩu thành công
             */

            // Mô phỏng mã hóa mật khẩu
            const hashedPassword = "hashed_" + newPw;

            // Cập nhật selectedUser.password trong mảng users demo
            if (selectedUser) {
                selectedUser.password = hashedPassword;
                selectedUser.updated_at = new Date()
                    .toISOString()
                    .split("T")[0];

                // Cập nhật trong mảng users
                const idx = users.findIndex((u) => u.id === selectedUser.id);
                if (idx !== -1) {
                    users[idx].password = hashedPassword;
                    users[idx].updated_at = selectedUser.updated_at;
                }
            }

            // Hiển thị thành công
            Swal.fire({
                icon: "success",
                title: "Đổi mật khẩu thành công",
                html:
                    "Mật khẩu của tài khoản <strong>" +
                    (selectedUser ? selectedUser.email : "") +
                    '</strong> đã được cập nhật.<br><small style="color:#6b7280;">Bạn có thể đăng nhập bằng mật khẩu mới.</small>',
                confirmButtonColor: "var(--teal-600)",
                confirmButtonText: "Đến trang đăng nhập",
                allowOutsideClick: false,
                customClass: { popup: "rounded-2xl" },
            }).then(() => {
                // Giả lập chuyển đến /login
                window.location.href = "/login";
            });
        }, 1500);
    }

    // Enter trên input xác nhận mật khẩu
    document.addEventListener("DOMContentLoaded", function () {
        document
            .getElementById("fp-confirm-pw")
            .addEventListener("keydown", function (e) {
                if (e.key === "Enter") {
                    e.preventDefault();
                    handleChangePassword();
                }
            });

        // Clear lỗi khi input
        document
            .getElementById("fp-new-pw")
            .addEventListener("input", function () {
                clearFieldError("err-new-pw");
            });
        document
            .getElementById("fp-confirm-pw")
            .addEventListener("input", function () {
                clearFieldError("err-confirm-pw");
            });
        document
            .getElementById("fp-email")
            .addEventListener("input", function () {
                clearFieldError("err-email");
            });
    });
</script>
