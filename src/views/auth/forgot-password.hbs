<main
    class="relative z-10 flex-1 flex items-center justify-center py-8 sm:py-12 px-4 sm:px-6"
>
    <div
        class="max-w-5xl w-full grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center"
    >
        {{> auth/benefits}}

        <section
            class="w-full max-w-[480px] mx-auto lg:mx-0 lg:ml-auto"
            aria-label="Form quên mật khẩu"
        >
            <div
                class="form-card bg-white rounded-2xl shadow-lg shadow-gray-200/50 border border-gray-100 p-6 sm:p-8"
            >
                <div class="text-center mb-6">
                    <div
                        class="w-14 h-14 rounded-2xl mx-auto mb-4 flex items-center justify-center"
                        style="
                            background: linear-gradient(
                                135deg,
                                var(--teal-50),
                                var(--teal-100)
                            );
                            border: 1px solid rgba(0, 122, 122, 0.1);
                        "
                    >
                        <i
                            class="fa-solid fa-shield-halved text-xl"
                            style="color: var(--teal-600)"
                        ></i>
                    </div>

                    <h2 class="text-xl font-bold text-gray-900">
                        Quên mật khẩu
                    </h2>

                    <p class="text-sm text-gray-500 mt-1.5">
                        Nhập email đã đăng ký để nhận liên kết đặt lại mật khẩu.
                    </p>
                </div>

                {{> common/alert}}

                <form
                    id="auth-forgot-form"
                    method="post"
                    action="/forgot-password"
                    novalidate
                    autocomplete="off"
                    class="space-y-4"
                >
                    <div>
                        <label
                            for="auth-forgot-email"
                            class="block text-sm font-medium text-gray-700 mb-1.5"
                        >
                            Email tài khoản
                        </label>

                        <div class="relative">
                            <span
                                class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"
                            >
                                <i class="fa-solid fa-envelope"></i>
                            </span>

                            <input
                                type="email"
                                id="auth-forgot-email"
                                name="email"
                                placeholder="Nhập email đã đăng ký"
                                autocomplete="email"
                                class="input-teal w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800 placeholder-gray-400 outline-none transition-all"
                                aria-label="Email tài khoản"
                            />
                        </div>

                        <p
                            id="auth-forgot-email-error"
                            class="hidden mt-1.5 text-xs text-red-500"
                        ></p>
                    </div>

                    <div class="pt-2">
                        <button
                            type="submit"
                            id="auth-forgot-submit"
                            class="w-full py-3 rounded-xl text-white font-semibold text-sm flex items-center justify-center gap-2 transition-all active:scale-[0.98] hover:shadow-lg disabled:opacity-70 disabled:cursor-not-allowed"
                            style="
                                background: var(--teal-500);
                                box-shadow: 0 4px 14px rgba(0, 122, 122, 0.25);
                            "
                        >
                            <i
                                class="fa-solid fa-paper-plane text-sm"
                                id="auth-forgot-submit-icon"
                            ></i>
                            <span id="auth-forgot-submit-text">
                                Gửi liên kết đặt lại mật khẩu
                            </span>
                        </button>
                    </div>
                </form>

                <div class="mt-5 pt-5 border-t border-gray-100 text-center">
                    <a
                        href="/login"
                        class="link-teal text-sm font-medium inline-flex items-center gap-1.5"
                    >
                        <i class="fa-solid fa-arrow-left text-xs"></i>
                        Quay lại đăng nhập
                    </a>
                </div>
            </div>
        </section>
    </div>
</main>

<script>
    (function AuthForgotPasswordPage(window, document) {
        "use strict";

        var Auth = window.AuthCommon;

        if (!Auth) return;

        var selectors = {
            form: "auth-forgot-form",
            email: "auth-forgot-email",
            emailError: "auth-forgot-email-error",

            submit: "auth-forgot-submit",
            submitIcon: "auth-forgot-submit-icon",
            submitText: "auth-forgot-submit-text",
        };

        var config = {
            apiUrl: Auth.buildApiUrl("/auth/forgot-password"),
        };

        var state = {
            isSubmitting: false,
        };

        var elements = {};

        function init() {
            elements = Auth.mapElements(selectors);

            if (!elements.form || !elements.email || !elements.submit) {
                return;
            }

            bindEvents();
        }

        function bindEvents() {
            elements.form.addEventListener("submit", handleSubmit);

            elements.email.addEventListener("input", function () {
                Auth.clearFieldError(elements.email, elements.emailError);
            });
        }

        function validateForm() {
            var email = elements.email.value.trim();

            Auth.clearFieldError(elements.email, elements.emailError);

            if (!email) {
                Auth.setFieldError(
                    elements.email,
                    elements.emailError,
                    "Vui lòng nhập email tài khoản.",
                );

                Auth.notify(
                    "warning",
                    "Thiếu email",
                    "Vui lòng nhập email để nhận liên kết đặt lại mật khẩu.",
                    3500,
                );

                elements.email.focus();
                return false;
            }

            if (!Auth.isValidEmail(email)) {
                Auth.setFieldError(
                    elements.email,
                    elements.emailError,
                    "Email không đúng định dạng.",
                );

                Auth.notify(
                    "warning",
                    "Email không hợp lệ",
                    "Vui lòng nhập email đúng định dạng. Ví dụ: user@example.com.",
                    3500,
                );

                elements.email.focus();
                return false;
            }

            return true;
        }

        function setLoading(isLoading) {
            Auth.setButtonLoading(
                elements.submit,
                elements.submitIcon,
                elements.submitText,
                isLoading,
                {
                    defaultIcon: "fa-solid fa-paper-plane text-sm",
                    loadingText: "Đang gửi liên kết...",
                    defaultText: "Gửi liên kết đặt lại mật khẩu",
                },
            );
        }

        async function handleSubmit(event) {
            event.preventDefault();

            if (state.isSubmitting) return;
            if (!validateForm()) return;

            state.isSubmitting = true;
            setLoading(true);

            try {
                var result = await forgotPassword();

                Auth.notify(
                    "success",
                    "Yêu cầu đã được xử lý",
                    result.message ||
                        "Chúng tôi đã gửi liên kết đặt lại mật khẩu.",
                    4500,
                );
            } catch (error) {
                Auth.notify(
                    "error",
                    "Gửi yêu cầu thất bại",
                    error.message ||
                        "Không thể gửi liên kết đặt lại mật khẩu. Vui lòng thử lại.",
                    4000,
                );
            } finally {
                state.isSubmitting = false;
                setLoading(false);
            }
        }

        function forgotPassword() {
            return Auth.requestJson(
                config.apiUrl,
                {
                    method: "POST",
                    body: JSON.stringify({
                        email: elements.email.value.trim(),
                    }),
                },
                "Không thể gửi liên kết đặt lại mật khẩu.",
            );
        }

        init();
    })(window, document);
</script>
