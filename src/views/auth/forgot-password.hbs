<div class="w-full max-w-md rounded-3xl bg-white p-8 shadow-sm">
  <h1 class="text-2xl font-bold text-slate-900">Quên mật khẩu</h1>
  <p class="mt-1 text-sm text-slate-500">
    Nhập email để nhận hướng dẫn đặt lại mật khẩu.
  </p>

  {{> common/alert}}

  <form method="POST" action="/auth/forgot-password" class="mt-6 space-y-4">
    <div>
      <label class="mb-1 block text-sm font-medium">Email</label>
      <input
        name="email"
        type="email"
        class="w-full rounded-xl border px-4 py-3"
        placeholder="email@example.com"
      />
    </div>

    <button
      type="submit"
      class="w-full rounded-xl px-4 py-3 font-semibold text-white"
      style="background: var(--teal-600);"
    >
      Gửi yêu cầu
    </button>
  </form>

  <div class="mt-5 text-center text-sm">
    <a href="/auth/login" class="font-semibold" style="color: var(--teal-600);">
      Quay lại đăng nhập
    </a>
  </div>
</div>