<main
    class="relative z-10 flex-1 flex items-center justify-center py-8 sm:py-12 px-4 sm:px-6"
>
    <div
        class="max-w-5xl w-full grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center"
    >
        {{> auth/benefits}}

        <section
            class="w-full max-w-[480px] mx-auto lg:mx-0 lg:ml-auto"
            aria-label="Form đặt lại mật khẩu"
        >
            <div
                class="form-card bg-white rounded-2xl shadow-lg shadow-gray-200/50 border border-gray-100 p-6 sm:p-8"
            >
                <div class="text-center mb-6">
                    <div
                        class="w-14 h-14 rounded-2xl mx-auto mb-4 flex items-center justify-center"
                        style="
                            background: linear-gradient(
                                135deg,
                                var(--teal-50),
                                var(--teal-100)
                            );
                            border: 1px solid rgba(0, 122, 122, 0.1);
                        "
                    >
                        <i
                            class="fa-solid fa-lock-open text-xl"
                            style="color: var(--teal-600)"
                        ></i>
                    </div>

                    <h2 class="text-xl font-bold text-gray-900">
                        Đặt lại mật khẩu
                    </h2>

                    <p class="text-sm text-gray-500 mt-1.5">
                        Nhập mật khẩu mới để khôi phục quyền truy cập tài khoản.
                    </p>
                </div>

                {{> common/alert}}

                <div
                    id="auth-reset-token-warning"
                    class="hidden mb-4 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700"
                >
                    <div class="flex items-start gap-2">
                        <i class="fa-solid fa-triangle-exclamation mt-0.5"></i>
                        <p>
                            Liên kết đặt lại mật khẩu không hợp lệ hoặc thiếu
                            thông tin. Vui lòng yêu cầu lại liên kết mới.
                        </p>
                    </div>
                </div>

                <form
                    id="auth-reset-form"
                    method="post"
                    action="/reset-password"
                    novalidate
                    autocomplete="off"
                    class="space-y-4"
                >
                    <input type="hidden" id="auth-reset-email" name="email" />
                    <input type="hidden" id="auth-reset-token" name="token" />

                    <div>
                        <label
                            for="auth-reset-password"
                            class="block text-sm font-medium text-gray-700 mb-1.5"
                        >
                            Mật khẩu mới
                        </label>

                        <div class="relative">
                            <span
                                class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"
                            >
                                <i class="fa-solid fa-lock"></i>
                            </span>

                            <input
                                type="password"
                                id="auth-reset-password"
                                name="password"
                                placeholder="Nhập mật khẩu mới"
                                class="input-teal w-full pl-10 pr-11 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800 placeholder-gray-400 outline-none transition-all"
                                aria-label="Mật khẩu mới"
                            />

                            <button
                                type="button"
                                id="auth-reset-toggle-password"
                                class="absolute right-3 top-1/2 -translate-y-1/2 w-8 h-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-[var(--teal-600)] hover:bg-teal-50 transition"
                                aria-label="Hiển thị mật khẩu"
                            >
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>

                        <div class="mt-2">
                            <div class="strength-bar">
                                <div
                                    id="auth-reset-strength-fill"
                                    class="strength-fill"
                                    style="width: 0%; background: #e5e7eb"
                                ></div>
                            </div>

                            <p
                                id="auth-reset-strength-text"
                                class="text-xs mt-1 text-gray-400"
                            >
                                Nhập mật khẩu để kiểm tra độ mạnh
                            </p>
                        </div>

                        <p
                            id="auth-reset-password-error"
                            class="hidden mt-1.5 text-xs text-red-500"
                        ></p>
                    </div>

                    <div>
                        <label
                            for="auth-reset-confirm-password"
                            class="block text-sm font-medium text-gray-700 mb-1.5"
                        >
                            Xác nhận mật khẩu mới
                        </label>

                        <div class="relative">
                            <span
                                class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"
                            >
                                <i class="fa-solid fa-lock"></i>
                            </span>

                            <input
                                type="password"
                                id="auth-reset-confirm-password"
                                name="confirmPassword"
                                placeholder="Nhập lại mật khẩu mới"
                                class="input-teal w-full pl-10 pr-11 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-800 placeholder-gray-400 outline-none transition-all"
                                aria-label="Xác nhận mật khẩu mới"
                            />

                            <button
                                type="button"
                                id="auth-reset-toggle-confirm-password"
                                class="absolute right-3 top-1/2 -translate-y-1/2 w-8 h-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-[var(--teal-600)] hover:bg-teal-50 transition"
                                aria-label="Hiển thị xác nhận mật khẩu"
                            >
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>

                        <p
                            id="auth-reset-confirm-password-error"
                            class="hidden mt-1.5 text-xs text-red-500"
                        ></p>
                    </div>

                    <div class="pt-2">
                        <button
                            type="submit"
                            id="auth-reset-submit"
                            class="w-full py-3 rounded-xl text-white font-semibold text-sm flex items-center justify-center gap-2 transition-all active:scale-[0.98] hover:shadow-lg disabled:opacity-70 disabled:cursor-not-allowed"
                            style="
                                background: var(--teal-500);
                                box-shadow: 0 4px 14px rgba(0, 122, 122, 0.25);
                            "
                        >
                            <i
                                class="fa-solid fa-check text-sm"
                                id="auth-reset-submit-icon"
                            ></i>
                            <span id="auth-reset-submit-text">
                                Đặt lại mật khẩu
                            </span>
                        </button>
                    </div>
                </form>

                <div class="mt-5 pt-5 border-t border-gray-100 text-center">
                    <a
                        href="/login"
                        class="link-teal text-sm font-medium inline-flex items-center gap-1.5"
                    >
                        <i class="fa-solid fa-arrow-left text-xs"></i>
                        Quay lại đăng nhập
                    </a>
                </div>
            </div>
        </section>
    </div>
</main>

<script>
    (function AuthResetPasswordPage(window, document) {
        "use strict";

        var Auth = window.AuthCommon;

        if (!Auth) return;

        var selectors = {
            form: "auth-reset-form",
            email: "auth-reset-email",
            token: "auth-reset-token",
            password: "auth-reset-password",
            confirmPassword: "auth-reset-confirm-password",

            togglePassword: "auth-reset-toggle-password",
            toggleConfirmPassword: "auth-reset-toggle-confirm-password",

            submit: "auth-reset-submit",
            submitIcon: "auth-reset-submit-icon",
            submitText: "auth-reset-submit-text",

            passwordError: "auth-reset-password-error",
            confirmPasswordError: "auth-reset-confirm-password-error",

            strengthFill: "auth-reset-strength-fill",
            strengthText: "auth-reset-strength-text",

            tokenWarning: "auth-reset-token-warning",
        };

        var config = {
            apiUrl: Auth.buildApiUrl("/auth/reset-password"),
            redirectUrl: "/login",
            redirectDelay: 1800,
        };

        var state = {
            isSubmitting: false,
            hasValidLink: false,
        };

        var elements = {};

        function init() {
            elements = Auth.mapElements(selectors);

            if (
                !elements.form ||
                !elements.email ||
                !elements.token ||
                !elements.password ||
                !elements.confirmPassword ||
                !elements.submit
            ) {
                return;
            }

            loadResetParams();
            bindEvents();
            updatePasswordStrength();
        }

        function loadResetParams() {
            var params = new URLSearchParams(window.location.search);
            var email = params.get("email") || "";
            var token = params.get("token") || "";

            elements.email.value = email;
            elements.token.value = token;

            state.hasValidLink = !!email && !!token;

            if (!state.hasValidLink) {
                showTokenWarning();
                setFormDisabled(true);

                Auth.notify(
                    "warning",
                    "Liên kết không hợp lệ",
                    "Liên kết đặt lại mật khẩu thiếu email hoặc token.",
                    4000,
                );
            }
        }

        function bindEvents() {
            elements.form.addEventListener("submit", handleSubmit);

            if (elements.togglePassword) {
                elements.togglePassword.addEventListener("click", function () {
                    Auth.togglePassword(
                        elements.password,
                        elements.togglePassword,
                    );
                });
            }

            if (elements.toggleConfirmPassword) {
                elements.toggleConfirmPassword.addEventListener(
                    "click",
                    function () {
                        Auth.togglePassword(
                            elements.confirmPassword,
                            elements.toggleConfirmPassword,
                        );
                    },
                );
            }

            elements.password.addEventListener("input", function () {
                updatePasswordStrength();

                if (elements.password.value.length >= 6) {
                    Auth.clearFieldError(
                        elements.password,
                        elements.passwordError,
                    );
                }
            });

            elements.confirmPassword.addEventListener("input", function () {
                if (
                    elements.confirmPassword.value &&
                    elements.confirmPassword.value === elements.password.value
                ) {
                    Auth.setFieldValid(
                        elements.confirmPassword,
                        elements.confirmPasswordError,
                    );
                }
            });
        }

        function showTokenWarning() {
            if (elements.tokenWarning) {
                elements.tokenWarning.classList.remove("hidden");
            }
        }

        function setFormDisabled(isDisabled) {
            elements.password.disabled = isDisabled;
            elements.confirmPassword.disabled = isDisabled;
            elements.submit.disabled = isDisabled;
        }

        function clearAllErrors() {
            Auth.clearFieldError(elements.password, elements.passwordError);
            Auth.clearFieldError(
                elements.confirmPassword,
                elements.confirmPasswordError,
            );
        }

        function validateForm() {
            clearAllErrors();

            if (!state.hasValidLink) {
                Auth.notify(
                    "warning",
                    "Liên kết không hợp lệ",
                    "Vui lòng yêu cầu lại liên kết đặt lại mật khẩu.",
                    4000,
                );

                return false;
            }

            if (!elements.password.value) {
                Auth.setFieldError(
                    elements.password,
                    elements.passwordError,
                    "Vui lòng nhập mật khẩu mới.",
                );

                Auth.notify(
                    "warning",
                    "Thiếu mật khẩu",
                    "Vui lòng nhập mật khẩu mới.",
                    3500,
                );

                elements.password.focus();
                return false;
            }

            if (elements.password.value.length < 6) {
                Auth.setFieldError(
                    elements.password,
                    elements.passwordError,
                    "Mật khẩu phải có ít nhất 6 ký tự.",
                );

                Auth.notify(
                    "warning",
                    "Mật khẩu chưa hợp lệ",
                    "Mật khẩu phải có ít nhất 6 ký tự.",
                    3500,
                );

                elements.password.focus();
                return false;
            }

            if (!elements.confirmPassword.value) {
                Auth.setFieldError(
                    elements.confirmPassword,
                    elements.confirmPasswordError,
                    "Vui lòng nhập lại mật khẩu mới.",
                );

                Auth.notify(
                    "warning",
                    "Thiếu xác nhận mật khẩu",
                    "Vui lòng nhập lại mật khẩu mới.",
                    3500,
                );

                elements.confirmPassword.focus();
                return false;
            }

            if (elements.confirmPassword.value !== elements.password.value) {
                Auth.setFieldError(
                    elements.confirmPassword,
                    elements.confirmPasswordError,
                    "Mật khẩu xác nhận không khớp.",
                );

                Auth.notify(
                    "warning",
                    "Mật khẩu không khớp",
                    "Mật khẩu xác nhận phải trùng với mật khẩu mới.",
                    3500,
                );

                elements.confirmPassword.focus();
                return false;
            }

            return true;
        }

        function updatePasswordStrength() {
            Auth.updatePasswordStrength(
                elements.password.value,
                elements.strengthFill,
                elements.strengthText,
            );
        }

        function setLoading(isLoading) {
            Auth.setButtonLoading(
                elements.submit,
                elements.submitIcon,
                elements.submitText,
                isLoading,
                {
                    defaultIcon: "fa-solid fa-check text-sm",
                    loadingText: "Đang đặt lại mật khẩu...",
                    defaultText: "Đặt lại mật khẩu",
                },
            );
        }

        async function handleSubmit(event) {
            event.preventDefault();

            if (state.isSubmitting) return;
            if (!validateForm()) return;

            state.isSubmitting = true;
            setLoading(true);

            try {
                var result = await resetPassword();

                Auth.redirectWithNotice({
                    successTitle: "Đặt lại mật khẩu thành công",
                    successMessage:
                        result.message ||
                        "Vui lòng đăng nhập bằng mật khẩu mới.",
                    infoMessage: "Bạn sẽ được chuyển đến trang đăng nhập.",
                    redirectUrl: config.redirectUrl,
                    redirectDelay: config.redirectDelay,
                });
            } catch (error) {
                state.isSubmitting = false;
                setLoading(false);
                handleResetError(error);
            }
        }

        function resetPassword() {
            return Auth.requestJson(
                config.apiUrl,
                {
                    method: "POST",
                    body: JSON.stringify({
                        email: elements.email.value,
                        token: elements.token.value,
                        password: elements.password.value,
                        confirmPassword: elements.confirmPassword.value,
                    }),
                },
                "Đặt lại mật khẩu thất bại.",
            );
        }

        function handleResetError(error) {
            var message = error.message || "Đặt lại mật khẩu thất bại.";
            var lowerMessage = message.toLowerCase();

            if (
                lowerMessage.includes("mật khẩu xác nhận") ||
                lowerMessage.includes("không khớp")
            ) {
                Auth.setFieldError(
                    elements.confirmPassword,
                    elements.confirmPasswordError,
                    message,
                );

                elements.confirmPassword.focus();
            } else if (
                lowerMessage.includes("liên kết") ||
                lowerMessage.includes("token") ||
                lowerMessage.includes("hết hạn")
            ) {
                showTokenWarning();
            }

            Auth.notify("error", "Đặt lại mật khẩu thất bại", message, 4500);
        }

        init();
    })(window, document);
</script>
