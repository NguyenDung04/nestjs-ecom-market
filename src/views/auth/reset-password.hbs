<div class="rounded-3xl bg-white p-8 shadow-xl border border-gray-100">
  <div class="mb-8 text-center">
    <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-3xl bg-primary-50 text-primary-600">
      <i class="fa-solid fa-shield-keyhole text-2xl"></i>
    </div>

    <h1 class="text-2xl font-bold text-gray-900">
      Đặt lại mật khẩu
    </h1>

    <p class="mt-3 text-sm leading-6 text-gray-500">
      Nhập token đặt lại mật khẩu và mật khẩu mới để khôi phục quyền truy cập tài khoản.
    </p>
  </div>

  <form id="resetPasswordForm" class="space-y-5">
    <div>
      <label class="mb-2 block text-sm font-semibold text-gray-700">
        Token đặt lại mật khẩu
      </label>

      <div class="relative">
        <i class="fa-solid fa-key absolute left-4 top-1/2 -translate-y-1/2 text-sm text-gray-400"></i>

        <input
          id="token"
          name="token"
          type="text"
          required
          autocomplete="off"
          class="block w-full rounded-2xl border border-gray-300 py-3 pl-11 pr-4 text-sm focus:border-primary-500 focus:ring-primary-500"
          placeholder="Nhập token đặt lại mật khẩu"
        />
      </div>

      <p class="mt-2 text-xs text-gray-500">
        Token có thể lấy từ email hoặc response của API trong môi trường development.
      </p>
    </div>

    <div>
      <label class="mb-2 block text-sm font-semibold text-gray-700">
        Mật khẩu mới
      </label>

      <div class="relative">
        <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-sm text-gray-400"></i>

        <input
          id="password"
          name="password"
          type="password"
          required
          autocomplete="new-password"
          class="block w-full rounded-2xl border border-gray-300 py-3 pl-11 pr-12 text-sm focus:border-primary-500 focus:ring-primary-500"
          placeholder="Tối thiểu 6 ký tự"
        />

        <button
          type="button"
          onclick="togglePassword('password', 'passwordEye')"
          class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-700"
        >
          <i id="passwordEye" class="fa-regular fa-eye"></i>
        </button>
      </div>
    </div>

    <div>
      <label class="mb-2 block text-sm font-semibold text-gray-700">
        Nhập lại mật khẩu mới
      </label>

      <div class="relative">
        <i class="fa-solid fa-shield-halved absolute left-4 top-1/2 -translate-y-1/2 text-sm text-gray-400"></i>

        <input
          id="confirmPassword"
          name="confirmPassword"
          type="password"
          required
          autocomplete="new-password"
          class="block w-full rounded-2xl border border-gray-300 py-3 pl-11 pr-12 text-sm focus:border-primary-500 focus:ring-primary-500"
          placeholder="Nhập lại mật khẩu mới"
        />

        <button
          type="button"
          onclick="togglePassword('confirmPassword', 'confirmPasswordEye')"
          class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-700"
        >
          <i id="confirmPasswordEye" class="fa-regular fa-eye"></i>
        </button>
      </div>
    </div>

    <button
      id="resetPasswordButton"
      type="submit"
      class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-primary-600 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-primary-600/20 transition hover:bg-primary-700 active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-70"
    >
      <i class="fa-solid fa-rotate-right"></i>
      Đặt lại mật khẩu
    </button>
  </form>

  <div class="mt-6 rounded-2xl bg-gray-50 p-4 text-sm leading-6 text-gray-600">
    <div class="flex gap-3">
      <div class="mt-0.5 text-primary-600">
        <i class="fa-solid fa-circle-info"></i>
      </div>

      <p>
        Sau khi đặt lại mật khẩu thành công, bạn sẽ được chuyển về trang đăng nhập để sử dụng mật khẩu mới.
      </p>
    </div>
  </div>

  <div class="mt-6 flex items-center justify-between text-sm">
    <a href="/auth/forgot-password" class="font-semibold text-gray-700 hover:text-primary-600">
      <i class="fa-solid fa-arrow-left mr-1"></i>
      Lấy lại token
    </a>

    <a href="/auth/login" class="font-semibold text-primary-600 hover:text-primary-700">
      Quay lại đăng nhập
    </a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const resetPasswordForm = document.getElementById('resetPasswordForm');
    const resetPasswordButton = document.getElementById('resetPasswordButton');
    const tokenInput = document.getElementById('token');

    const urlParams = new URLSearchParams(window.location.search);
    const tokenFromUrl = urlParams.get('token');

    if (tokenFromUrl) {
      tokenInput.value = tokenFromUrl;
    }

    resetPasswordForm.addEventListener('submit', async function (event) {
      event.preventDefault();

      const token = document.getElementById('token').value.trim();
      const password = document.getElementById('password').value;
      const confirmPassword = document.getElementById('confirmPassword').value;

      if (password.length < 6) {
        if (typeof showToast === 'function') {
          showToast('Mật khẩu mới phải có tối thiểu 6 ký tự', 'error');
        } else {
          alert('Mật khẩu mới phải có tối thiểu 6 ký tự');
        }

        return;
      }

      if (password !== confirmPassword) {
        if (typeof showToast === 'function') {
          showToast('Mật khẩu nhập lại không khớp', 'error');
        } else {
          alert('Mật khẩu nhập lại không khớp');
        }

        return;
      }

      resetPasswordButton.disabled = true;
      resetPasswordButton.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang đặt lại mật khẩu...';

      try {
        const response = await fetch('/api/auth/reset-password', {
          method: 'POST',
          credentials: 'include',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            token,
            password,
          }),
        });

        const result = await response.json();

        console.log('RESET_PASSWORD_RESPONSE:', result);

        if (!response.ok || result.success === false) {
          const message = result.message || 'Đặt lại mật khẩu thất bại';

          if (typeof showToast === 'function') {
            showToast(message, 'error');
          } else {
            alert(message);
          }

          return;
        }

        if (typeof showToast === 'function') {
          showToast(result.message || 'Đặt lại mật khẩu thành công', 'success');
        } else {
          alert(result.message || 'Đặt lại mật khẩu thành công');
        }

        setTimeout(function () {
          window.location.href = '/auth/login';
        }, 900);
      } catch (error) {
        console.error(error);

        if (typeof showToast === 'function') {
          showToast('Không thể kết nối tới máy chủ', 'error');
        } else {
          alert('Không thể kết nối tới máy chủ');
        }
      } finally {
        resetPasswordButton.disabled = false;
        resetPasswordButton.innerHTML = '<i class="fa-solid fa-rotate-right"></i> Đặt lại mật khẩu';
      }
    });
  });

  function togglePassword(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon = document.getElementById(iconId);

    if (input.type === 'password') {
      input.type = 'text';
      icon.classList.remove('fa-eye');
      icon.classList.add('fa-eye-slash');
    } else {
      input.type = 'password';
      icon.classList.remove('fa-eye-slash');
      icon.classList.add('fa-eye');
    }
  }
</script>