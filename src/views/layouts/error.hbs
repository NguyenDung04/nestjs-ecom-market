<!doctype html>
<html lang="vi">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>{{statusCode}} - {{title}} | {{siteName}}</title>

        <script src="https://cdn.tailwindcss.com"></script>

        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
        />

        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        <style>
            :root {
                --teal-50: #adffff;
                --teal-100: #00f5f5;
                --teal-200: #00d2d2;
                --teal-300: #00b4b4;
                --teal-400: #009898;
                --teal-500: #007a7a;
                --teal-600: #006060;
                --teal-700: #004949;
                --teal-800: #003434;
                --teal-900: #001f1f;
                --teal-1000: #001818;
                --teal-1100: #000f0f;
            }

            * {
                scroll-behavior: smooth;
            }

            body {
                font-family:
                    Inter,
                    ui-sans-serif,
                    system-ui,
                    -apple-system,
                    BlinkMacSystemFont,
                    "Segoe UI",
                    sans-serif;
                color: #0f172a;
                background:
                    radial-gradient(
                        circle at top left,
                        rgba(0, 245, 245, 0.15),
                        transparent 34rem
                    ),
                    radial-gradient(
                        circle at right 12rem,
                        rgba(251, 146, 60, 0.1),
                        transparent 26rem
                    ),
                    linear-gradient(
                        180deg,
                        #f8ffff 0%,
                        #ffffff 44%,
                        #f8fafc 100%
                    );
            }

            .bg-teal-brand {
                background-color: var(--teal-500);
            }

            .bg-teal-brand:hover {
                background-color: var(--teal-700);
            }

            .border-teal-brand {
                border-color: rgba(0, 122, 122, 0.28);
            }

            .gradient-error {
                background: linear-gradient(
                    135deg,
                    var(--teal-300),
                    var(--teal-700),
                    var(--teal-900)
                );
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
            }

            .soft-card {
                background: rgba(255, 255, 255, 0.93);
                border: 1px solid rgba(15, 23, 42, 0.08);
                box-shadow: 0 24px 70px rgba(0, 73, 73, 0.12);
                backdrop-filter: blur(18px);
            }

            .nav-link {
                color: #334155;
                transition:
                    color 180ms ease,
                    background-color 180ms ease;
            }

            .nav-link:hover {
                color: var(--teal-600);
                background-color: rgba(0, 210, 210, 0.1);
            }

            .link-teal {
                color: #64748b;
                transition: color 180ms ease;
            }

            .link-teal:hover {
                color: var(--teal-600);
            }

            .lift-card {
                transition:
                    transform 180ms ease,
                    box-shadow 180ms ease,
                    border-color 180ms ease;
            }

            .lift-card:hover {
                transform: translateY(-3px);
                border-color: rgba(0, 152, 152, 0.34);
                box-shadow: 0 18px 42px rgba(0, 73, 73, 0.12);
            }

            .float-soft {
                animation: floatSoft 4.8s ease-in-out infinite;
            }

            .pulse-dot {
                animation: pulseDot 1.6s ease-in-out infinite;
            }

            @keyframes floatSoft {
                0%,
                100% {
                    transform: translateY(0);
                }

                50% {
                    transform: translateY(-10px);
                }
            }

            @keyframes pulseDot {
                0%,
                100% {
                    opacity: 0.45;
                    transform: scale(0.9);
                }

                50% {
                    opacity: 1;
                    transform: scale(1);
                }
            }

            .focus-ring:focus {
                outline: 3px solid rgba(0, 180, 180, 0.28);
                outline-offset: 2px;
            }

            @media (max-width: 640px) {
                .mobile-full {
                    width: 100%;
                }
            }
        </style>
    </head>

    <body class="min-h-screen antialiased">
        <header
            class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/90 backdrop-blur-xl"
        >
            <div
                class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8"
            >
                <a
                    href="/"
                    class="flex items-center gap-3"
                    aria-label="{{siteName}}"
                >
                    <span
                        class="flex h-10 w-10 items-center justify-center rounded-2xl bg-[var(--teal-500)] text-white shadow-lg shadow-teal-900/15"
                    >
                        <i class="fa-solid fa-bag-shopping"></i>
                    </span>

                    <span class="text-lg font-bold tracking-tight text-slate-950">
                        {{siteName}}
                    </span>
                </a>

                <nav
                    class="hidden items-center gap-2 md:flex"
                    aria-label="Điều hướng chính"
                >
                    <a
                        href="/"
                        class="nav-link rounded-full px-4 py-2 text-sm font-semibold"
                    >
                        Trang chủ
                    </a>

                    <a
                        href="/products"
                        class="nav-link rounded-full px-4 py-2 text-sm font-semibold"
                    >
                        Sản phẩm
                    </a>

                    <a
                        href="/categories"
                        class="nav-link rounded-full px-4 py-2 text-sm font-semibold"
                    >
                        Danh mục
                    </a>

                    <a
                        href="/contact"
                        class="nav-link rounded-full px-4 py-2 text-sm font-semibold"
                    >
                        Liên hệ
                    </a>

                    <a
                        href="/login"
                        class="rounded-full border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-[var(--teal-500)] hover:text-[var(--teal-600)]"
                    >
                        <i class="fa-regular fa-user mr-2"></i>
                        Đăng nhập
                    </a>
                </nav>

                <button
                    id="mobileMenuButton"
                    type="button"
                    class="focus-ring inline-flex h-11 w-11 items-center justify-center rounded-xl border border-slate-200 text-slate-700 md:hidden"
                    aria-label="Mở menu"
                >
                    <i class="fa-solid fa-bars"></i>
                </button>
            </div>

            <div
                id="mobileMenu"
                class="hidden border-t border-slate-200 bg-white px-4 py-3 md:hidden"
            >
                <div class="grid gap-2">
                    <a
                        href="/"
                        class="nav-link rounded-xl px-3 py-3 text-sm font-semibold"
                    >
                        Trang chủ
                    </a>

                    <a
                        href="/products"
                        class="nav-link rounded-xl px-3 py-3 text-sm font-semibold"
                    >
                        Sản phẩm
                    </a>

                    <a
                        href="/categories"
                        class="nav-link rounded-xl px-3 py-3 text-sm font-semibold"
                    >
                        Danh mục
                    </a>

                    <a
                        href="/contact"
                        class="nav-link rounded-xl px-3 py-3 text-sm font-semibold"
                    >
                        Liên hệ
                    </a>

                    <a
                        href="/login"
                        class="nav-link rounded-xl px-3 py-3 text-sm font-semibold"
                    >
                        Đăng nhập
                    </a>
                </div>
            </div>
        </header>

        {{{body}}}

        <footer
            class="relative z-10 border-t bg-white/70 backdrop-blur"
            style="border-color: rgba(0, 122, 122, 0.06)"
        >
            <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
                <div
                    class="flex flex-col items-center justify-between gap-4 sm:flex-row"
                >
                    <div class="flex items-center gap-2">
                        <div
                            class="flex h-7 w-7 items-center justify-center rounded-md bg-[var(--teal-500)]"
                        >
                            <i
                                class="fa-solid fa-bag-shopping text-xs text-white"
                            ></i>
                        </div>

                        <span class="text-sm font-bold text-[var(--teal-800)]">
                            {{siteName}}
                        </span>
                    </div>

                    <nav
                        class="flex items-center gap-4 sm:gap-6"
                        aria-label="Liên kết footer"
                    >
                        <a href="#" class="link-teal text-xs font-medium">
                            Chính sách bảo mật
                        </a>

                        <a href="#" class="link-teal text-xs font-medium">
                            Điều khoản sử dụng
                        </a>

                        <a href="/contact" class="link-teal text-xs font-medium">
                            Hỗ trợ
                        </a>
                    </nav>

                    <p class="text-xs text-gray-400">
                        &copy; 2026 {{siteName}}. All rights reserved.
                    </p>
                </div>
            </div>
        </footer>

        <script>
            const mobileMenuButton = document.getElementById("mobileMenuButton");
            const mobileMenu = document.getElementById("mobileMenu");

            if (mobileMenuButton && mobileMenu) {
                mobileMenuButton.addEventListener("click", () => {
                    mobileMenu.classList.toggle("hidden");
                });
            }
        </script>
    </body>
</html>