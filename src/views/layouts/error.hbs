<!doctype html>
<html lang="vi">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>{{statusCode}} - {{title}} | {{siteName}}</title>

        <script src="https://cdn.tailwindcss.com"></script>

        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
        />

        <style>
            :root {
                --teal-50: #adffff;
                --teal-100: #00f5f5;
                --teal-200: #00d2d2;
                --teal-300: #00b4b4;
                --teal-400: #009898;
                --teal-500: #007a7a;
                --teal-600: #006060;
                --teal-700: #004949;
                --teal-800: #003434;
                --teal-900: #001f1f;
                --teal-1000: #001818;
                --teal-1100: #000f0f;
            }

            * {
                scroll-behavior: smooth;
            }

            body {
                font-family:
                    Inter,
                    ui-sans-serif,
                    system-ui,
                    -apple-system,
                    BlinkMacSystemFont,
                    "Segoe UI",
                    sans-serif;
                color: #0f172a;
                background:
                    radial-gradient(
                        circle at top left,
                        rgba(0, 245, 245, 0.15),
                        transparent 34rem
                    ),
                    radial-gradient(
                        circle at right 12rem,
                        rgba(251, 146, 60, 0.1),
                        transparent 26rem
                    ),
                    linear-gradient(
                        180deg,
                        #f8ffff 0%,
                        #ffffff 44%,
                        #f8fafc 100%
                    );
            }

            .bg-teal-brand {
                background-color: var(--teal-500);
            }

            .bg-teal-brand:hover {
                background-color: var(--teal-700);
            }

            .border-teal-brand {
                border-color: rgba(0, 122, 122, 0.28);
            }

            .gradient-error {
                background: linear-gradient(
                    135deg,
                    var(--teal-300),
                    var(--teal-700),
                    var(--teal-900)
                );
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
            }

            .soft-card {
                background: rgba(255, 255, 255, 0.93);
                border: 1px solid rgba(15, 23, 42, 0.08);
                box-shadow: 0 24px 70px rgba(0, 73, 73, 0.12);
                backdrop-filter: blur(18px);
            }

            .nav-link {
                color: #334155;
                transition:
                    color 180ms ease,
                    background-color 180ms ease;
            }

            .nav-link:hover {
                color: var(--teal-600);
                background-color: rgba(0, 210, 210, 0.1);
            }

            .link-teal {
                color: #64748b;
                transition: color 180ms ease;
            }

            .link-teal:hover {
                color: var(--teal-600);
            }

            .lift-card {
                transition:
                    transform 180ms ease,
                    box-shadow 180ms ease,
                    border-color 180ms ease;
            }

            .lift-card:hover {
                transform: translateY(-3px);
                border-color: rgba(0, 152, 152, 0.34);
                box-shadow: 0 18px 42px rgba(0, 73, 73, 0.12);
            }

            .float-soft {
                animation: floatSoft 4.8s ease-in-out infinite;
            }

            .pulse-dot {
                animation: pulseDot 1.6s ease-in-out infinite;
            }

            @keyframes floatSoft {
                0%,
                100% {
                    transform: translateY(0);
                }

                50% {
                    transform: translateY(-10px);
                }
            }

            @keyframes pulseDot {
                0%,
                100% {
                    opacity: 0.45;
                    transform: scale(0.9);
                }

                50% {
                    opacity: 1;
                    transform: scale(1);
                }
            }

            .focus-ring:focus {
                outline: 3px solid rgba(0, 180, 180, 0.28);
                outline-offset: 2px;
            }

            .alert24-item {
                pointer-events: auto;
                animation: alert24In 0.25s ease-out both;
            }

            .alert24-item.alert24-removing {
                animation: alert24Out 0.22s ease-in both;
            }

            .alert24-progress {
                position: absolute;
                left: 0;
                bottom: 0;
                height: 3px;
                width: 100%;
                transform-origin: left;
                animation-name: alert24Progress;
                animation-timing-function: linear;
                animation-fill-mode: forwards;
            }

            @keyframes alert24In {
                from {
                    opacity: 0;
                    transform: translateX(24px);
                }

                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }

            @keyframes alert24Out {
                from {
                    opacity: 1;
                    transform: translateX(0);
                }

                to {
                    opacity: 0;
                    transform: translateX(24px);
                }
            }

            @keyframes alert24Progress {
                from {
                    transform: scaleX(1);
                }

                to {
                    transform: scaleX(0);
                }
            }

            @media (max-width: 640px) {
                .mobile-full {
                    width: 100%;
                }
            }

            @media (prefers-reduced-motion: reduce) {
                *,
                *::before,
                *::after {
                    animation-duration: 0.01ms !important;
                    transition-duration: 0.01ms !important;
                }
            }
        </style>

        <script>
            function escapeHtml24(value) {
                return String(value || "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            function showAlert24(type, title, message, duration, callback) {
                var container = document.getElementById("alert24-container");

                if (!container) {
                    console.warn("Missing #alert24-container");
                    return;
                }

                duration = duration || 3500;

                var variants = {
                    success: {
                        box: "bg-emerald-50 border-emerald-200",
                        iconBox: "bg-emerald-100 text-emerald-600",
                        title: "text-emerald-900",
                        message: "text-emerald-700",
                        progress: "bg-emerald-500",
                        icon: "fa-circle-check",
                    },
                    error: {
                        box: "bg-red-50 border-red-200",
                        iconBox: "bg-red-100 text-red-600",
                        title: "text-red-900",
                        message: "text-red-700",
                        progress: "bg-red-500",
                        icon: "fa-circle-xmark",
                    },
                    warning: {
                        box: "bg-amber-50 border-amber-200",
                        iconBox: "bg-amber-100 text-amber-600",
                        title: "text-amber-900",
                        message: "text-amber-700",
                        progress: "bg-amber-500",
                        icon: "fa-triangle-exclamation",
                    },
                    info: {
                        box: "bg-sky-50 border-sky-200",
                        iconBox: "bg-sky-100 text-sky-600",
                        title: "text-sky-900",
                        message: "text-sky-700",
                        progress: "bg-sky-500",
                        icon: "fa-circle-info",
                    },
                };

                var current = variants[type] || variants.info;

                var alert = document.createElement("div");
                alert.className =
                    "alert24-item relative overflow-hidden rounded-xl border px-4 py-3 shadow-lg " +
                    current.box;

                alert.innerHTML =
                    '<div class="flex items-start gap-3">' +
                    '<div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg ' +
                    current.iconBox +
                    '">' +
                    '<i class="fa-solid ' +
                    current.icon +
                    ' text-sm"></i>' +
                    "</div>" +
                    '<div class="min-w-0 flex-1">' +
                    '<p class="text-sm font-semibold ' +
                    current.title +
                    '">' +
                    escapeHtml24(title || "Thông báo") +
                    "</p>" +
                    '<p class="mt-0.5 text-xs leading-relaxed ' +
                    current.message +
                    '">' +
                    escapeHtml24(message || "") +
                    "</p>" +
                    "</div>" +
                    '<button type="button" class="alert24-close mt-0.5 shrink-0 text-gray-400 hover:text-gray-600" aria-label="Đóng thông báo">' +
                    '<i class="fa-solid fa-xmark text-sm"></i>' +
                    "</button>" +
                    "</div>" +
                    '<div class="alert24-progress ' +
                    current.progress +
                    '" style="animation-duration: ' +
                    duration +
                    'ms;"></div>';

                container.appendChild(alert);

                var isRemoved = false;
                var timer = setTimeout(removeAlert, duration);

                function removeAlert() {
                    if (isRemoved) return;

                    isRemoved = true;
                    clearTimeout(timer);
                    alert.classList.add("alert24-removing");

                    setTimeout(function () {
                        if (alert.parentNode) {
                            alert.parentNode.removeChild(alert);
                        }

                        if (typeof callback === "function") {
                            callback();
                        }
                    }, 220);
                }

                var closeButton = alert.querySelector(".alert24-close");

                if (closeButton) {
                    closeButton.addEventListener("click", removeAlert);
                }

                alert.addEventListener("mouseenter", function () {
                    clearTimeout(timer);

                    var progress = alert.querySelector(".alert24-progress");

                    if (progress) {
                        progress.style.animationPlayState = "paused";
                    }
                });

                alert.addEventListener("mouseleave", function () {
                    var progress = alert.querySelector(".alert24-progress");

                    if (progress) {
                        progress.style.animationPlayState = "running";
                    }

                    timer = setTimeout(removeAlert, 1200);
                });
            }
        </script>
    </head>

    <body class="min-h-screen antialiased">
        <div
            id="alert24-container"
            style="
                position: fixed;
                top: 20px;
                right: 20px;
                z-index: 999999;
                width: 360px;
                max-width: calc(100vw - 2rem);
            "
            class="space-y-3 pointer-events-none max-sm:left-4 max-sm:right-4 max-sm:w-auto"
        ></div>

        <header
            class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/90 backdrop-blur-xl"
        >
            <div
                class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8"
            >
                <a
                    href="/"
                    class="flex items-center gap-3"
                    aria-label="{{siteName}}"
                >
                    <span
                        class="flex h-10 w-10 items-center justify-center rounded-2xl bg-[var(--teal-500)] text-white shadow-lg shadow-teal-900/15"
                    >
                        <i class="fa-solid fa-bag-shopping"></i>
                    </span>

                    <span
                        class="text-lg font-bold tracking-tight text-slate-950"
                    >
                        {{siteName}}
                    </span>
                </a>

                <nav
                    class="hidden items-center gap-2 md:flex"
                    aria-label="Điều hướng chính"
                >
                    <a
                        href="/"
                        class="nav-link rounded-full px-4 py-2 text-sm font-semibold"
                    >
                        Trang chủ
                    </a>

                    <a
                        href="/products"
                        class="nav-link rounded-full px-4 py-2 text-sm font-semibold"
                    >
                        Sản phẩm
                    </a>

                    <a
                        href="/categories"
                        class="nav-link rounded-full px-4 py-2 text-sm font-semibold"
                    >
                        Danh mục
                    </a>

                    <a
                        href="/contact"
                        class="nav-link rounded-full px-4 py-2 text-sm font-semibold"
                    >
                        Liên hệ
                    </a>

                    <a
                        href="/login"
                        class="rounded-full border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-[var(--teal-500)] hover:text-[var(--teal-600)]"
                    >
                        <i class="fa-regular fa-user mr-2"></i>
                        Đăng nhập
                    </a>
                </nav>

                <button
                    id="mobileMenuButton"
                    type="button"
                    class="focus-ring inline-flex h-11 w-11 items-center justify-center rounded-xl border border-slate-200 text-slate-700 md:hidden"
                    aria-label="Mở menu"
                >
                    <i class="fa-solid fa-bars"></i>
                </button>
            </div>

            <div
                id="mobileMenu"
                class="hidden border-t border-slate-200 bg-white px-4 py-3 md:hidden"
            >
                <div class="grid gap-2">
                    <a
                        href="/"
                        class="nav-link rounded-xl px-3 py-3 text-sm font-semibold"
                    >
                        Trang chủ
                    </a>

                    <a
                        href="/products"
                        class="nav-link rounded-xl px-3 py-3 text-sm font-semibold"
                    >
                        Sản phẩm
                    </a>

                    <a
                        href="/categories"
                        class="nav-link rounded-xl px-3 py-3 text-sm font-semibold"
                    >
                        Danh mục
                    </a>

                    <a
                        href="/contact"
                        class="nav-link rounded-xl px-3 py-3 text-sm font-semibold"
                    >
                        Liên hệ
                    </a>

                    <a
                        href="/login"
                        class="nav-link rounded-xl px-3 py-3 text-sm font-semibold"
                    >
                        Đăng nhập
                    </a>
                </div>
            </div>
        </header>

        {{{body}}}

        <footer
            class="relative z-10 border-t bg-white/70 backdrop-blur"
            style="border-color: rgba(0, 122, 122, 0.06)"
        >
            <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
                <div
                    class="flex flex-col items-center justify-between gap-4 sm:flex-row"
                >
                    <div class="flex items-center gap-2">
                        <div
                            class="flex h-7 w-7 items-center justify-center rounded-md bg-[var(--teal-500)]"
                        >
                            <i
                                class="fa-solid fa-bag-shopping text-xs text-white"
                            ></i>
                        </div>

                        <span class="text-sm font-bold text-[var(--teal-800)]">
                            {{siteName}}
                        </span>
                    </div>

                    <nav
                        class="flex items-center gap-4 sm:gap-6"
                        aria-label="Liên kết footer"
                    >
                        <a href="#" class="link-teal text-xs font-medium">
                            Chính sách bảo mật
                        </a>

                        <a href="#" class="link-teal text-xs font-medium">
                            Điều khoản sử dụng
                        </a>

                        <a
                            href="/contact"
                            class="link-teal text-xs font-medium"
                        >
                            Hỗ trợ
                        </a>
                    </nav>

                    <p class="text-xs text-gray-400">
                        &copy; 2026 {{siteName}}. All rights reserved.
                    </p>
                </div>
            </div>
        </footer>

        <script>
            var mobileMenuButton = document.getElementById("mobileMenuButton");
            var mobileMenu = document.getElementById("mobileMenu");

            if (mobileMenuButton && mobileMenu) {
                mobileMenuButton.addEventListener("click", function () {
                    mobileMenu.classList.toggle("hidden");
                });
            }
        </script>
    </body>
</html>
