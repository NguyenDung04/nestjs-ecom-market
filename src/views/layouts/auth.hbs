<!doctype html>
<html lang="vi">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>{{title}} - {{siteName}}</title>

        <script src="https://cdn.tailwindcss.com"></script>

        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
        />

        <style>
            :root {
                --teal-50: #adffff;
                --teal-100: #00f5f5;
                --teal-200: #00d2d2;
                --teal-300: #00b4b4;
                --teal-400: #009898;
                --teal-500: #007a7a;
                --teal-600: #006060;
                --teal-700: #004949;
                --teal-800: #003434;
                --teal-900: #001f1f;
                --teal-1000: #001818;
                --teal-1100: #000f0f;
            }

            * {
                box-sizing: border-box;
            }

            body {
                font-family:
                    "Segoe UI",
                    system-ui,
                    -apple-system,
                    sans-serif;
                margin: 0;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                background: linear-gradient(
                    135deg,
                    #f0fdfa 0%,
                    #f8fffe 40%,
                    #ffffff 100%
                );
            }

            .bg-pattern {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                pointer-events: none;
                z-index: 0;
                overflow: hidden;
            }

            .bg-pattern::before {
                content: "";
                position: absolute;
                top: -50%;
                right: -30%;
                width: 800px;
                height: 800px;
                background: radial-gradient(
                    circle,
                    rgba(0, 122, 122, 0.04) 0%,
                    transparent 70%
                );
                border-radius: 50%;
                animation: floatBlob 20s ease-in-out infinite;
            }

            .bg-pattern::after {
                content: "";
                position: absolute;
                bottom: -40%;
                left: -20%;
                width: 600px;
                height: 600px;
                background: radial-gradient(
                    circle,
                    rgba(0, 210, 210, 0.05) 0%,
                    transparent 70%
                );
                border-radius: 50%;
                animation: floatBlob 15s ease-in-out infinite reverse;
            }

            @keyframes floatBlob {
                0%,
                100% {
                    transform: translate(0, 0) scale(1);
                }

                33% {
                    transform: translate(30px, -40px) scale(1.05);
                }

                66% {
                    transform: translate(-20px, 20px) scale(0.95);
                }
            }

            .custom-checkbox {
                appearance: none;
                -webkit-appearance: none;
                width: 18px;
                height: 18px;
                border: 2px solid #c4c4c4;
                border-radius: 4px;
                cursor: pointer;
                position: relative;
                transition: all 0.2s ease;
                flex-shrink: 0;
            }

            .custom-checkbox:checked {
                background: var(--teal-500);
                border-color: var(--teal-500);
            }

            .custom-checkbox:checked::after {
                content: "";
                position: absolute;
                top: 1px;
                left: 5px;
                width: 5px;
                height: 9px;
                border: solid white;
                border-width: 0 2px 2px 0;
                transform: rotate(45deg);
            }

            .custom-checkbox:focus-visible {
                outline: 2px solid var(--teal-300);
                outline-offset: 2px;
            }

            .input-teal:focus {
                border-color: var(--teal-400) !important;
                box-shadow: 0 0 0 3px rgba(0, 122, 122, 0.12);
            }

            .input-teal.input-error {
                border-color: #ef4444 !important;
                box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.08);
            }

            .input-teal.input-valid {
                border-color: var(--teal-400) !important;
            }

            .strength-bar {
                height: 4px;
                border-radius: 2px;
                background: #e5e7eb;
                overflow: hidden;
                transition: all 0.3s ease;
            }

            .strength-fill {
                height: 100%;
                border-radius: 2px;
                transition:
                    width 0.4s ease,
                    background 0.4s ease;
            }

            .form-card,
            .auth-login-card {
                animation: cardSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
            }

            @keyframes cardSlideUp {
                from {
                    opacity: 0;
                    transform: translateY(30px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .benefit-item {
                animation: benefitFade 0.5s ease both;
            }

            .benefit-item:nth-child(1) {
                animation-delay: 0.1s;
            }

            .benefit-item:nth-child(2) {
                animation-delay: 0.2s;
            }

            .benefit-item:nth-child(3) {
                animation-delay: 0.3s;
            }

            .benefit-item:nth-child(4) {
                animation-delay: 0.4s;
            }

            .benefit-item:nth-child(5) {
                animation-delay: 0.5s;
            }

            @keyframes benefitFade {
                from {
                    opacity: 0;
                    transform: translateX(-15px);
                }

                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }

            .btn-loading {
                pointer-events: none;
                opacity: 0.8;
            }

            .spinner {
                display: inline-block;
                width: 18px;
                height: 18px;
                border: 2px solid rgba(255, 255, 255, 0.3);
                border-top-color: white;
                border-radius: 50%;
                animation: spin 0.6s linear infinite;
            }

            @keyframes spin {
                to {
                    transform: rotate(360deg);
                }
            }

            .link-teal {
                color: var(--teal-600);
                text-decoration: none;
                transition: color 0.2s ease;
            }

            .link-teal:hover {
                color: var(--teal-800);
                text-decoration: underline;
            }

            .error-msg {
                color: #dc2626;
                font-size: 0.8rem;
                margin-top: 4px;
                display: none;
                align-items: center;
                gap: 4px;
            }

            .error-msg.show {
                display: flex;
            }

            ::-webkit-scrollbar {
                width: 6px;
            }

            ::-webkit-scrollbar-track {
                background: transparent;
            }

            ::-webkit-scrollbar-thumb {
                background: var(--teal-200);
                border-radius: 3px;
            }

            .toggle-pw {
                position: absolute;
                right: 12px;
                top: 50%;
                transform: translateY(-50%);
                background: none;
                border: none;
                color: #9ca3af;
                cursor: pointer;
                padding: 4px;
                transition: color 0.2s;
                font-size: 0.95rem;
            }

            .toggle-pw:hover {
                color: var(--teal-600);
            }

            .divider-line {
                height: 1px;
                flex: 1;
                background: linear-gradient(
                    90deg,
                    transparent,
                    #e5e7eb,
                    transparent
                );
            }

            .btn-google {
                border: 1px solid #e5e7eb;
                background: #ffffff;
                transition:
                    border-color 0.2s ease,
                    box-shadow 0.2s ease,
                    transform 0.2s ease;
            }

            .btn-google:hover {
                border-color: var(--teal-200);
                box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
                transform: translateY(-1px);
            }

            .alert24-item {
                pointer-events: auto;
                animation: alert24In 0.25s ease-out both;
            }

            .alert24-item.alert24-removing {
                animation: alert24Out 0.22s ease-in both;
            }

            .alert24-progress {
                position: absolute;
                left: 0;
                bottom: 0;
                height: 3px;
                width: 100%;
                transform-origin: left;
                animation-name: alert24Progress;
                animation-timing-function: linear;
                animation-fill-mode: forwards;
            }

            @keyframes alert24In {
                from {
                    opacity: 0;
                    transform: translateX(24px);
                }

                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }

            @keyframes alert24Out {
                from {
                    opacity: 1;
                    transform: translateX(0);
                }

                to {
                    opacity: 0;
                    transform: translateX(24px);
                }
            }

            @keyframes alert24Progress {
                from {
                    transform: scaleX(1);
                }

                to {
                    transform: scaleX(0);
                }
            }

            @media (prefers-reduced-motion: reduce) {
                *,
                *::before,
                *::after {
                    animation-duration: 0.01ms !important;
                    transition-duration: 0.01ms !important;
                }
            }
        </style>

        <script>
            function escapeHtml24(value) {
                return String(value || "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            function showAlert24(type, title, message, duration, callback) {
                var container = document.getElementById("alert24-container");

                if (!container) {
                    console.warn("Missing #alert24-container");
                    return;
                }

                duration = duration || 3500;

                var variants = {
                    success: {
                        box: "bg-emerald-50 border-emerald-200",
                        iconBox: "bg-emerald-100 text-emerald-600",
                        title: "text-emerald-900",
                        message: "text-emerald-700",
                        progress: "bg-emerald-500",
                        icon: "fa-circle-check",
                    },
                    error: {
                        box: "bg-red-50 border-red-200",
                        iconBox: "bg-red-100 text-red-600",
                        title: "text-red-900",
                        message: "text-red-700",
                        progress: "bg-red-500",
                        icon: "fa-circle-xmark",
                    },
                    warning: {
                        box: "bg-amber-50 border-amber-200",
                        iconBox: "bg-amber-100 text-amber-600",
                        title: "text-amber-900",
                        message: "text-amber-700",
                        progress: "bg-amber-500",
                        icon: "fa-triangle-exclamation",
                    },
                    info: {
                        box: "bg-sky-50 border-sky-200",
                        iconBox: "bg-sky-100 text-sky-600",
                        title: "text-sky-900",
                        message: "text-sky-700",
                        progress: "bg-sky-500",
                        icon: "fa-circle-info",
                    },
                };

                var current = variants[type] || variants.info;

                var alert = document.createElement("div");
                alert.className =
                    "alert24-item relative overflow-hidden rounded-xl border px-4 py-3 shadow-lg " +
                    current.box;

                alert.innerHTML =
                    '<div class="flex items-start gap-3">' +
                    '<div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg ' +
                    current.iconBox +
                    '">' +
                    '<i class="fa-solid ' +
                    current.icon +
                    ' text-sm"></i>' +
                    "</div>" +
                    '<div class="min-w-0 flex-1">' +
                    '<p class="text-sm font-semibold ' +
                    current.title +
                    '">' +
                    escapeHtml24(title || "Thông báo") +
                    "</p>" +
                    '<p class="mt-0.5 text-xs leading-relaxed ' +
                    current.message +
                    '">' +
                    escapeHtml24(message || "") +
                    "</p>" +
                    "</div>" +
                    '<button type="button" class="alert24-close mt-0.5 shrink-0 text-gray-400 hover:text-gray-600" aria-label="Đóng thông báo">' +
                    '<i class="fa-solid fa-xmark text-sm"></i>' +
                    "</button>" +
                    "</div>" +
                    '<div class="alert24-progress ' +
                    current.progress +
                    '" style="animation-duration: ' +
                    duration +
                    'ms;"></div>';

                container.appendChild(alert);

                var isRemoved = false;
                var timer = setTimeout(removeAlert, duration);

                function removeAlert() {
                    if (isRemoved) return;

                    isRemoved = true;
                    clearTimeout(timer);
                    alert.classList.add("alert24-removing");

                    setTimeout(function () {
                        if (alert.parentNode) {
                            alert.parentNode.removeChild(alert);
                        }

                        if (typeof callback === "function") {
                            callback();
                        }
                    }, 220);
                }

                var closeButton = alert.querySelector(".alert24-close");

                if (closeButton) {
                    closeButton.addEventListener("click", removeAlert);
                }

                alert.addEventListener("mouseenter", function () {
                    clearTimeout(timer);

                    var progress = alert.querySelector(".alert24-progress");
                    if (progress) {
                        progress.style.animationPlayState = "paused";
                    }
                });

                alert.addEventListener("mouseleave", function () {
                    var progress = alert.querySelector(".alert24-progress");

                    if (progress) {
                        progress.style.animationPlayState = "running";
                    }

                    timer = setTimeout(removeAlert, 1200);
                });
            }
        </script>
        <script>
            (function AuthCommon(window, document) {
                "use strict";

                var appConfig = window.APP_CONFIG || {};

                function getApiBaseUrl() {
                    return (
                        appConfig.APP_URL_API || window.location.origin + "/api"
                    );
                }

                function buildApiUrl(path) {
                    return getApiBaseUrl() + path;
                }

                function mapElements(selectors) {
                    var elements = {};

                    Object.keys(selectors).forEach(function (key) {
                        elements[key] = document.getElementById(selectors[key]);
                    });

                    return elements;
                }

                function notify(type, title, message, duration, callback) {
                    if (typeof window.showAlert24 === "function") {
                        window.showAlert24(
                            type,
                            title,
                            message,
                            duration || 3500,
                            callback,
                        );
                        return;
                    }

                    if (typeof Swal !== "undefined") {
                        Swal.fire({
                            title: title || "Thông báo",
                            text: message || "",
                            icon:
                                type === "error"
                                    ? "error"
                                    : type === "warning"
                                      ? "warning"
                                      : type === "success"
                                        ? "success"
                                        : "info",
                            confirmButtonColor: "#0d9488",
                        }).then(function () {
                            if (typeof callback === "function") {
                                callback();
                            }
                        });

                        return;
                    }

                    console[type === "error" ? "error" : "log"](
                        (title ? title + ": " : "") + (message || ""),
                    );

                    if (typeof callback === "function") {
                        callback();
                    }
                }

                function setFieldError(input, errorElement, message) {
                    if (!input || !errorElement) return;

                    errorElement.textContent = message || "";
                    errorElement.classList.toggle("hidden", !message);

                    input.classList.toggle("input-error", !!message);

                    if (message) {
                        input.classList.remove("input-valid");
                    }
                }

                function clearFieldError(input, errorElement) {
                    setFieldError(input, errorElement, "");
                }

                function setFieldValid(input, errorElement) {
                    if (!input) return;

                    input.classList.remove("input-error");
                    input.classList.add("input-valid");

                    if (errorElement) {
                        errorElement.textContent = "";
                        errorElement.classList.add("hidden");
                    }
                }

                function setTextError(errorElement, message) {
                    if (!errorElement) return;

                    errorElement.textContent = message || "";
                    errorElement.classList.toggle("hidden", !message);
                }

                function clearTextError(errorElement) {
                    setTextError(errorElement, "");
                }

                function isValidEmail(email) {
                    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
                }

                function isValidVietnamesePhone(phone) {
                    return /^(0[35789])[0-9]{8}$/.test(phone);
                }

                function onlyDigits(value) {
                    return String(value || "").replace(/\D/g, "");
                }

                function calculatePasswordScore(password) {
                    var score = 0;

                    if (!password) return score;

                    if (password.length >= 6) score++;
                    if (password.length >= 10) score++;
                    if (/[A-Z]/.test(password)) score++;
                    if (/[a-z]/.test(password)) score++;
                    if (/[0-9]/.test(password)) score++;
                    if (/[^A-Za-z0-9]/.test(password)) score++;

                    return score;
                }

                function getPasswordStrength(password) {
                    var score = calculatePasswordScore(password);

                    if (!password) {
                        return {
                            label: "Nhập mật khẩu để kiểm tra độ mạnh",
                            color: "#9ca3af",
                            width: "0%",
                        };
                    }

                    if (score <= 2) {
                        return {
                            label: "Mật khẩu yếu",
                            color: "#ef4444",
                            width: "33%",
                        };
                    }

                    if (score <= 4) {
                        return {
                            label: "Mật khẩu trung bình",
                            color: "#f59e0b",
                            width: "66%",
                        };
                    }

                    return {
                        label: "Mật khẩu mạnh",
                        color: "var(--teal-500)",
                        width: "100%",
                    };
                }

                function updatePasswordStrength(
                    password,
                    fillElement,
                    textElement,
                ) {
                    var result = getPasswordStrength(password);

                    if (fillElement) {
                        fillElement.style.width = result.width;
                        fillElement.style.background = result.color;
                    }

                    if (textElement) {
                        textElement.textContent = result.label;
                        textElement.style.color = result.color;
                    }
                }

                function togglePassword(input, button) {
                    if (!input || !button) return;

                    var icon = button.querySelector("i");
                    var isHidden = input.type === "password";

                    input.type = isHidden ? "text" : "password";

                    if (icon) {
                        icon.className = isHidden
                            ? "fa-solid fa-eye-slash"
                            : "fa-solid fa-eye";
                    }

                    button.setAttribute(
                        "aria-label",
                        isHidden ? "Ẩn mật khẩu" : "Hiển thị mật khẩu",
                    );
                }

                function setButtonLoading(
                    button,
                    icon,
                    text,
                    isLoading,
                    options,
                ) {
                    if (!button) return;

                    var loadingIcon =
                        options.loadingIcon ||
                        "fa-solid fa-spinner fa-spin text-sm";
                    var defaultIcon = options.defaultIcon || "";
                    var loadingText = options.loadingText || "Đang xử lý...";
                    var defaultText = options.defaultText || "Xác nhận";

                    button.disabled = isLoading;

                    if (icon) {
                        icon.className = isLoading ? loadingIcon : defaultIcon;
                    }

                    if (text) {
                        text.textContent = isLoading
                            ? loadingText
                            : defaultText;
                    }
                }

                async function readJsonResponse(response) {
                    try {
                        return await response.json();
                    } catch (error) {
                        return null;
                    }
                }

                async function requestJson(url, options, fallbackMessage) {
                    var response = await fetch(url, {
                        credentials: "include",
                        headers: {
                            "Content-Type": "application/json",
                        },
                        ...(options || {}),
                    });

                    var result = await readJsonResponse(response);

                    if (!response.ok || !result || result.success === false) {
                        throw new Error(
                            (result && result.message) ||
                                fallbackMessage ||
                                "Yêu cầu xử lý thất bại.",
                        );
                    }

                    return result;
                }

                function redirectWithNotice(options) {
                    notify(
                        options.successType || "success",
                        options.successTitle || "Thành công",
                        options.successMessage || "Thao tác thành công.",
                        options.successDuration || 2200,
                    );

                    if (options.infoMessage) {
                        window.setTimeout(function () {
                            notify(
                                "info",
                                options.infoTitle || "Đang chuyển hướng",
                                options.infoMessage,
                                options.infoDuration || 1200,
                            );
                        }, options.infoDelay || 700);
                    }

                    window.setTimeout(function () {
                        window.location.href = options.redirectUrl || "/";
                    }, options.redirectDelay || 1800);
                }

                window.AuthCommon = {
                    getApiBaseUrl: getApiBaseUrl,
                    buildApiUrl: buildApiUrl,
                    mapElements: mapElements,

                    notify: notify,

                    setFieldError: setFieldError,
                    clearFieldError: clearFieldError,
                    setFieldValid: setFieldValid,
                    setTextError: setTextError,
                    clearTextError: clearTextError,

                    isValidEmail: isValidEmail,
                    isValidVietnamesePhone: isValidVietnamesePhone,
                    onlyDigits: onlyDigits,

                    calculatePasswordScore: calculatePasswordScore,
                    getPasswordStrength: getPasswordStrength,
                    updatePasswordStrength: updatePasswordStrength,

                    togglePassword: togglePassword,
                    setButtonLoading: setButtonLoading,

                    readJsonResponse: readJsonResponse,
                    requestJson: requestJson,

                    redirectWithNotice: redirectWithNotice,
                };
            })(window, document);
        </script>
    </head>

    <body>
        <div
            id="alert24-container"
            style="
                position: fixed;
                top: 20px;
                right: 20px;
                z-index: 999999;
                width: 360px;
                max-width: calc(100vw - 2rem);
            "
            class="space-y-3 pointer-events-none max-sm:left-4 max-sm:right-4 max-sm:w-auto"
        ></div>

        <div class="bg-pattern" aria-hidden="true"></div>

        {{> auth/header}}

        <main class="relative z-10 flex-1">{{{body}}}</main>

        {{> auth/footer}}
    </body>
</html>
