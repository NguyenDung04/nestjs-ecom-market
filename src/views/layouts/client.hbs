<!doctype html>
<html lang="vi">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>{{title}}</title>

        <script src="https://cdn.tailwindcss.com"></script>

        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
        />

        <style>
            :root {
                --teal-50: #adffff;
                --teal-100: #00f5f5;
                --teal-200: #00d2d2;
                --teal-300: #00b4b4;
                --teal-400: #009898;
                --teal-500: #007a7a;
                --teal-600: #006060;
                --teal-700: #004949;
                --teal-800: #003434;
                --teal-900: #001f1f;
                --teal-1000: #001818;
                --teal-1100: #000f0f;
            }

            * {
                box-sizing: border-box;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
                color: #334155;
                background: #f8fafb;
            }

            .badge-new {
                background: linear-gradient(
                    135deg,
                    var(--teal-400),
                    var(--teal-600)
                );
                color: #fff;
            }
            .badge-hot {
                background: linear-gradient(135deg, #f97316, #ef4444);
                color: #fff;
            }
            .badge-sale {
                background: linear-gradient(135deg, #ef4444, #dc2626);
                color: #fff;
            }
            .badge-out {
                background: #94a3b8;
                color: #fff;
            }

            .product-card {
                transition:
                    transform 0.25s ease,
                    box-shadow 0.25s ease;
            }
            .product-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 12px 32px rgba(0, 122, 122, 0.13);
            }

            .category-card {
                transition:
                    transform 0.25s ease,
                    box-shadow 0.25s ease;
            }
            .category-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 24px rgba(0, 122, 122, 0.12);
            }

            .btn-teal {
                background: var(--teal-500);
                color: #fff;
                transition:
                    background 0.2s,
                    transform 0.15s;
            }
            .btn-teal:hover {
                background: var(--teal-700);
                transform: translateY(-1px);
            }

            .btn-outline-teal {
                border: 2px solid var(--teal-500);
                color: var(--teal-500);
                transition: all 0.2s;
            }
            .btn-outline-teal:hover {
                background: var(--teal-500);
                color: #fff;
            }

            .search-dropdown {
                max-height: 380px;
                overflow-y: auto;
            }
            .search-dropdown::-webkit-scrollbar {
                width: 5px;
            }
            .search-dropdown::-webkit-scrollbar-thumb {
                background: var(--teal-300);
                border-radius: 8px;
            }

            .mobile-menu {
                transform: translateX(-100%);
                transition: transform 0.3s ease;
            }
            .mobile-menu.active {
                transform: translateX(0);
            }
            .mobile-overlay {
                opacity: 0;
                pointer-events: none;
                transition: opacity 0.3s ease;
            }
            .mobile-overlay.active {
                opacity: 1;
                pointer-events: auto;
            }

            .banner-gradient {
                background: linear-gradient(
                    135deg,
                    var(--teal-800) 0%,
                    var(--teal-600) 50%,
                    var(--teal-400) 100%
                );
            }

            .section-title {
                position: relative;
                display: inline-block;
            }
            .section-title::after {
                content: "";
                position: absolute;
                bottom: -6px;
                left: 0;
                width: 50px;
                height: 3px;
                background: var(--teal-500);
                border-radius: 2px;
            }

            .hero-pattern {
                background-image:
                    radial-gradient(
                        circle at 20% 50%,
                        rgba(173, 255, 255, 0.15) 0%,
                        transparent 50%
                    ),
                    radial-gradient(
                        circle at 80% 20%,
                        rgba(0, 212, 212, 0.1) 0%,
                        transparent 40%
                    ),
                    radial-gradient(
                        circle at 60% 80%,
                        rgba(0, 180, 180, 0.08) 0%,
                        transparent 40%
                    );
            }

            .cart-badge {
                animation: pulse-badge 0.3s ease;
            }
            @keyframes pulse-badge {
                0% {
                    transform: scale(1);
                }
                50% {
                    transform: scale(1.4);
                }
                100% {
                    transform: scale(1);
                }
            }

            @keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
            .animate-fade-in-up {
                animation: fadeInUp 0.5s ease forwards;
            }

            .footer-link {
                transition:
                    color 0.2s,
                    padding-left 0.2s;
            }
            .footer-link:hover {
                color: var(--teal-100);
                padding-left: 4px;
            }

            .alert24-item {
                pointer-events: auto;
                animation: alert24In 0.25s ease-out both;
            }

            .alert24-item.alert24-removing {
                animation: alert24Out 0.22s ease-in both;
            }

            .alert24-progress {
                position: absolute;
                left: 0;
                bottom: 0;
                height: 3px;
                width: 100%;
                transform-origin: left;
                animation-name: alert24Progress;
                animation-timing-function: linear;
                animation-fill-mode: forwards;
            }

            @keyframes alert24In {
                from {
                    opacity: 0;
                    transform: translateX(24px);
                }
                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }

            @keyframes alert24Out {
                from {
                    opacity: 1;
                    transform: translateX(0);
                }
                to {
                    opacity: 0;
                    transform: translateX(24px);
                }
            }

            @keyframes alert24Progress {
                from {
                    transform: scaleX(1);
                }
                to {
                    transform: scaleX(0);
                }
            }

            @media (prefers-reduced-motion: reduce) {
                *,
                *::before,
                *::after {
                    animation-duration: 0.01ms !important;
                    transition-duration: 0.01ms !important;
                }
            }
        </style>

        <script>
            tailwind.config = {
                theme: {
                    extend: {
                        colors: {
                            teal: {
                                50: "#adffff",
                                100: "#00f5f5",
                                200: "#00d2d2",
                                300: "#00b4b4",
                                400: "#009898",
                                500: "#007a7a",
                                600: "#006060",
                                700: "#004949",
                                800: "#003434",
                                900: "#001f1f",
                                1000: "#001818",
                                1100: "#000f0f",
                            },
                        },
                    },
                },
            };

            function escapeHtml24(value) {
                return String(value || "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            function showAlert24(type, title, message, duration, callback) {
                var container = document.getElementById("alert24-container");

                if (!container) {
                    console.warn("Missing #alert24-container");
                    return;
                }

                duration = duration || 3500;

                var variants = {
                    success: {
                        box: "bg-emerald-50 border-emerald-200",
                        iconBox: "bg-emerald-100 text-emerald-600",
                        title: "text-emerald-900",
                        message: "text-emerald-700",
                        progress: "bg-emerald-500",
                        icon: "fa-circle-check",
                    },
                    error: {
                        box: "bg-red-50 border-red-200",
                        iconBox: "bg-red-100 text-red-600",
                        title: "text-red-900",
                        message: "text-red-700",
                        progress: "bg-red-500",
                        icon: "fa-circle-xmark",
                    },
                    warning: {
                        box: "bg-amber-50 border-amber-200",
                        iconBox: "bg-amber-100 text-amber-600",
                        title: "text-amber-900",
                        message: "text-amber-700",
                        progress: "bg-amber-500",
                        icon: "fa-triangle-exclamation",
                    },
                    info: {
                        box: "bg-sky-50 border-sky-200",
                        iconBox: "bg-sky-100 text-sky-600",
                        title: "text-sky-900",
                        message: "text-sky-700",
                        progress: "bg-sky-500",
                        icon: "fa-circle-info",
                    },
                };

                var current = variants[type] || variants.info;

                var alert = document.createElement("div");
                alert.className =
                    "alert24-item relative overflow-hidden rounded-xl border px-4 py-3 shadow-lg " +
                    current.box;

                alert.innerHTML =
                    '<div class="flex items-start gap-3">' +
                    '<div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg ' +
                    current.iconBox +
                    '">' +
                    '<i class="fa-solid ' +
                    current.icon +
                    ' text-sm"></i>' +
                    "</div>" +
                    '<div class="min-w-0 flex-1">' +
                    '<p class="text-sm font-semibold ' +
                    current.title +
                    '">' +
                    escapeHtml24(title || "Thông báo") +
                    "</p>" +
                    '<p class="mt-0.5 text-xs leading-relaxed ' +
                    current.message +
                    '">' +
                    escapeHtml24(message || "") +
                    "</p>" +
                    "</div>" +
                    '<button type="button" class="alert24-close mt-0.5 shrink-0 text-gray-400 hover:text-gray-600" aria-label="Đóng thông báo">' +
                    '<i class="fa-solid fa-xmark text-sm"></i>' +
                    "</button>" +
                    "</div>" +
                    '<div class="alert24-progress ' +
                    current.progress +
                    '" style="animation-duration: ' +
                    duration +
                    'ms;"></div>';

                container.appendChild(alert);

                var isRemoved = false;
                var timer = setTimeout(removeAlert, duration);

                function removeAlert() {
                    if (isRemoved) return;

                    isRemoved = true;
                    clearTimeout(timer);
                    alert.classList.add("alert24-removing");

                    setTimeout(function () {
                        if (alert.parentNode) {
                            alert.parentNode.removeChild(alert);
                        }
                        if (typeof callback === "function") {
                            callback();
                        }
                    }, 220);
                }

                var closeButton = alert.querySelector(".alert24-close");
                if (closeButton) {
                    closeButton.addEventListener("click", removeAlert);
                }

                alert.addEventListener("mouseenter", function () {
                    clearTimeout(timer);
                    var progress = alert.querySelector(".alert24-progress");
                    if (progress) {
                        progress.style.animationPlayState = "paused";
                    }
                });

                alert.addEventListener("mouseleave", function () {
                    var progress = alert.querySelector(".alert24-progress");
                    if (progress) {
                        progress.style.animationPlayState = "running";
                    }
                    timer = setTimeout(removeAlert, 1200);
                });
            }
        </script>
    </head>

    <body class="min-h-screen">
        <div
            id="alert24-container"
            style="
                position: fixed;
                top: 20px;
                right: 20px;
                z-index: 999999;
                width: 360px;
                max-width: calc(100vw - 2rem);
            "
            class="space-y-3 pointer-events-none max-sm:left-4 max-sm:right-4 max-sm:w-auto"
        ></div>

        <!-- Mobile menu overlay -->
        <div
            id="mobileOverlay"
            class="mobile-overlay fixed inset-0 bg-black/40 z-50"
        ></div>

        {{> client/header}} 
        {{> client/aside}}
        {{{body}}} 
        {{> client/footer}}
    </body>
</html>
