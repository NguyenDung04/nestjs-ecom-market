<div class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-gray-300 bg-white p-10 text-center">
  <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-gray-100 text-gray-500">
    <i class="fa-regular fa-folder-open text-2xl"></i>
  </div>

  <h3 class="text-base font-semibold text-gray-900">
    {{#if title}}{{title}}{{else}}Không có dữ liệu{{/if}}
  </h3>

  <p class="mt-1 text-sm text-gray-500">
    {{#if description}}{{description}}{{else}}Hiện chưa có dữ liệu để hiển thị.{{/if}}
  </p>
</div>