<script>
    document.addEventListener('DOMContentLoaded', function () {
        const currentPath = window.location.pathname;
        const sidebarNav = document.getElementById('admin-sidebar-nav');
        const sidebarLinks = document.querySelectorAll('.admin-sidebar-link');

        let activeLink = null;

        sidebarLinks.forEach(function (link) {
            const linkPath = new URL(link.href).pathname;
            const icon = link.querySelector('i');

            link.classList.remove(
                'bg-kigen-50',
                'bg-kigen-100',
                'text-kigen-700',
                'font-semibold',
                'shadow-sm',
                'border',
                'border-kigen-100',
                'ring-1',
                'ring-kigen-100'
            );

            link.classList.add(
                'text-slate-600',
                'font-medium',
                'hover:bg-slate-100'
            );

            if (icon) {
                icon.classList.remove('text-kigen-600');
                icon.classList.add('text-slate-500');
            }

            const isAdminHome =
                currentPath === '/admin' && linkPath === '/admin/dashboard';

            const isCurrentPath =
                currentPath === linkPath || currentPath.startsWith(linkPath + '/');

            if (isAdminHome || isCurrentPath) {
                activeLink = link;

                link.classList.remove(
                    'text-slate-600',
                    'font-medium',
                    'hover:bg-slate-100'
                );

                link.classList.add(
                    'bg-kigen-50',
                    'text-kigen-700',
                    'font-semibold',
                    'shadow-sm',
                    'border',
                    'border-kigen-100',
                    'ring-1',
                    'ring-kigen-100'
                );

                if (icon) {
                    icon.classList.remove('text-slate-500');
                    icon.classList.add('text-kigen-600');
                }
            }
        });

        if (activeLink && sidebarNav) {
            setTimeout(function () {
                activeLink.scrollIntoView({
                    behavior: 'smooth',
                    block: 'center'
                });
            }, 120);
        }
    });
</script>