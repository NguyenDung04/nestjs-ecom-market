<header
    class="sticky top-0 z-20 flex h-16 items-center justify-between border-b border-slate-200 bg-white/90 px-4 backdrop-blur lg:px-8"
>
    <div class="flex items-center gap-3">
        <button
            id="toggleSidebar"
            type="button"
            class="grid h-10 w-10 place-items-center rounded-xl border border-slate-200 text-slate-600 hover:bg-slate-100"
            title="Thu gọn sidebar"
        >
            <i class="fa-solid fa-bars"></i>
        </button>

        <div
            class="hidden h-10 w-80 items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 md:flex"
        >
            <i class="fa-solid fa-magnifying-glass text-slate-400"></i>

            <input
                id="headerSearch"
                class="w-full bg-transparent text-sm outline-none"
                type="search"
                placeholder="Tìm nhanh ..."
                autocomplete="off"
            />
        </div>
    </div>

    <div class="flex items-center gap-3">
        <button
            id="notifyBtn"
            type="button"
            class="relative grid h-10 w-10 place-items-center rounded-xl border border-slate-200 text-slate-600 hover:bg-slate-100"
            title="Thông báo"
        >
            <i class="fa-regular fa-bell"></i>

            <span
                class="absolute right-2 top-2 h-2.5 w-2.5 rounded-full bg-rose-500"
            ></span>
        </button>

        <div class="relative">
            <button
                id="accountBtn"
                type="button"
                class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-2 py-1.5 hover:bg-slate-50"
            >
                <img
                    class="h-9 w-9 rounded-xl object-cover"
                    src="{{authAvatar}}"
                    alt="Admin avatar"
                />

                <div class="hidden text-left sm:block">
                    <p class="max-w-36 truncate text-sm font-semibold text-slate-700">
                        {{authName}}
                    </p>

                    <p class="text-xs text-slate-400">
                        {{#if isAdmin}}
                            Quản trị viên
                        {{else if isStaff}}
                            Nhân viên
                        {{else}}
                            Người dùng
                        {{/if}}
                    </p>
                </div>

                <i class="fa-solid fa-chevron-down text-xs text-slate-400"></i>
            </button>

            <div
                id="accountMenu"
                class="absolute right-0 mt-2 hidden w-64 rounded-2xl border border-slate-200 bg-white p-2 shadow-soft"
            >
                <div class="border-b border-slate-100 px-3 py-3">
                    <p class="truncate text-sm font-bold text-slate-800">
                        {{authName}}
                    </p>

                    <p class="mt-0.5 truncate text-xs text-slate-500">
                        {{authUser.email}}
                    </p>

                    <span
                        class="mt-2 inline-flex rounded-full bg-kigen-50 px-2.5 py-1 text-xs font-bold text-kigen-700 ring-1 ring-kigen-100"
                    >
                        {{#if isAdmin}}
                            Admin
                        {{else if isStaff}}
                            Staff
                        {{else}}
                            Member
                        {{/if}}
                    </span>
                </div>

                <a
                    href="/admin/profile"
                    class="mt-2 block rounded-xl px-3 py-2 text-sm text-slate-600 hover:bg-slate-100"
                >
                    <i class="fa-regular fa-user mr-2 w-4"></i>
                    Hồ sơ tài khoản
                </a>

                <a
                    href="/admin/settings"
                    class="block rounded-xl px-3 py-2 text-sm text-slate-600 hover:bg-slate-100"
                >
                    <i class="fa-solid fa-gear mr-2 w-4"></i>
                    Cài đặt hệ thống
                </a>

                <button
                    type="button"
                    class="admin-logout-btn mt-2 w-full rounded-xl border-t border-slate-100 px-3 py-2 pt-3 text-left text-sm font-semibold text-rose-600 hover:bg-rose-50"
                >
                    <i class="fa-solid fa-right-from-bracket mr-2 w-4"></i>
                    Đăng xuất
                </button>
            </div>
        </div>
    </div>
</header>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const toggleSidebar = document.getElementById("toggleSidebar");
        const sidebarOverlay = document.getElementById("sidebarOverlay");
        const accountBtn = document.getElementById("accountBtn");
        const accountMenu = document.getElementById("accountMenu");
        const notifyBtn = document.getElementById("notifyBtn");
        const headerSearch = document.getElementById("headerSearch");
        const logoutButtons = document.querySelectorAll(".admin-logout-btn");

        if (toggleSidebar) {
            toggleSidebar.addEventListener("click", function () {
                if (window.innerWidth < 1024) {
                    document.body.classList.toggle("mobile-sidebar-open");
                } else {
                    document.body.classList.toggle("sidebar-collapsed");
                }
            });
        }

        if (sidebarOverlay) {
            sidebarOverlay.addEventListener("click", function () {
                document.body.classList.remove("mobile-sidebar-open");
            });
        }

        if (accountBtn && accountMenu) {
            accountBtn.addEventListener("click", function (event) {
                event.stopPropagation();
                accountMenu.classList.toggle("hidden");
            });

            accountMenu.addEventListener("click", function (event) {
                event.stopPropagation();
            });

            document.addEventListener("click", function () {
                accountMenu.classList.add("hidden");
            });
        }

        if (notifyBtn) {
            notifyBtn.addEventListener("click", function () {
                window.location.href = "/admin/notifications";
            });
        }

        if (headerSearch) {
            headerSearch.addEventListener("keydown", function (event) {
                if (event.key !== "Enter") return;

                const keyword = headerSearch.value.trim();

                if (!keyword) return;

                window.location.href =
                    "/admin/products?keyword=" + encodeURIComponent(keyword);
            });
        }
        
        const apiBaseUrl =
            window.APP_CONFIG?.APP_URL_API || `${window.location.origin}/api`;

        logoutButtons.forEach(function (button) {
            button.addEventListener("click", async function () {
                button.disabled = true;
                button.classList.add("opacity-60", "cursor-not-allowed");

                try {

                    await fetch(`${apiBaseUrl}/logout`, {
                        method: "POST",
                        credentials: "include",
                    });
                } catch (error) {
                    console.error("Logout failed:", error);
                } finally {
                    window.location.href = "/login";
                }
            });
        });
    });
</script>