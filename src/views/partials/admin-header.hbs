<header class="h-16 bg-white border-b border-slate-200 px-6 flex items-center justify-between">
  <div>
    <h1 class="text-lg font-extrabold text-slate-900">
      {{#if title}}{{title}}{{else}}Admin{{/if}}
    </h1>
    <p class="text-xs text-slate-500">
      Quản trị hệ thống Ecom Market
    </p>
  </div>

  <div class="flex items-center gap-3">
    <button class="w-10 h-10 rounded-2xl border border-slate-200 flex items-center justify-center text-slate-600 hover:text-teal-600 hover:border-teal-300 transition">
      <i class="fa-regular fa-bell"></i>
    </button>

    <div class="flex items-center gap-3 pl-3 border-l border-slate-200">
      <div class="w-10 h-10 rounded-2xl bg-teal-600 text-white flex items-center justify-center font-bold">
        A
      </div>
      <div class="hidden sm:block">
        <div class="text-sm font-bold text-slate-900">Admin</div>
        <div class="text-xs text-slate-500">Quản trị viên</div>
      </div>
    </div>
  </div>
</header>