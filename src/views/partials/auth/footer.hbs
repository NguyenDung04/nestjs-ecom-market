<!-- ========== FOOTER ========== -->
<footer
	class="relative z-10 border-t"
	style="
	border-color: rgba(0, 122, 122, 0.06);
	background: rgba(255, 255, 255, 0.7);
	backdrop-filter: blur(8px);
	"
	>
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
		<div
			class="flex flex-col sm:flex-row items-center justify-between gap-4"
			>
			<!-- Logo footer -->
			<div class="flex items-center gap-2">
				<div
					class="w-7 h-7 rounded-md flex items-center justify-center"
					style="background: var(--teal-500)"
					>
					<i
						class="fa-solid fa-bag-shopping text-white text-xs"
						></i>
				</div>
				<span
					class="text-sm font-bold"
					style="color: var(--teal-800)"
					>{{siteName}}</span
					>
			</div>
			<!-- Links footer -->
			<nav
				class="flex items-center gap-4 sm:gap-6"
				aria-label="Liên kết footer"
				>
				<a
					href="#"
					class="link-teal text-xs font-medium"					 
					>Chính sách bảo mật</a
					>
				<a
					href="#"
					class="link-teal text-xs font-medium"
					>Điều khoản sử dụng</a
					>
				<a
					href="#"
					class="link-teal text-xs font-medium"
					>Hỗ trợ</a
					>
			</nav>
			<!-- Copyright -->
			<p class="text-xs text-gray-400">
				&copy; {{currentYear}} {{siteName}}. All rights reserved.
			</p>
		</div>
	</div>
</footer>