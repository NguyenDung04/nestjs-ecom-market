<section class="hidden lg:block" aria-label="Lợi ích tài khoản">
    <div class="max-w-md mx-auto lg:mx-0">
        <div class="mb-8">
            <h1
                class="text-3xl font-bold leading-tight mb-3"
                style="color: var(--teal-900)"
            >
                {{authHeroTitle}}<br />
                <span style="color: var(--teal-500)">{{authHeroHighlight}}</span>
            </h1>

            <p class="text-gray-500 leading-relaxed">
                {{description}}
            </p>
        </div>

        <div class="space-y-4">
            <div
                class="benefit-item flex items-start gap-3.5 p-3.5 rounded-xl transition-colors hover:bg-white/80"
                style="background: rgba(255, 255, 255, 0.5)"
            >
                <div
                    class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
                    style="
                        background: linear-gradient(
                            135deg,
                            var(--teal-50),
                            var(--teal-100)
                        );
                    "
                >
                    <i
                        class="fa-solid fa-box-open text-sm"
                        style="color: var(--teal-600)"
                    ></i>
                </div>

                <div>
                    <h3 class="font-semibold text-sm text-gray-800">
                        Theo dõi đơn hàng
                    </h3>
                    <p class="text-xs text-gray-500 mt-0.5">
                        Cập nhật trạng thái đơn hàng theo thời gian thực
                    </p>
                </div>
            </div>

            <div
                class="benefit-item flex items-start gap-3.5 p-3.5 rounded-xl transition-colors hover:bg-white/80"
                style="background: rgba(255, 255, 255, 0.5)"
            >
                <div
                    class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
                    style="
                        background: linear-gradient(
                            135deg,
                            var(--teal-50),
                            var(--teal-100)
                        );
                    "
                >
                    <i
                        class="fa-solid fa-location-dot text-sm"
                        style="color: var(--teal-600)"
                    ></i>
                </div>

                <div>
                    <h3 class="font-semibold text-sm text-gray-800">
                        Lưu địa chỉ giao hàng
                    </h3>
                    <p class="text-xs text-gray-500 mt-0.5">
                        Quản lý nhiều địa chỉ, đặt hàng nhanh chóng
                    </p>
                </div>
            </div>

            <div
                class="benefit-item flex items-start gap-3.5 p-3.5 rounded-xl transition-colors hover:bg-white/80"
                style="background: rgba(255, 255, 255, 0.5)"
            >
                <div
                    class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
                    style="
                        background: linear-gradient(
                            135deg,
                            var(--teal-50),
                            var(--teal-100)
                        );
                    "
                >
                    <i
                        class="fa-solid fa-ticket text-sm"
                        style="color: var(--teal-600)"
                    ></i>
                </div>

                <div>
                    <h3 class="font-semibold text-sm text-gray-800">
                        Nhận ưu đãi độc quyền
                    </h3>
                    <p class="text-xs text-gray-500 mt-0.5">
                        Mã giảm giá và khuyến mãi dành riêng cho thành viên
                    </p>
                </div>
            </div>

            <div
                class="benefit-item flex items-start gap-3.5 p-3.5 rounded-xl transition-colors hover:bg-white/80"
                style="background: rgba(255, 255, 255, 0.5)"
            >
                <div
                    class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
                    style="
                        background: linear-gradient(
                            135deg,
                            var(--teal-50),
                            var(--teal-100)
                        );
                    "
                >
                    <i
                        class="fa-solid fa-star text-sm"
                        style="color: var(--teal-600)"
                    ></i>
                </div>

                <div>
                    <h3 class="font-semibold text-sm text-gray-800">
                        Đánh giá sản phẩm
                    </h3>
                    <p class="text-xs text-gray-500 mt-0.5">
                        Chia sẻ trải nghiệm và giúp cộng đồng mua sắm tốt hơn
                    </p>
                </div>
            </div>

            <div
                class="benefit-item flex items-start gap-3.5 p-3.5 rounded-xl transition-colors hover:bg-white/80"
                style="background: rgba(255, 255, 255, 0.5)"
            >
                <div
                    class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
                    style="
                        background: linear-gradient(
                            135deg,
                            var(--teal-50),
                            var(--teal-100)
                        );
                    "
                >
                    <i
                        class="fa-solid fa-user-gear text-sm"
                        style="color: var(--teal-600)"
                    ></i>
                </div>

                <div>
                    <h3 class="font-semibold text-sm text-gray-800">
                        Quản lý thông tin cá nhân
                    </h3>
                    <p class="text-xs text-gray-500 mt-0.5">
                        Cập nhật hồ sơ, thay đổi mật khẩu dễ dàng
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>