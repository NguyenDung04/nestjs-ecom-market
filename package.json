{
  "name": "nestjs-ecom-market",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "nest start",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/main.js",
    "start:prod:debug": "cross-env NODE_ENV=production node --inspect dist/main.js",
    "build": "nest build",
    "build:css": "tailwindcss -i ./public/css/app.css -o ./public/css/output.css --watch",
    "build:css:prod": "tailwindcss -i ./public/css/app.css -o ./public/css/output.css --minify",
    "dev": "concurrently \"npm run start:dev\" \"npm run build:css\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "cross-env NODE_ENV=test jest",
    "test:unit": "cross-env NODE_ENV=test jest",
    "test:e2e": "cross-env NODE_ENV=test jest --config ./test/jest-e2e.json --runInBand",
    "test:cov": "cross-env NODE_ENV=test jest --coverage",
    "seed": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register src/database/seeds/seed.ts",
    "migration:generate": "cross-env NODE_ENV=development node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate ./src/database/migrations/AutoMigration -d ./src/database/data-source.ts",
    "migration:show": "cross-env NODE_ENV=development node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:show -d ./src/database/data-source.ts",
    "migration:create": "cross-env NODE_ENV=development node ./node_modules/typeorm/cli.js migration:create ./src/database/migrations/CustomMigration",
    "migration:run": "cross-env NODE_ENV=development node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d ./src/database/data-source.ts",
    "migration:revert": "cross-env NODE_ENV=development node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d ./src/database/data-source.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.12",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.12",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mapped-types": "2.1.1",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.12",
    "@nestjs/serve-static": "5.0.4",
    "@nestjs/swagger": "11.4.1",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/typeorm": "11.0.0",
    "bcrypt": "6.0.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.3",
    "compression": "1.8.1",
    "connect-redis": "9.0.0",
    "cookie-parser": "1.4.7",
    "csrf-csrf": "4.0.3",
    "express-session": "1.19.0",
    "flowbite": "4.0.1",
    "hbs": "4.2.1",
    "helmet": "8.1.0",
    "ioredis": "5.9.3",
    "multer": "2.1.1",
    "mysql2": "3.16.1",
    "nest-winston": "1.10.2",
    "nodemailer": "8.0.7",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "sharp": "0.34.5",
    "swagger-ui-express": "5.0.1",
    "typeorm": "0.3.28",
    "uuid": "9.0.1",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.18.0",
    "@nestjs/cli": "11.0.0",
    "@nestjs/schematics": "11.0.0",
    "@nestjs/testing": "11.0.1",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.0",
    "@types/express-session": "1.19.0",
    "@types/hbs": "4.0.5",
    "@types/jest": "30.0.0",
    "@types/multer": "2.1.0",
    "@types/node": "22.10.7",
    "@types/nodemailer": "8.0.0",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.2",
    "@types/uuid": "9.0.8",
    "autoprefixer": "10.4.27",
    "browser-sync": "3.0.4",
    "concurrently": "9.2.1",
    "cross-env": "7.0.3",
    "dotenv": "17.4.2",
    "eslint": "9.18.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-prettier": "5.2.2",
    "globals": "16.0.0",
    "jest": "30.2.0",
    "postcss": "8.5.8",
    "prettier": "3.4.2",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "tailwindcss": "3.4.13",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typeorm-ts-node-commonjs": "0.3.20",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      ".+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
